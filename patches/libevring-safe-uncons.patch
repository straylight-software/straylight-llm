 -- Model Integration
diff --git a/slide/src/Slide/Wire/Decode.hs b/slide/src/Slide/Wire/Decode.hs
index 9e2d162..f055540 100644
--- a/slide/src/Slide/Wire/Decode.hs
+++ b/slide/src/Slide/Wire/Decode.hs
@@ -212,13 +212,12 @@ decodeFrameIncremental initialState inputBytes =
     processBytes initialState (decodeLeftover initialState <> inputBytes) []
   where
     processBytes :: DecodeState -> ByteString -> [Chunk] -> (DecodeState, [Chunk])
-    processBytes !state !remainingInput !accumulatedChunks
-        | BS.null remainingInput =
-            (state{decodeLeftover = BS.empty}, reverse accumulatedChunks)
-        | otherwise =
-            let currentByte = BS.head remainingInput
-                restOfInput = BS.tail remainingInput
-             in case decodeSingleByte state currentByte restOfInput of
+    processBytes !state !remainingInput !accumulatedChunks =
+        case BS.uncons remainingInput of
+            Nothing ->
+                (state{decodeLeftover = BS.empty}, reverse accumulatedChunks)
+            Just (currentByte, restOfInput) ->
+                case decodeSingleByte state currentByte restOfInput of
                     Left leftoverBytes ->
                         (state{decodeLeftover = leftoverBytes}, reverse accumulatedChunks)
                     Right (newState, maybeChunk, bytesRemaining) ->
diff --git a/slide/test/EncodeSpec.hs b/slide/test/EncodeSpec.hs
index 673cd3f..3bea9ba 100644
--- a/slide/test/EncodeSpec.hs
+++ b/slide/test/EncodeSpec.hs
@@ -34,7 +34,9 @@ spec = do
     describe "encodeExtendedToken" $ do
         it "uses OP_EXTENDED prefix" $ do
             let frame = encodeExtendedToken 128
-            BS.head (frameBytes frame) `shouldBe` unFrameOp OP_EXTENDED
+            case BS.uncons (frameBytes frame) of
+                Just (firstByte, _) -> firstByte `shouldBe` unFrameOp OP_EXTENDED
+                Nothing -> expectationFailure "Frame should not be empty"
 
         it "encodes 128 correctly" $ do
             frameBytes (encodeExtendedToken 128) `shouldBe` BS.pack [0x80, 0x80, 0x01]
diff --git a/slide/test/StressSpec.hs b/slide/test/StressSpec.hs
index 55bf403..95629bf 100644
--- a/slide/test/StressSpec.hs
+++ b/slide/test/StressSpec.hs
@@ -443,15 +443,15 @@ feedOneByte (state, accChunks) byte =
 decodeIncremental :: ByteString -> [Chunk]
 decodeIncremental bytes = go initDecodeState bytes []
   where
-    go state remaining acc
-        | BS.null remaining = 
-            case flushDecoder state of
-                Just chunk -> acc ++ [chunk]
-                Nothing -> acc
-        | otherwise =
-            let (byte, rest) = (BS.head remaining, BS.tail remaining)
-                (newState, chunks) = feedBytes state (BS.singleton byte)
-            in go newState rest (acc ++ chunks)
+    go state remaining acc =
+        case BS.uncons remaining of
+            Nothing ->
+                case flushDecoder state of
+                    Just chunk -> acc ++ [chunk]
+                    Nothing -> acc
+            Just (byte, rest) ->
+                let (newState, chunks) = feedBytes state (BS.singleton byte)
+                in go newState rest (acc ++ chunks)
 
