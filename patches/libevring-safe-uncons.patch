From e71ebe07e296079442b22f9bfc414b407ee7a647 Mon Sep 17 00:00:00 2001
From: justinfleek <justinfleek@users.noreply.github.com>
Date: Mon, 23 Feb 2026 11:19:24 +0000
Subject: [PATCH] fix: replace partial BS.head/BS.tail with total BS.uncons

Replace all uses of partial functions BS.head and BS.tail with
the total alternative BS.uncons, which returns Maybe (Word8, ByteString).

This prevents potential runtime exceptions if the ByteString is empty,
even though the current code checks for empty before calling.
Using BS.uncons makes the safety invariant explicit in the pattern match.

Files changed:
- hs/Evring/Sigil.hs: processBytes function
- hs/test/Evring/Test/Sigil.hs: processTestBytes function
- slide/src/Slide/Wire/Decode.hs: processBytes function
- slide/src/Slide/Tokenizer.hs: tokenToId function
- slide/test/EncodeSpec.hs: frame byte assertion
- slide/test/StressSpec.hs: byte-by-byte decoding loop

No functional changes - this is a safety refactor only.
---
 hs/Evring/Sigil.hs             | 11 +++++------
 hs/test/Evring/Test/Sigil.hs   | 11 +++++------
 slide/src/Slide/Tokenizer.hs   |  6 +++---
 slide/src/Slide/Wire/Decode.hs | 13 ++++++-------
 slide/test/EncodeSpec.hs       |  4 +++-
 slide/test/StressSpec.hs       | 18 +++++++++---------
 6 files changed, 31 insertions(+), 32 deletions(-)

diff --git a/hs/Evring/Sigil.hs b/hs/Evring/Sigil.hs
index 552adf4..6dec10c 100644
--- a/hs/Evring/Sigil.hs
+++ b/hs/Evring/Sigil.hs
@@ -470,12 +470,11 @@ processBytes ::
   ByteString ->
   [Chunk] ->
   (SigilState, [Chunk])
-processBytes !state !input !acc
-  | BS.null input = (state { sigilLeftover = BS.empty }, reverse acc)
-  | otherwise =
-      let byte = BS.head input
-          rest = BS.tail input
-      in case decodeSingleByte state byte rest of
+processBytes !state !input !acc =
+  case BS.uncons input of
+    Nothing -> (state { sigilLeftover = BS.empty }, reverse acc)
+    Just (byte, rest) ->
+      case decodeSingleByte state byte rest of
         Left leftover ->
           (state { sigilLeftover = leftover }, reverse acc)
         Right (newState, maybeChunk, remaining) ->
diff --git a/hs/test/Evring/Test/Sigil.hs b/hs/test/Evring/Test/Sigil.hs
index cf7dac4..abc9ea4 100644
--- a/hs/test/Evring/Test/Sigil.hs
+++ b/hs/test/Evring/Test/Sigil.hs
@@ -216,12 +216,11 @@ prop_streamEndDone =
 processTestBytes :: SigilState -> ByteString -> (SigilState, [Chunk])
 processTestBytes state input = go state input []
   where
-    go !s !bs !acc
-      | BS.null bs = (s { sigilLeftover = BS.empty }, reverse acc)
-      | otherwise =
-          let byte = BS.head bs
-              rest = BS.tail bs
-          in case decodeByte s byte rest of
+    go !s !bs !acc =
+      case BS.uncons bs of
+        Nothing -> (s { sigilLeftover = BS.empty }, reverse acc)
+        Just (byte, rest) ->
+          case decodeByte s byte rest of
             Left leftover -> (s { sigilLeftover = leftover }, reverse acc)
             Right (newState, maybeChunk, remaining) ->
               let newAcc = maybe acc (: acc) maybeChunk
diff --git a/slide/src/Slide/Tokenizer.hs b/slide/src/Slide/Tokenizer.hs
index 2b242e1..6ff21bf 100644
--- a/slide/src/Slide/Tokenizer.hs
+++ b/slide/src/Slide/Tokenizer.hs
@@ -148,9 +148,9 @@ vocabSize HFTokenizerIdentity = pure 256
 tokenToId :: HFTokenizer -> Text -> IO (Maybe Word32)
 tokenToId HFTokenizerIdentity token = do
     let bytes = TE.encodeUtf8 token
-    if BS.length bytes == 1
-        then pure $ Just (fromIntegral (BS.head bytes))
-        else pure Nothing
+    case BS.uncons bytes of
+        Just (byte, rest) | BS.null rest -> pure $ Just (fromIntegral byte)
+        _ -> pure Nothing
 
