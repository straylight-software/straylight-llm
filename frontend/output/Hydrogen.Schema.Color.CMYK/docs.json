"Prim"],"Int"],"tag":"TypeConstructor"},{"annotation":[],"contents":["k",{"annotation":[],"contents":[["Prim"],"Int"],"tag":"TypeConstructor"},{"annotation":[],"tag":"REmpty"}],"tag":"RCons"}],"tag":"RCons"}],"tag":"RCons"}],"tag":"RCons"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[141,67],"name":"../../hydrogen/src/Hydrogen/Schema/Color/CMYK.purs","start":[141,1]},"title":"cmykToRecord"},{"children":[],"comments":"Convert to CSS device-cmyk() function string.\n\nUses CSS Color Level 4 device-cmyk() syntax:\n```purescript\ncmykToCss (cmyk 0 100 100 0)  -- \"device-cmyk(0%, 100%, 100%, 0%)\"\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","CMYK"],"CMYK"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"String"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[159,28],"name":"../../hydrogen/src/Hydrogen/Schema/Color/CMYK.purs","start":[159,1]},"title":"cmykToCss"},{"children":[],"comments":"Convert RGB to CMYK.\n\nThis is an approximation - actual conversion depends on color profiles,\nink characteristics, and paper type. For print-accurate conversion,\nuse ICC color profiles.\n\nAlgorithm:\n1. Normalize RGB to 0.0-1.0\n2. Calculate K = 1 - max(R, G, B)\n3. If K = 1 (black), C=M=Y=0\n4. Otherwise: C = (1-R-K)/(1-K), M = (1-G-K)/(1-K), Y = (1-B-K)/(1-K)\n\n```purescript\nrgbToCmyk (RGB.rgb 255 0 0)  -- Red → CMYK(0, 100, 100, 0)\nrgbToCmyk (RGB.rgb 0 0 0)    -- Black → CMYK(0, 0, 0, 100)\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","CMYK"],"CMYK"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[187,29],"name":"../../hydrogen/src/Hydrogen/Schema/Color/CMYK.purs","start":[187,1]},"title":"rgbToCmyk"},{"children":[],"comments":"Convert CMYK to RGB.\n\nThis is an approximation - actual conversion depends on color profiles,\nink characteristics, and paper type. For accurate conversion, use ICC\ncolor profiles.\n\nAlgorithm:\n1. Normalize CMYK to 0.0-1.0\n2. R = 255 × (1-C) × (1-K)\n3. G = 255 × (1-M) × (1-K)\n4. B = 255 × (1-Y) × (1-K)\n\n```purescript\ncmykToRgb (cmyk 0 100 100 0)  -- CMYK Red → RGB(255, 0, 0)\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","CMYK"],"CMYK"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[227,29],"name":"../../hydrogen/src/Hydrogen/Schema/Color/CMYK.purs","start":[227,1]},"title":"cmykToRgb"}],"name":"Hydrogen.Schema.Color.CMYK","reExports":[]}