{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                           // hydrogen // schema // typography"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Typography pillar - type systems for autonomous brand generation."},{"LineComment":" |"},{"LineComment":" | A comprehensive system for working with:"},{"LineComment":" |"},{"LineComment":" | ## Atoms (Primitives)"},{"LineComment":" | - **FontWeight**: Stroke thickness (1-1000, CSS font-weight scale)"},{"LineComment":" | - **FontSize**: Em-square height in CSS pixels"},{"LineComment":" | - **LineHeight**: Vertical rhythm as unitless ratio"},{"LineComment":" | - **LetterSpacing**: Tracking in per mille (thousandths of em)"},{"LineComment":" | - **TextTransform**: Case transformation (uppercase, lowercase, etc.)"},{"LineComment":" | - **FontFamily**: Typeface identification (string, not enumerable)"},{"LineComment":" |"},{"LineComment":" | ## Font Sources"},{"LineComment":" | - **SystemFont**: Pre-installed fonts (enumerable, no loading)"},{"LineComment":" | - **CustomFont**: Requires import (Google Fonts, Adobe, self-hosted)"},{"LineComment":" |"},{"LineComment":" | ## Molecules (Compounds)"},{"LineComment":" | - **TypeStyle**: Complete style = family + weight + size + line-height + tracking + transform"},{"LineComment":" | - **FontStack**: Ordered fallback list of font families"},{"LineComment":" |"},{"LineComment":" | ## Compounds (Systems)"},{"LineComment":" | - **TypeScale**: Base size + ratio for mathematical hierarchy"},{"LineComment":" | - **TypeHierarchy**: Semantic levels (H1-H6, body, etc.) mapped to styles"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Schema.Typography.FontFamily as FF"},{"LineComment":" | import Hydrogen.Schema.Typography.FontWeight as FW"},{"LineComment":" | import Hydrogen.Schema.Typography.TypeStyle as TS"},{"LineComment":" | import Hydrogen.Schema.Typography.TypeScale as Scale"},{"LineComment":" | import Hydrogen.Schema.Typography.TypeHierarchy as TH"},{"LineComment":" |"},{"LineComment":" | -- Create a type style"},{"LineComment":" | heading = TS.typeStyle "},{"LineComment":" |   (FF.fontFamily \"Archivo\")"},{"LineComment":" |   FW.extraBold"},{"LineComment":" |   (FontSize.fontSize 32.0)"},{"LineComment":" |   LineHeight.tight"},{"LineComment":" |   LetterSpacing.uppercase"},{"LineComment":" |   TextTransform.Uppercase"},{"LineComment":" |"},{"LineComment":" | -- Generate a hierarchy from a scale"},{"LineComment":" | hierarchy = TH.generate"},{"LineComment":" |   { scale: Scale.defaultScale"},{"LineComment":" |   , headingStack: TS.singleFont (FF.fontFamily \"Archivo\")"},{"LineComment":" |   , bodyStack: TS.singleFont (FF.fontFamily \"Poppins\")"},{"LineComment":" |   , headingWeight: FW.extraBold"},{"LineComment":" |   , bodyWeight: FW.normal"},{"LineComment":" |   , headingLineHeight: LineHeight.tight"},{"LineComment":" |   , bodyLineHeight: LineHeight.relaxed"},{"LineComment":" |   , headingLetterSpacing: LetterSpacing.none"},{"LineComment":" |   , bodyLetterSpacing: LetterSpacing.normal"},{"LineComment":" |   , useUppercaseHeadings: true"},{"LineComment":" |   }"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Type Safety"},{"LineComment":" |"},{"LineComment":" | Each atom is a distinct newtype. You cannot accidentally use a FontWeight"},{"LineComment":" | where a FontSize is expected. Conversions to CSS are explicit."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | Typography primitives model typographic concepts, not CSS properties."},{"LineComment":" | The CSS conversion happens at the boundary. This allows the same types"},{"LineComment":" | to target different rendering backends (web, native, PDF, etc.)."}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[73,40],"start":[73,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Typography"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Typography.purs","reExports":{},"sourceSpan":{"end":[73,40],"start":[73,1]}}