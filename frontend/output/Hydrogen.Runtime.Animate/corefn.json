:" |"},{"LineComment":" | ## Tween Animation Pattern"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | type State = { opacity :: Animate.TweenState }"},{"LineComment":" |"},{"LineComment":" | update = case _ of"},{"LineComment":" |   FadeIn -> "},{"LineComment":" |     transition state"},{"LineComment":" |       { opacity = Animate.tweenTo state.opacity 1.0 300.0 easeOutCubic }"},{"LineComment":" |       (animationFrame Tick)"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" |"},{"LineComment":" | - `Hydrogen.Runtime.Animate.Spring` - Physics-based spring animations"},{"LineComment":" | - `Hydrogen.Runtime.Animate.Tween` - Duration-based tween animations"},{"LineComment":" | - `Hydrogen.Runtime.Animate.Style` - CSS transform/style helpers"},{"LineComment":" | - `Hydrogen.Runtime.Animate.Vec2` - 2D vector animations"},{"LineComment":" | - `Hydrogen.Runtime.Animate.Color` - RGB color animations"},{"LineComment":" | - `Hydrogen.Runtime.Animate.Animator` - Multi-property animation manager"},{"LineComment":" | - `Hydrogen.Runtime.Animate.Sequence` - Animation sequencing"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[149,4],"start":[135,1]}},"moduleName":["Hydrogen","Runtime","Animate","Animator"]},{"annotation":{"meta":null,"sourceSpan":{"end":[133,4],"start":[124,1]}},"moduleName":["Hydrogen","Runtime","Animate","Color"]},{"annotation":{"meta":null,"sourceSpan":{"end":[160,4],"start":[151,1]}},"moduleName":["Hydrogen","Runtime","Animate","Sequence"]},{"annotation":{"meta":null,"sourceSpan":{"end":[93,4],"start":[85,1]}},"moduleName":["Hydrogen","Runtime","Animate","Spring"]},{"annotation":{"meta":null,"sourceSpan":{"end":[112,4],"start":[105,1]}},"moduleName":["Hydrogen","Runtime","Animate","Style"]},{"annotation":{"meta":null,"sourceSpan":