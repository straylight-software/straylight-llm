,"contents":[["Data","Ord"],"Ord"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Elevation","DepthOfField"],"BokehRadius"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[229,50],"name":"../../hydrogen/src/Hydrogen/Schema/Elevation/DepthOfField.purs","start":[229,1]},"title":"ordBokehRadius"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Show"],"Show"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Elevation","DepthOfField"],"BokehRadius"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[232,50],"name":"../../hydrogen/src/Hydrogen/Schema/Elevation/DepthOfField.purs","start":[231,1]},"title":"showBokehRadius"}],"comments":"Maximum bokeh (blur) radius in pixels.\n\nThis is the maximum blur radius applied to out-of-focus elements.\nThe actual blur scales with distance from focal plane.\n\nValues clamped to >= 0.\n","info":{"dataDeclType":"newtype","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[226,41],"name":"../../hydrogen/src/Hydrogen/Schema/Elevation/DepthOfField.purs","start":[226,1]},"title":"BokehRadius"},{"children":[],"comments":"Create a bokeh radius\n\nValue clamped to >= 0.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Elevation","DepthOfField"],"BokehRadius"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[237,37],"name":"../../hydrogen/src/Hydrogen/Schema/Elevation/DepthOfField.purs","start":[237,1]},"title":"bokehRadius"},{"children":[],"comments":"Extract the bokeh radius value\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"anno