r"},{"annotation":[],"contents":["pr",{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"},{"annotation":[],"tag":"REmpty"}],"tag":"RCons"}],"tag":"RCons"}],"tag":"RCons"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[346,70],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Video.purs","start":[346,1]},"title":"yPbPrToRecord"},{"children":[],"comments":"Convert RGB to YCbCr (ITU-R BT.601)\n\nStandard conversion matrix for SD video:\nY  =  0.299 R + 0.587 G + 0.114 B\nCb = -0.169 R - 0.331 G + 0.500 B\nCr =  0.500 R - 0.419 G - 0.081 B\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Video"],"YCbCr"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[363,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Video.purs","start":[363,1]},"title":"rgbToYCbCr"},{"children":[],"comments":"Convert YCbCr to RGB (ITU-R BT.601)\n\nInverse conversion:\nR = Y + 1.402 Cr\nG = Y - 0.344 Cb - 0.714 Cr\nB = Y + 1.772 Cb\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Video"],"YCbCr"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[379,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Video.purs","start":[379,1]},"title":"yCbCrToRgb"},{"children":[],"comments":"Convert RGB to YIQ (NTSC)\n\nY = 0.299 R + 0.587 G + 0.114 B\nI = 0.596 R - 0.274 G - 0.322 B\nQ = 0.211 R - 0.523 G + 0.312 B\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Video"],"YIQ"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[398,27],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Video.purs","start":[398,1]},"title":"rgbToYIQ"},{"children":[],"comments":"Convert YIQ to RGB (NTSC)\n\nR = Y + 0.956 I + 0.621 Q\nG = Y - 0.272 I - 0.647 Q\nB = Y - 1.105 I + 1.702 Q\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Video"],"YIQ"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[413,27],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Video.purs","start":[413,1]},"title":"yIQToRgb"},{"children":[],"comments":"Convert RGB to YPbPr (Component Analog Video)\n\nYPbPr uses the same matrix as YCbCr for ITU-R BT.601.\nThe difference is in signal levels for analog transmission.\nY  =  0.299 R + 0.587 G + 0.114 B\nPb = -0.169 R - 0.331 G + 0.500 B\nPr =  0.500 R - 0.419 G - 0.081 B\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Video"],"YPbPr"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[434,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Video.purs","start":[434,1]},"title":"rgbToYPbPr"},{"children":[],"comments":"Convert YPbPr to RGB (Component Analog Video)\n\nR = Y + 1.402 Pr\nG = Y - 0.344 Pb - 0.714 Pr\nB = Y + 1.772 Pb\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Video"],"YPbPr"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[449,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Video.purs","start":[449,1]},"title":"yPbPrToRgb"},{"children":[],"comments":"Convert YCbCr to YPbPr\n\nThese are mathematically equivalent, just different naming conventions.\nYCbCr is digital (scaled 16-235), YPbPr is analog (0.0-1.0).\nThis conversion assumes normalized values (0.0-1.0 for Y, -0.5 to 0.5 for chroma).\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Video"],"YCbCr"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Video"],"YPbPr"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[472,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Video.purs","start":[472,1]},"title":"yCbCrToYPbPr"},{"children":[],"comments":"Convert YPbPr to YCbCr\n\nThese are mathematically equivalent, just different naming conventions.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Video"],"YPbPr"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Video"],"YCbCr"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[482,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Video.purs","start":[482,1]},"title":"yPbPrToYCbCr"},{"children":[],"comments":"Convert YUV to YCbCr\n\nYUV (analog PAL) and YCbCr (digital) use different scaling factors.\nYUV: U and V are in range -0.5 to 0.5\nYCbCr: Cb and Cr are also in range -0.5 to 0.5 (for normalized values)\nThe main difference is in how they're encoded for transmission.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","YUV"],"YUV"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Video"],"YCbCr"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[495,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Video.purs","start":[495,1]},"title":"yuvToYCbCr"},{"children":[],"comments":"Convert YCbCr to YUV\n\nDirect mapping between normalized YCbCr and YUV.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Video"],"YCbCr"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","YUV"],"YUV"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[503,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Video.purs","start":[503,1]},"title":"yCbCrToYuv"}],"name":"Hydrogen.Schema.Color.Video","reExports":[]}