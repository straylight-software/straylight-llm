2...\"\n```\n","info":{"dataDeclType":"data","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[100,14],"name":"../../hydrogen/src/Hydrogen/Element/Compound/Carousel/Item/Shape.purs","start":[93,1]},"title":"ItemShape"},{"children":[],"comments":"Create rectangular shape with corner radius\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Element","Compound","Carousel","Item","Shape"],"ItemShape"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[118,33],"name":"../../hydrogen/src/Hydrogen/Element/Compound/Carousel/Item/Shape.purs","start":[118,1]},"title":"itemShape"},{"children":[],"comments":"No shape clipping (default rectangle, no radius)\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Element","Compound","Carousel","Item","Shape"],"ItemShape"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[126,25],"name":"../../hydrogen/src/Hydrogen/Element/Compound/Carousel/Item/Shape.purs","start":[126,1]},"title":"noItemShape"},{"children":[],"comments":"Rectangle with rounded corners\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Element","Compound","Carousel","Item","Shape"],"ItemShape"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[130,38],"name":"../../hydrogen/src/Hydrogen/Element/Compound/Carousel/Item/Shape.purs","start":[130,1]},"title":"rectangleShape"},{"children":[],"comments":"Star-shaped item with configurable points\n\n- points: Nu