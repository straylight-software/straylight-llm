{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                           // hydrogen // optimize // submodular // continuous"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Continuous Relaxation for Submodular Optimization."},{"LineComment":" |"},{"LineComment":" | ## Theoretical Foundation"},{"LineComment":" |"},{"LineComment":" | The multilinear extension F : [0,1]^n → ℝ of f : 2^V → ℝ is:"},{"LineComment":" |"},{"LineComment":" |   F(x) = 𝔼_{S ~ x}[f(S)] = Σ_{S ⊆ V} f(S) ∏_{e ∈ S} x_e ∏_{e ∉ S} (1 - x_e)"},{"LineComment":" |"},{"LineComment":" | Where S ~ x means each element e is included independently with probability x_e."},{"LineComment":" |"},{"LineComment":" | Key properties:"},{"LineComment":" | - F(1_S) = f(S) for indicator vectors"},{"LineComment":" | - F is multilinear (linear in each coordinate)"},{"LineComment":" | - ∂F/∂x_e = 𝔼_{S ~ x_{-e}}[f(S ∪ {e}) - f(S)] (expected marginal gain)"},{"LineComment":" | - F is concave along any direction if f is submodular"},{"LineComment":" |"},{"LineComment":" | ## Gradient Estimation"},{"LineComment":" |"},{"LineComment":" | Computing F(x) exactly requires exponentially many evaluations."},{"LineComment":" | We use two-point gradient estimation:"},{"LineComment":" |"},{"LineComment":" |   ∇F(x) ≈ (F(x + δ) - F(x - δ)) / (2δ) · d"},{"LineComment":" |"},{"LineComment":" | Where d is the perturbation direction."},{"LineComment":" |"},{"LineComment":" | For coordinates: ∂F/∂x_e ≈ (f(S ∪ {e}) - f(S)) sampled over S ~ x."},{"LineComment":" |"},{"LineComment":" | ## Frank-Wolfe Algorithm"},{"LineComment":" |"},{"LineComment":" | Continuous greedy maximizes F over the matroid polytope:"},{"LineComment":" |"},{"LineComment":" |   x_{t+1} = x_t + (1/T) · v_t"},{"LineComment":" |"},{"LineComment":" | Where v_t = argmax_{v ∈ P} ⟨∇F(x_t), v⟩ is a linear maximization oracle."},{"LineComment":" |"},{"LineComment":" | For matroid polytopes, this reduces to greedy selection."},{"LineComment":" |"},{"LineComment":" | ## Billion-Agent Context"},{"LineComment":" |"},{"LineComment":" | Continuous relaxation enables:"},{"LineComment":" | - Fractional solutions for load balancing across agents"},{"LineComment":" | - Smooth optimization landscapes for gradient methods"},{"LineComment":" | - Provable approximation guarantees with rounding"},{"LineComment":" |"},{"LineComment":" | Agents can solve relaxed problems independently, then coordinate rounding."},{"LineComment":" |"},{"LineComment":" | ## References"},{"LineComment":" |"},{"LineComment":" | - Vondrák, J. \"Optimal approximation for the submodular welfare problem"},{"LineComment":" |   in the value oracle model\" STOC 2008"},{"LineComment":" | - Calinescu et al. \"Maximizing a Monotone Submodular Function Subject"},{"LineComment":" |   to a Matroid Constraint\" SICOMP 2011"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This leader module re-exports from submodules:"},{"LineComment":" | - Continuous.Utilities: Number/Int conversion helpers"},{"LineComment":" | - Continuous.FractionalSolution: Fractional points in [0,1]^n"},{"LineComment":" | - Continuous.Multilinear: Multilinear extension evaluation"},{"LineComment":" | - Continuous.MatroidPolytope: Polytope membership and optimization"},{"LineComment":" | - Continuous.Greedy: Standard continuous greedy algorithm"},{"LineComment":" | - Continuous.FAA: FAA-enhanced continuous greedy (√T speedup)"},{"LineComment":" | - Continuous.Gradient: Gradient estimation methods"},{"LineComment":" | - Continuous.Rounding: Converting fractional to discrete solutions"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[144,11],"start":[137,1]}},"moduleName":["Hydrogen","Optimize","Submodular","Continuous","FAA"]},{"annotation":{"meta":null,"sourceSpan":{"end":[111,26],"start":[97,1]}},"moduleName":["Hydrogen","Optimize","Submodular","Continuous","FractionalSolution"]},{"annotation":{"meta":null,"sourceSpan":{"end":[151,16],"start":[146,1]}},"moduleName":["Hydrogen","Optimize","Submodular","Continuous","Gradient"]},{"annotation":{"meta":null,"sourceSpan":{"end":[135,14],"start":[130,1]}},"moduleName":["Hydrogen","Optimize","Submodular","Continuous","Greedy"]},{"annotation":{"meta":null,"sourceSpan":{"end":[128,23],"start":[123,1]}},"moduleName":["Hydrogen","Optimize","Submodular","Continuous","MatroidPolytope"]},{"annotation":{"meta":null,"sourceSpan":{"end":[121,19],"start":[113,1]}},"moduleName":["Hydrogen","Optimize","Submodular","Continuous","Multilinear"]},{"annotation":{"meta":null,"sourceSpan":{"end":[157,16],"start":[153,1]}},"moduleName":["Hydrogen","Optimize","Submodular","Continuous","Rounding"]},{"annotation":{"meta":null,"sourceSpan":{"end":[157,16],"start":[70,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Optimize","Submodular","Continuous"],"modulePath":"../../hydrogen/src/Hydrogen/Optimize/Submodular/Continuous.purs","reExports":{"Hydrogen.Optimize.Submodular.Continuous.FAA":["FAAConfig","continuousGreedyFAA","continuousGreedyStepFAA","faaIterations","faaStepSize","mkFAAConfig"],"Hydrogen.Optimize.Submodular.Continuous.FractionalSolution":["FractionalSolution","addScaled","mkFractionalSolution","mkFractionalSolutionBounded","ones","solutionCoord","solutionCoordBounded","solutionCoords","solutionSupport","solutionValue","solutionValueBounded","uniform","zeroes"],"Hydrogen.Optimize.Submodular.Continuous.Gradient":["GradientEstimate","coordinateGradient","stochasticGradient","twoPointEstimate"],"Hydrogen.Optimize.Submodular.Continuous.Greedy":["ContinuousGreedyConfig","continuousGreedy","continuousGreedyStep","mkContinuousGreedyConfig"],"Hydrogen.Optimize.Submodular.Continuous.MatroidPolytope":["MatroidPolytope","isInPolytope","linearMaximize","mkMatroidPolytope"],"Hydrogen.Optimize.Submodular.Continuous.Multilinear":["MultilinearExt","evalMultilinear","evalMultilinearSampled","gradientSampled","mkMultilinearExt","partialDerivative","sampleOnce"],"Hydrogen.Optimize.Submodular.Continuous.Rounding":["dependentRound","sampleSolution","thresholdRound"]},"sourceSpan":{"end":[157,16],"start":[70,1]}}