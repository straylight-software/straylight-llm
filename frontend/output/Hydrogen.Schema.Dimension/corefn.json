{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                           // hydrogen // schema // dimension"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Dimension pillar - measurement, space, and spatial reasoning."},{"LineComment":" |"},{"LineComment":" | A comprehensive system for working with:"},{"LineComment":" |"},{"LineComment":" | - **Physical**: Real-world units (meters, inches, points)"},{"LineComment":" | - **Device**: Display-dependent units (pixels, device pixels, dp, sp)"},{"LineComment":" | - **Angular**: Rotation and direction (radians, degrees, turns)"},{"LineComment":" | - **Temporal**: Time and duration (seconds, frames, frame rates)"},{"LineComment":" | - **Context**: Display properties for unit conversion (PPI, DPR)"},{"LineComment":" | - **Vector**: 2D, 3D, 4D, and N-dimensional coordinates"},{"LineComment":" | - **Camera**: Cinematography vocabulary (dolly, truck, pan, tilt)"},{"LineComment":" |"},{"LineComment":" | ## Type Safety"},{"LineComment":" |"},{"LineComment":" | Each unit is a distinct newtype. You cannot accidentally add meters"},{"LineComment":" | to pixels, or radians to degrees. Conversions require explicit context."},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Schema.Dimension.Physical as Phys"},{"LineComment":" | import Hydrogen.Schema.Dimension.Device as Dev"},{"LineComment":" | import Hydrogen.Schema.Dimension.Context as Ctx"},{"LineComment":" |"},{"LineComment":" | -- Physical measurements"},{"LineComment":" | width :: Phys.Meter"},{"LineComment":" | width = Phys.meters 1.5"},{"LineComment":" |"},{"LineComment":" | -- Device measurements"},{"LineComment":" | buttonSize :: Dev.Pixel"},{"LineComment":" | buttonSize = Dev.px 48.0"},{"LineComment":" |"},{"LineComment":" | -- Convert between them"},{"LineComment":" | physicalSize :: Phys.Inch"},{"LineComment":" | physicalSize = Ctx.pixelsToInch myDisplayContext buttonSize"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | Re-exports all Dimension submodules."}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[44,39],"start":[44,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Dimension"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Dimension.purs","reExports":{},"sourceSpan":{"end":[44,39],"start":[44,1]}}