{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                     // hydrogen // element // widget // table"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Table Widget — Tabular data display with sorting and pagination."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | A Table widget displays data in rows and columns with:"},{"LineComment":" | - Column definitions (type, label, alignment, width)"},{"LineComment":" | - Row data as arrays of cell values"},{"LineComment":" | - Pagination state and controls"},{"LineComment":" | - Optional sorting by column"},{"LineComment":" | - Optional row selection"},{"LineComment":" | - Optional search filtering"},{"LineComment":" |"},{"LineComment":" | The widget accepts complete `TableData` — all data, column defs, and"},{"LineComment":" | pagination state are provided upfront. Pure data in, Element out."},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Element.Compound.Widget.Table as Table"},{"LineComment":" |"},{"LineComment":" | Table.tableWidget []"},{"LineComment":" |   { columns:"},{"LineComment":" |       [ { key: \"name\", label: \"Name\", colType: Table.ColText, ... }"},{"LineComment":" |       , { key: \"amount\", label: \"Amount\", colType: Table.ColCurrency, ... }"},{"LineComment":" |       ]"},{"LineComment":" |   , rows:"},{"LineComment":" |       [ [ Table.TextCell \"John Doe\", Table.NumberCell 1234.56 ]"},{"LineComment":" |       , [ Table.TextCell \"Jane Smith\", Table.NumberCell 5678.90 ]"},{"LineComment":" |       ]"},{"LineComment":" |   , pagination: Just { page: 1, pageSize: 10, total: 100, totalPages: 10 }"},{"LineComment":" |   , ..."},{"LineComment":" |   }"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" | - `Table.Types` — Core data types (ColumnType, CellValue, Pagination, etc.)"},{"LineComment":" | - `Table.Props` — Property types and builders"},{"LineComment":" | - `Table.Pagination` — Pagination helper functions"},{"LineComment":" | - `Table.Render` — Rendering functions"},{"LineComment":" | - `Table.Helpers` — Utility functions"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[60,65],"start":[60,1]}},"moduleName":["Hydrogen","Element","Compound","Widget","Table","Helpers"]},{"annotation":{"meta":null,"sourceSpan":{"end":[58,71],"start":[58,1]}},"moduleName":["Hydrogen","Element","Compound","Widget","Table","Pagination"]},{"annotation":{"meta":null,"sourceSpan":{"end":[57,61],"start":[57,1]}},"moduleName":["Hydrogen","Element","Compound","Widget","Table","Props"]},{"annotation":{"meta":null,"sourceSpan":{"end":[59,63],"start":[59,1]}},"moduleName":["Hydrogen","Element","Compound","Widget","Table","Render"]},{"annotation":{"meta":null,"sourceSpan":{"end":[56,61],"start":[56,1]}},"moduleName":["Hydrogen","Element","Compound","Widget","Table","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[60,65],"start":[48,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Element","Compound","Widget","Table"],"modulePath":"../../hydrogen/src/Hydrogen/Element/Compound/Widget/Table.purs","reExports":{"Hydrogen.Element.Compound.Widget.Table.Helpers":["arrayMax","arrayMin","formatNumber","mod","toNumber"],"Hydrogen.Element.Compound.Widget.Table.Pagination":["hasNextPage","hasPrevPage","pageRange","range","totalPages"],"Hydrogen.Element.Compound.Widget.Table.Props":["bordered","className","compact","defaultProps","searchable","selectable","striped"],"Hydrogen.Element.Compound.Widget.Table.Render":["generateSparklinePath","renderCellC