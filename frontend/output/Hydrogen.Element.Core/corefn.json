{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                                 // hydrogen // element // core"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Element Core — Pure data description of visual elements."},{"LineComment":" |"},{"LineComment":" | ## Purpose"},{"LineComment":" |"},{"LineComment":" | This module defines the CORRECT Element type: pure data composed entirely"},{"LineComment":" | from Schema atoms. No strings. No DOM concepts. No CSS. No JavaScript."},{"LineComment":" |"},{"LineComment":" | This replaces the broken `Hydrogen.Render.Element` which uses:"},{"LineComment":" |   - `tag :: String` (unbounded, non-deterministic)"},{"LineComment":" |   - `Attr String String` (CSS as strings)"},{"LineComment":" |"},{"LineComment":" | ## Architecture"},{"LineComment":" |"},{"LineComment":" | Element is pure data that flows:"},{"LineComment":" |   Haskell backend → PureScript types → WebGPU execution"},{"LineComment":" |"},{"LineComment":" | There is no browser in this stack. JavaScript is treated as legacy"},{"LineComment":" | bytecode only at the export boundary for broken legacy formats."},{"LineComment":" |"},{"LineComment":" | ## Design Principles"},{"LineComment":" |"},{"LineComment":" | 1. **Composed from Schema atoms** — Every field uses bounded, typed atoms"},{"LineComment":" | 2. **GPU-native** — Describes what to render, not how"},{"LineComment":" | 3. **Deterministic** — Same Element = same pixels, always"},{"LineComment":" | 4. **Serializable** — Can be sent over wire, stored, replayed"},{"LineComment":" | 5. **Target-agnostic** — WebGPU, Canvas, Static HTML, any renderer"},{"LineComment":" |"},{"LineComment":" | ## What Element IS"},{"LineComment":" |"},{"LineComment":" | Element is a complete GPU instruction set as pure data:"},{"LineComment":" |   - Shapes (Rectangle, Ellipse, Path)"},{"LineComment":" |   - Fills (Solid, Gradient, Pattern, Noise)"},{"LineComment":" |   - Strokes (Width, Color, Dash pattern, Caps, Joins)"},{"LineComment":" |   - Transforms (Translate, Rotate, Scale, Skew)"},{"LineComment":" |   - Compositions (Group, Clip, Mask)"},{"LineComment":" |"},{"LineComment":" | ## What Element is NOT"},{"LineComment":" |"},{"LineComment":" | Element is NOT:"},{"LineComment":" |   - A DOM abstraction (no \"div\", \"span\", \"button\")"},{"LineComment":" |   - A CSS generator (no \"background-color\", \"border-radius\")"},{"LineComment":" |   - A framework adapter (no Halogen, React, Vue concepts)"},{"LineComment":" |   - JavaScript-dependent (no FFI for core operations)"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This leader module re-exports from submodules:"},{"LineComment":" |   - Hydrogen.Element.Core.Stroke — StrokeSpec and constructors"},{"LineComment":" |   - Hydrogen.Element.Core.Specs — Shape and text specifications"},{"LineComment":" |   - Hydrogen.Element.Core.Media — Image, video, audio, 3D specs"},{"LineComment":" |   - Hydrogen.Element.Core.Element — Element type, instances, constructors"},{"LineComment":" |"},{"LineComment":" | ## Dependencies (Schema atoms only)"},{"LineComment":" |"},{"LineComment":" | - Hydrogen.Schema.Geometry.Shape (RectangleShape, EllipseShape, PathShape)"},{"LineComment":" | - Hydrogen.Schema.Surface.Fill (Fill)"},{"LineComment":" | - Hydrogen.Schema.Geometry.Stroke (LineCap, LineJoin, MiterLimit)"},{"LineComment":" | - Hydrogen.Schema.Dimension.Stroke (StrokeWidth, DashPattern)"},{"LineComment":" | - Hydrogen.Schema.Geometry.Transform (Transform2D)"},{"LineComment":" | - Hydrogen.Schema.Color.Opacity (Opacity)"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[104,23],"start":[89,1]}},"moduleName":["Hydrogen","Element","Core","Element"]},{"annotation":{"meta":null,"sourceSpan":{"end":[136,21],"start":[124,1]}},"moduleName":["Hydrogen","Element","Core","Media"]},{"annotation":{"meta":null,"sourceSpan":{"end":[113,21],"start":[107,1]}},"moduleName":["Hydrogen","Element","Core","Specs"]},{"annotation":{"meta":null,"sourceSpan":{"end":[121,22],"start":[116,1]}},"moduleName":["Hydrogen","Element","Core","Stroke"]},{"annotation":{"meta":null,"sourceSpan":{"end":[144,24],"start":[142,1]}},"moduleName":["Hydrogen","Schema","Geometry","Stroke"]},{"annotation":{"meta":null,"sourceSpan":{"end":[144,24],"start":[66,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Element","Core"],"modulePath":"../../hydrogen/src/Hydrogen/Element/Core.purs","reExports":{"Hydrogen.Element.Core.Element":["Audio","Ellipse","Empty","Group","Image","Model3D","Path","Rectangle","Text","Transform","Video","audio","ellipse","empty","group","image","model3D","path","rectangle","text","transform","video"],"Hydrogen.Element.Core.Media":["AudioBlobId","AudioOscillator","AudioStreamId","AudioUrl","ImageDataUri","ImageTextureId","ImageUrl","ModelGeometryId","ModelUrl","VideoBlobId","VideoStreamId","VideoUrl"],"Hydrogen.Element.Core.Specs":[],"Hydrogen.Element.Core.Stroke":["noStroke","stroke","strokeWith"],"Hydrogen.Schema.Geometry.Stroke":["CapButt","CapRound","CapSquare","JoinBevel","JoinMiter","JoinRound"]},"sourceSpan":{"end":[144,24],"start":[66,1]}}