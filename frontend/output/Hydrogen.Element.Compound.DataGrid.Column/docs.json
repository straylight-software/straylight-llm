,"sourceSpan":{"end":[134,43],"name":"../../hydrogen/src/Hydrogen/Element/Compound/DataGrid/Column.purs","start":[134,1]},"title":"notResizable"},{"children":[],"comments":"Make cells editable\n\nEditable cells can be clicked to enter edit mode. The grid will emit\nonCellEdit events when values change.\n","info":{"declType":"value","type":{"annotation":[],"contents":{"identifier":"msg","kind":null,"skolem":null,"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Hydrogen","Element","Compound","DataGrid","Types"],"ColumnProp"],"tag":"TypeConstructor"},{"annotation":[],"contents":"msg","tag":"TypeVar"}],"tag":"TypeApp"},"visibility":"TypeVarInvisible"},"tag":"ForAll"}},"kind":null,"sourceSpan":{"end":[141,39],"name":"../../hydrogen/src/Hydrogen/Element/Compound/DataGrid/Column.purs","start":[141,1]},"title":"editable"},{"children":[],"comments":"Hide column\n\nHidden columns are not rendered but their data remains available\nfor filtering, sorting, and export operations.\n","info":{"declType":"value","type":{"annotation":[],"contents":{"identifier":"msg","kind":null,"skolem":null,"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Hydrogen","Element","Compound","DataGrid","Types"],"ColumnProp"],"tag":"TypeConstructor"},{"annotation":[],"contents":"msg","tag":"TypeVar"}],"tag":"TypeApp"},"visibility":"TypeVarInvisible"},"tag":"ForAll"}},"kind":null,"sourceSpan":{"end":[148,37],"name":"../../hydrogen/src/Hydrogen/Element/Compound/DataGrid/Column.purs","start":[148,1]},"title":"hidden"},{"children":[],"comments":"Fix column to left edge\n\nFixed left columns remain visible during horizontal scrolling,\nstaying pinned to the left edge of the grid viewport.\n","info":{"declType":"value","type":{"annotation":[],"contents":{"identifier":"msg","kind":null,"skolem":null,"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Hydrogen","Element","Compound","DataGrid","Types"],"ColumnProp"],"tag":"TypeConstructor"},{"annotation":[],"conte