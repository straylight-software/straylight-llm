{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                                      // hydrogen // compositor"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Compositor — Layered Rendering Architecture"},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | The Compositor is a pure data model for layered rendering, inspired by"},{"LineComment":" | professional compositing software (After Effects, Nuke, Fusion). It provides"},{"LineComment":" | a z-depth stack where every element has physics, temporal behavior, and"},{"LineComment":" | can contain any content."},{"LineComment":" |"},{"LineComment":" | ## Architecture"},{"LineComment":" |"},{"LineComment":" | ```"},{"LineComment":" | Canvas (z=0)"},{"LineComment":" | ├── Ultimate boundary container"},{"LineComment":" | ├── Receives shadows from above"},{"LineComment":" | ├── Nothing goes \"behind\""},{"LineComment":" | └── Critical for 3D scenes, VR/AR, game worlds"},{"LineComment":" |"},{"LineComment":" | Viewport (z=1+)"},{"LineComment":" | ├── ShapeLayer (z+1) — Pure math, pixel-perfect clipping at any scale"},{"LineComment":" | ├── MaterialLayer (z+0.5) — Diffusion surface, 8px grid aligned"},{"LineComment":" | └── ContentLayer (z+0) — Anything: buttons, dashboards, world models"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Key Insight: Scale Behavior"},{"LineComment":" |"},{"LineComment":" | On pinch zoom:"},{"LineComment":" | - **MaterialLayer**: Snaps to nearest 8px boundary (diffusion tile alignment)"},{"LineComment":" | - **ShapeLayer**: Pure math recalculation, clips at exact pixel"},{"LineComment":" |"},{"LineComment":" | This is because diffusion models operate on 8×8 (or 64×64) tile boundaries"},{"LineComment":" | (the latent space constraint), while shape layers are vector math and"},{"LineComment":" | resolution-independent."},{"LineComment":" |"},{"LineComment":" | ## Bento Widget Model"},{"LineComment":" |"},{"LineComment":" | Viewports are bento-style widget boxes:"},{"LineComment":" | - Can snap to grid or be dynamic"},{"LineComment":" | - Have padding, effects, glows, animated strokes"},{"LineComment":" | - Support temporal, gestural, and physics behaviors"},{"LineComment":" | - Frame.io style hyper-responsive widgets"},{"LineComment":" |"},{"LineComment":" | A **button** is just a mini-viewport (length divisible by 8) with a shape"},{"LineComment":" | layer on top. It has the same material background system — could be a"},{"LineComment":" | diffusion model layer, SVG, image, video, or generated world model element."},{"LineComment":" |"},{"LineComment":" | ## At Billion-Agent Scale"},{"LineComment":" |"},{"LineComment":" | Because everything is pure data:"},{"LineComment":" | - 12 viewports on a display, each running different world model simulations"},{"LineComment":" | - Lottie path animations between elements with proper occlusion"},{"LineComment":" | - Physics interactions across the z-depth stack"},{"LineComment":" | - Same viewport definition = same rendering (always)"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | - `Compositor.Canvas` — Base layer (z=0), shadow receiver, boundary"},{"LineComment":" | - `Compositor.Viewport` — Bento widget container with layer stack"},{"LineComment":" | - `Compositor.MaterialLayer` — Diffusion surface, 8px grid aligned"},{"LineComment":" | - `Compositor.ShapeLayer` — Pure math, pixel-perfect clipping"},{"LineComment":" | - `Compositor.Stack` — Z-depth ordering, occlusion, physics"},{"LineComment":" | - `Compositor.Transform` — Scale, rotation, translation with proper layer behavior"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[118,14],"start":[92,1]}},"moduleName":["Hydrogen","Compositor","Canvas"]},{"annotation":{"meta":null,"sourceSpan":{"end":[165,21],"start":[133,1]}},"moduleName":["Hydrogen","Compositor","MaterialLayer"]},{"annotation":{"meta":null,"sourceSpan":{"end":[221,18],"start":[167,1]}},"moduleName":["Hydrogen","Compositor","ShapeLayer"]},{"annotation":{"meta":null,"sourceSpan":{"end":[250,13],"start":[223,1]}},"moduleName":["Hydrogen","Compositor","Stack"]},{"annotation":{"meta":null,"sourceSpan":{"end":[290,17],"start":[252,1]}},"moduleName":["Hydrogen","Compositor","Transform"]},{"annotation":{"meta":null,"sourceSpan":{"end":[131,16],"start":[120,1]}},"moduleName":["Hydrogen","Compositor","Viewport"]},{"annotation":{"meta":null,"sourceSpan":{"end":[290,17],"start":[68,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Compositor"],"modulePath":"../../hydrogen/src/Hydrogen/Compositor.purs","reExports":{"Hydrogen.Compositor.Canvas":["Canvas","Percentage","Pixels","ViewportRelative","Gradient","Solid","Transparent","ShadowConfig","acceptsShadows","canvas","canvasBounds","canvasHeight","canvasWidth","defaultCanvas","defaultShadowConfig","dimensionToPixels","disabledShadowConfig","gradient","isTransparent","percentage","pixels","resizeCanvas","setClearColor","setShadowConfig","shadowConfig","solid","transparent","unwrapCanvas","viewportRelative"],"Hydrogen.Compositor.MaterialLayer":["DiffusionSettings","GridAlignment","MaterialLayer","DiffusionSource","ImageSource","NoiseSource","SVGSource","ShaderSource","SolidColor","VideoSource","defaultDiffusionSettings","defaultGridAlignment","defaultMaterialLayer","getAlignment","getHeight","getOpacity","getSource","getWidth","isMaterialVisible","materialLayer","resize","resizeSnapped","setAlignment","setMaterialVisible","setOpacity","setSource","snapToGrid","toggleMaterialVisible","unwrapMaterialLayer"],"Hydrogen.Compositor.ShapeLayer":["CapButt","CapRound","CapSquare","JoinBevel","JoinMiter","JoinRound","ClosePath","CubicTo","LineTo","MoveTo","QuadTo","ShapeLayer","Ellipse","Line","Path","Polygon","Polyline","Rectangle","RegularPolygon","RoundedRect","Star","StrokeConfig","addShape","addShapes","clearShapes","defaultShapeLayer","defaultStrokeConfig","elevationShadow","ellipse","getFill","getGlowColor","getGlowRadius","getShadow","getShapes","getStroke","hexagon","isShapeVisible","line","noShadow","path","pentagon","polygon","polyline","rectangle","regularPolygon","removeShapeAt","roundedRect","setFill","setGlow","setGlowColor","setGlowRadius","setShadow","setShapeVisible","setStroke","shapeCount","star","toggleShapeVisible","triangle","unwrapShapeLayer"],"Hydrogen.Compositor.Stack":["Stack","ZDepth","addDepth","baseDepth","bringToFront","emptyStack","getHiddenLayers","getLayerAt","getLayerById","getTopVisibleLayer","incrementLayerDepth","insertAt","layerCount","moveDown","moveUp","popLayer","pushLayer","removeById","reorderLayers","sendToBack","sortByDepth","toggleLayerVisibility","updateContent","zDepth"],"Hydrogen.Compositor.Transform":["Matrix3x3","Rotation","Scale","Transform","Translation","applyInverseToPoint","applyToPoint","clampScale","clampTranslation","compose","determinant","fromMatrix","getRotation","getScale","getTranslation","identityTransform","invert","isIdentity","lerp","multiplyMatrices","rotate","scale","scaleBy","setRotation","setScale","setTranslation","toMatrix","translate","uniformScale"],"Hydrogen.Compositor.Viewport":["SnapConfig","Viewport","ViewportConfig","ViewportId","defaultSnapConfig","defaultViewport","defaultViewportConfig","noSnap","viewport","viewportIdFromString"]},"sourceSpan":{"end":[290,17],"start":[68,1]}}