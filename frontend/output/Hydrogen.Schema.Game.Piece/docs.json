[318,4],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[315,1]},"title":"OwnedPiece"},{"children":[],"comments":"Smart constructor for OwnedPiece.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"PieceType"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"Player"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"OwnedPiece"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[321,50],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[321,1]},"title":"mkOwnedPiece"},{"children":[],"comments":"All chess piece kinds in standard order.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Array"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"ChessPieceKind"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[133,39],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[133,1]},"title":"allChessPieces"},{"children":[],"comments":"All go stones.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Array"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"GoStone"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[156,29],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[156,1]},"title":"allGoStones"},{"children":[],"comments":"All checker piece kinds.\n","info":{"declType":"value","t