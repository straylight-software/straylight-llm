lt.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"PieceType"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Boolean"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[413,32],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[413,1]},"title":"isRoyal"},{"children":[],"comments":"Check if a piece can promote.\n\n## Promotable Pieces\n- Chess Pawn: promotes to Queen, Rook, Bishop, or Knight\n- Checkers Man: promotes to CrownedKing\n\nGo stones and generic tokens do not promote.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"PieceType"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Boolean"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[424,35],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[424,1]},"title":"canPromote"},{"children":[],"comments":"Available promotion options for a piece.\n\nReturns empty array if the piece cannot promote.\n\n## Chess Pawn\nCan promote to Queen, Rook, Bishop, or Knight (not King or Pawn).\n\n## Checkers Man\nPromotes only to CrownedKing.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"PieceType"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Array"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"PieceTy