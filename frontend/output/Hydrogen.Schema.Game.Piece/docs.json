[{"annotation":[],"contents":[["Data","Ord"],"Ord"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"CheckerKind"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[172,50],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[172,1]},"title":"ordCheckerKind"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Show"],"Show"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"CheckerKind"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[176,35],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[174,1]},"title":"showCheckerKind"}],"comments":"Checker piece kinds.\n\nNote: We use `CrownedKing` to avoid name collision with chess `King`.\nA Man promotes to CrownedKing upon reaching the opposite end.\n","info":{"dataDeclType":"data","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[169,16],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[167,1]},"title":"CheckerKind"},{"children":[{"comments":null,"info":{"arguments":[],"declType":"dataConstructor"},"sourceSpan":{"end":[279,12],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[279,3]},"title":"Player1"},{"comments":null,"info":{"arguments":[],"declType":"dataConstructor"},"sourceSpan":{"end":[280,12],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[280,3]},"title":"Player2"},{"comments":null,"info":{"arguments":[],"declType":"dataConstructor"},"sourceSpan":{"end":[281,12],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[281,3]},"title":"Neutral"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Eq"],"Eq"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"Player"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[283,38],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[283,1]},"title":"eqPlayer"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Ord"],"Ord"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"Player"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[284,40],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[284,1]},"title":"ordPlayer"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Show"],"Show"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"Player"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[289,27],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[286,1]},"title":"showPlayer"}],"comments":"Player ownership for two-player games.\n\nMost abstract strategy games have exactly two players. Neutral covers\nshared resources, obstacles, or unowned spaces.\n","info":{"dataDeclType":"data","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[281,12],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[278,1]},"title":"Player"},{"children":[{"comments":null,"info":{"arguments":[],"declType":"dataConstructor"},"sourceSpan":{"end":[340,11],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[340,3]},"title":"Active"},{"comments":null,"info":{"arguments":[],"declType":"dataConstructor"},"sourceSpan":{"end":[341,13],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[341,3]},"title":"Captured"},{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"PieceType"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[342,13],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[342,3]},"title":"Promoted"},{"comments":null,"info":{"arguments":[],"declType":"dataConstructor"},"sourceSpan":{"end":[343,18],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[343,3]},"title":"EnPassantable"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Eq"],"Eq"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"PieceState"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[345,46],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[345,1]},"title":"eqPieceState"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Show"],"Show"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Piece"],"PieceState"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[351,41],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[347,1]},"title":"showPieceState"}],"comments":"Piece lifecycle state.\n\nTracks whether a piece is active, captured, promoted, or has special\ntransient state (like en passant eligibility in chess).\n\n## States\n\n- `Active`: Piece is in play on the board\n- `Captured`: Piece has been removed from play\n- `Promoted`: Piece has transformed (pawn -> queen, man -> king)\n- `EnPassantable`: Pawn that just moved two squares (chess-specific)\n","info":{"dataDeclType":"data","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[343,18],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Piece.purs","start":[339,1]},"title":"PieceState"},{"children":[{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Eq"],"Eq"],"tag":"TypeCons