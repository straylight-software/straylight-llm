":[["Prim"],"Array"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Motion","Orchestration"],"Orchestration"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Motion","Orchestration"],"Orchestration"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[221,49],"name":"../../hydrogen/src/Hydrogen/Schema/Motion/Orchestration.purs","start":[221,1]},"title":"parallel"},{"children":[],"comments":"Run animations with staggered start times.\n\nEach animation starts `interval` after the previous.\n\n```purescript\nstagger (ms 50) [item1, item2, item3, item4]\n-- item1 at 0ms, item2 at 50ms, item3 at 100ms, item4 at 150ms\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Dimension","Temporal"],"Milliseconds"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Array"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Motion","Orchestration"],"Orchestration"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Motion","Orchestration"],"Orchestration"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[232,64],"name":"../../hydrogen/src/Hydrogen/Schema/Motion/Orchestration.purs","start":[232,1]},"title":"stagger"},{"children":[],"comments":"Stagger in reverse order (last item starts first).\n\nUseful for exit animations where you want items to leave\nin reverse order of their appearance.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"con