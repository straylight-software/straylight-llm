{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                             // hydrogen // schema // surface // perlin-noise"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | PerlinNoise - classic gradient noise configuration."},{"LineComment":" |"},{"LineComment":" | Ken Perlin's gradient noise algorithm (1983/2002), the foundation of"},{"LineComment":" | procedural texture generation. Produces smooth, natural-looking random"},{"LineComment":" | patterns without the harsh edges of value noise."},{"LineComment":" |"},{"LineComment":" | ## Composition"},{"LineComment":" |"},{"LineComment":" | A molecule composed from Material pillar atoms:"},{"LineComment":" | - NoiseFrequency: spatial frequency (0.0 to finite)"},{"LineComment":" | - NoiseAmplitude: output range (0.0 to 1.0)"},{"LineComment":" | - NoiseSeed: deterministic seed (any Int)"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | -- Subtle texture noise"},{"LineComment":" | subtle = perlinNoise"},{"LineComment":" |   { frequency: NoiseFrequency.standard"},{"LineComment":" |   , amplitude: NoiseAmplitude.subtle"},{"LineComment":" |   , seed: NoiseSeed.zero"},{"LineComment":" |   }"},{"LineComment":" |"},{"LineComment":" | -- Turbulent cloud-like noise"},{"LineComment":" | turbulent = perlinNoiseTurbulent"},{"LineComment":" |   { frequency: noiseFrequency 2.0"},{"LineComment":" |   , amplitude: noiseAmplitude 0.8"},{"LineComment":" |   , seed: noiseSeed 42"},{"LineComment":" |   }"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Performance"},{"LineComment":" |"},{"LineComment":" | Perlin noise is O(2^n) where n is dimensions. 2D is fast, 3D is moderate."},{"LineComment":" | For better performance with similar quality, consider SimplexNoise."},{"LineComment":" |"},{"LineComment":" | ## Dependencies"},{"LineComment":" |"},{"LineComment":" | - Hydrogen.Schema.Surface.NoiseFrequency"},{"LineComment":" | - Hydrogen.Schema.Surface.NoiseAmplitude"},{"LineComment":" | - Hydrogen.Schema.Surface.NoiseSeed"}],"decls":[{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"bindType":"NonRec","expression":{"abstraction":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[110,28],"start":[110,26]}},"type":"Var","value":{"identifier":"append","moduleName":["Data","Semigroup"]}},"annotation":{"meta":{"metaType":"IsSyntheticApp"},"sourceSpan":{"end":[114,13],"start":[110,5]}},"argument":{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"type":"Var","value":{"identifier":"semigroupString","moduleName":["Data","Semigroup"]}},"type":"App"},"identifier":"append"},{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"bindType":"NonRec","expression":{"abstraction":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[110,33],"start":[110,29]}},"type":"Var","value":{"identifier":"show","moduleName":["Data","Show"]}},"annotation":{"meta":{"metaType":"IsSyntheticApp"},"sourceSpan":{"end":[110,45],"start":[110,29]}},"argument":{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"type":"Var","value":{"identifier":"showNoiseFrequency","moduleName":["Hydrogen","Schema","Surface","NoiseFrequency"]}},"type":"App"},"identifier":"show"},{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"bindType":"NonRec","expression":{"abstraction":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[111,25],"start":[111,21]}},"type":"Var","value":{"identifier":"show","moduleName":["Data","Show"]}},"annotation":{"meta":{"metaType":"IsSyntheticApp"},"sourceSpan":{"end":[111,37],"start":[111,21]}},"argument":{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"type":"Var","value":{"identifier":"showNoiseAmplitude","