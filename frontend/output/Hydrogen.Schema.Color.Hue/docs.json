ntents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[328,26],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Hue.purs","start":[328,1]},"title":"toNumber"},{"children":[],"comments":"Blend two hues by simple linear interpolation\n\nWARNING: This takes the \"long way\" around the color wheel for large\ndifferences. For perceptually correct blending, use `blendShortestPath`.\n```purescript\nblend 0.5 (hue 10) (hue 350)  -- hue 180 (through green/cyan!)\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Hue"],"Hue"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Hue"],"Hue"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Hue"],"Hue"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[145,37],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Hue.purs","start":[145,1]},"title":"blend"},{"children":[],"comments":"Blend two hues via shortest path around the color wheel\n\nThis is perceptually correct for hue interpolation. It automatically\nchooses the shorter arc between two hues:\n```purescript\nblendShortestPath 0.5 (hue 10) (hue 350)  -- hue 0 (through red!)\nblendShortestPath 0.5 red cyan            -- hue 90 (yellow-green)\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"content