{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                           // hydrogen // gpu // render-effect"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | RenderEffect — Unified Real-Time Effect Pipeline"},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | Frame.io, Ghostty, Linear — hyper-responsive UIs that feel alive."},{"LineComment":" | This module provides the composable effect vocabulary for that experience:"},{"LineComment":" |"},{"LineComment":" | - **Blur effects**: Gaussian, directional, radial, zoom"},{"LineComment":" | - **Glow effects**: Inner, outer, animated pulse, color cycling"},{"LineComment":" | - **Shadow effects**: Drop, box, layered, animated"},{"LineComment":" | - **Border effects**: Gradient stroke, conic rotation, marching ants"},{"LineComment":" | - **Material effects**: Glass, frosted, noise, grain"},{"LineComment":" | - **Temporal effects**: Motion blur, echo, time displacement"},{"LineComment":" |"},{"LineComment":" | ## Architecture"},{"LineComment":" |"},{"LineComment":" | Effects are **pure data** describing GPU render passes. At billion-agent"},{"LineComment":" | scale, effects compose deterministically:"},{"LineComment":" |"},{"LineComment":" | ```"},{"LineComment":" | Element + Effects → RenderPlan → GPU Passes → Tensor Output"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | Same effect parameters = same pixels. Always."},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from:"},{"LineComment":" | - `Hydrogen.GPU.RenderEffect.Types` — Shared types (GlowColor, BlendMode, etc.)"},{"LineComment":" | - `Hydrogen.GPU.RenderEffect.Core` — RenderEffect ADT and composition"},{"LineComment":" | - `Hydrogen.GPU.RenderEffect.Blur` — Blur effect variants"},{"LineComment":" | - `Hydrogen.GPU.RenderEffect.Glow` — Glow effect variants"},{"LineComment":" | - `Hydrogen.GPU.RenderEffect.Shadow` — Shadow effect variants"},{"LineComment":" | - `Hydrogen.GPU.RenderEffect.Border` — Border effect variants"},{"LineComment":" | - `Hydrogen.GPU.RenderEffect.Material` — Material effect variants"},{"LineComment":" | - `Hydrogen.GPU.RenderEffect.Temporal` — Temporal effect variants"},{"LineComment":" | - `Hydrogen.GPU.RenderEffect.Particle` — Particle effect variants"},{"LineComment":" | - `Hydrogen.GPU.RenderEffect.Constructors` — Convenience constructors"},{"LineComment":" | - `Hydrogen.GPU.RenderEffect.Presets` — Pre-configured effects"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[101,4],"start":[98,1]}},"moduleName":["Hydrogen","GPU","ComputeKernel"]},{"annotation":{"meta":null,"sourceSpan":{"end":[96,4],"start":[90,1]}},"moduleName":["Hydrogen","GPU","RenderEffect","Blur"]},{"annotation":{"meta":null,"sourceSpan":{"end":[127,4],"start":[119,1]}},"moduleName":["Hydrogen","GPU","RenderEffect","Border"]},{"annotation":{"meta":null,"sourceSpan":{"end":[177,4],"start":[152,1]}},"moduleName":["Hydrogen","GPU","RenderEffect","Constructors"]},{"annotation":{"meta":null,"sourceSpan":{"end":[88,4],"start":[80,1]}},"moduleName":["Hydrogen","GPU","RenderEffect","Core"]},{"annotation":{"meta":null,"sourceSpan":{"end":[110,4],"start":[103,1]}},"moduleName":["Hydrogen","GPU","RenderEffect","Glow"]},{"annotation":{"meta":null,"sourceSpan":{"end":[136,4],"start":[129,1]}},"moduleName":["Hydrogen","GPU","RenderEffect","Material"]},{"annotation":{"meta":null,"sourceSpan":{"end":[150,4],"start":[146,1]}},"moduleName":["Hydrogen","GPU","RenderEffect","Particle"]},{"annotation":{"meta":null,"sourceSpan":{"end":[195,4],"start":[179,1]}},"moduleName":["Hydrogen","GPU","RenderEffect","Presets"]},{"annotation":{"meta":null,"sourceSpan":{"end":