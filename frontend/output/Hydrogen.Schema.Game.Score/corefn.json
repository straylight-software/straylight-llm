{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                         // hydrogen // schema // game // score"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Complete scoring and ranking systems for competitive games."},{"LineComment":" |"},{"LineComment":" | Defines the atomic vocabulary for rating systems (Elo, Glicko), leaderboards,"},{"LineComment":" | achievements, and score calculations. This module provides mathematically"},{"LineComment":" | correct implementations suitable for deterministic game state at billion-"},{"LineComment":" | agent scale."},{"LineComment":" |"},{"LineComment":" | ## Rating Systems"},{"LineComment":" |"},{"LineComment":" | - **Elo**: Classic rating system (bounded 0-4000)"},{"LineComment":" | - **Glicko**: Elo extension with rating deviation and volatility"},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | Ratings are pure data with bounded domains. K-factors are bounded 10-40"},{"LineComment":" | to prevent unstable rating swings. All calculations use standard formulas"},{"LineComment":" | from statistical game theory."},{"LineComment":" |"},{"LineComment":" | ## At Billion-Agent Scale"},{"LineComment":" |"},{"LineComment":" | When agents compute ratings:"},{"LineComment":" | - Same inputs = same outputs (always)"},{"LineComment":" | - Bounded domains prevent overflow/underflow"},{"LineComment":" | - Deterministic expected score calculations"},{"LineComment":" | - Complete achievement enumeration"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" | - `Types`: Core data types (EloRating, GlickoRating, GameOutcome, etc.)"},{"LineComment":" | - `Elo`: Elo rating calculations"},{"LineComment":" | - `Glicko`: Glicko rating calculations"},{"LineComment":" | - `Categories`: Rating categories, percentiles, tiers"},{"LineComment":" | - `Leaderboard`: Leaderboard entry operations"},{"LineComment":" | - `Scoring`: Score breakdown and streak tracking"},{"LineComment":" | - `Formatting`: Display formatting functions"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[55,59],"start":[55,1]}},"moduleName":["Hydrogen","Schema","Game","Score","Categories"]},{"annotation":{"meta":null,"sourceSpan":{"end":[53,45],"start":[53,1]}},"moduleName":["Hydrogen","Schema","Game","Score","Elo"]},{"annotation":{"meta":null,"sourceSpan":{"end":[58,59],"start":[58,1]}},"moduleName":["Hydrogen","Schema","Game","Score","Formatting"]},{"annotation":{"meta":null,"sourceSpan":{"end":[54,51],"start":[54,1]}},"moduleName":["Hydrogen","Schema","Game","Score","Glicko"]},{"annotation":{"meta":null,"sourceSpan":{"end":[56,61],"start":[56,1]}},"moduleName":["Hydrogen","Schema","Game","Score","Leaderboard"]},{"annotation":{"meta":null,"sourceSpan":{"end":[57,53],"start":[57,1]}},"moduleName":["Hydrogen","Schema","Game","Score","Scoring"]},{"annotation":{"meta":null,"sourceSpan":{"end":[52,49],"start":[52,1]}},"moduleName":["Hydrogen","Schema","Game","Score","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[58,59],"start":[42,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Game","Score"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Game/Score.purs","reExports":{"Hydrogen.Schema.Game.Score.Categories":["ratingCategory","ratingPercentile","ratingTier"],"Hydrogen.Schema.Game.Score.Elo":["eloChange","expectedScore","glickoToElo","kFactorByRating","newEloRating","winProbability"],"Hydrogen.Schema.Game.Score.Formatting":["formatChange","formatRating","formatWinRate"],"Hydrogen.Schema.Game.Score.Glicko":["glickoExpectedScore","glickoG","glickoQ","updateGlicko"],"Hydrogen.Schema.Game.Score.Leaderboard":["mkLe