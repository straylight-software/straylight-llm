{"comments":"Stereo and spatial audio positioning atoms.\n\n## Stereo Positioning\nPan and Balance control left/right placement in the stereo field.\nPan: -1.0 = full left, 0.0 = center, 1.0 = full right.\n\n## Stereo Width\nWidth controls the stereo spread of a signal.\n0.0 = mono, 1.0 = normal stereo, 2.0 = extra wide.\n\n## 3D Spatial Audio\nAzimuth and Elevation position sounds in 3D space around the listener.\nDistance affects volume attenuation with proximity.\n","declarations":[{"children":[{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[89,25],"name":"../../hydrogen/src/Hydrogen/Schema/Audio/Spatial.purs","start":[89,13]},"title":"Pan"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Eq"],"Eq"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Audio","Spatial"],"Pan"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[91,32],"name":"../../hydrogen/src/Hydrogen/Schema/Audio/Spatial.purs","start":[91,1]},"title":"eqPan"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Ord"],"Ord"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Audio","Spatial"],"Pan"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[92,34],"name":"../../hydrogen/src/Hydrogen/Schema/Audio/Spatial.purs","start":[92,1]},"title":"ordPan"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Show"],"Show"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Audio","Spatial"],"Pan"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[98,27],"name":"../../hydrogen/src/Hydrogen/Schema/Audio/Spatial.purs","