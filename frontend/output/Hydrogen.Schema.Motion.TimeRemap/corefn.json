{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                 // hydrogen // schema // motion // time-remap"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | TimeRemap — Variable speed, time remapping, and ramps for animation."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | Time remapping allows non-linear playback of animations:"},{"LineComment":" |"},{"LineComment":" | - **Speed curves**: Gradual acceleration/deceleration"},{"LineComment":" | - **Time freeze**: Hold at specific frame"},{"LineComment":" | - **Time reverse**: Play backwards"},{"LineComment":" | - **Time stretch**: Slow motion or fast forward"},{"LineComment":" | - **Ramps**: Gradual speed transitions"},{"LineComment":" |"},{"LineComment":" | This mirrors motion graphics Time Remap effect and 3D animation software's"},{"LineComment":" | F-Curve editor with explicit time control."},{"LineComment":" |"},{"LineComment":" | ## Core Concept"},{"LineComment":" |"},{"LineComment":" | A TimeRemap maps input time to output time:"},{"LineComment":" |"},{"LineComment":" | ```"},{"LineComment":" | outputTime = remap(inputTime)"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | For example:"},{"LineComment":" | - Linear: outputTime = inputTime (normal playback)"},{"LineComment":" | - Reverse: outputTime = totalDuration - inputTime"},{"LineComment":" | - Slow motion: outputTime = inputTime * 0.5"},{"LineComment":" | - Speed ramp: outputTime follows a curve"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Schema.Motion.TimeRemap as TR"},{"LineComment":" |"},{"LineComment":" | -- Create slow motion (50% speed)"},{"LineComment":" | slowMo = TR.uniformSpeed 0.5"},{"LineComment":" |"},{"LineComment":" | -- Create speed ramp (slow start, fast end)"},{"LineComment":" | ramp = TR.speedRamp TR.easeIn 0.2 1.5"},{"LineComment":" |"},{"LineComment":" | -- Apply to animation time"},{"LineComment":" | remappedTime = TR.apply 30.0 ramp  -- Remap frame 30"},{"LineComment":" |"},{"LineComment":" | -- Create freeze frame"},{"LineComment":" | freeze = TR.freezeAt 60.0  -- Hold at frame 60"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" |"},{"LineComment":" | - `TimeRemap.Types` — Core types (RemapMode, SpeedKeyframe, TimeRemap)"},{"LineComment":" | - `TimeRemap.Construction` — Constructors and speed ramps"},{"LineComment":" | - `TimeRemap.Evaluation` — Evaluation and duration functions"},{"LineComment":" | - `TimeRemap.Composition` — Composition, presets, analysis, sampling"},{"LineComment":" | - `TimeRemap.Utilities` — Validation, normalization, helpers"},{"LineComment":" | - `TimeRemap.Internal` — Internal helpers (not re-exported)"},{"LineComment":" |"},{"LineComment":" | ## Dependencies"},{"LineComment":" |"},{"LineComment":" | - Schema.Motion.Easing (curves for speed transitions)"},{"LineComment":" | - Schema.Dimension.Temporal (Frames)"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[133,4],"start":[117,1]}},"moduleName":["Hydrogen","Schema","Motion","TimeRemap","Composition"]},{"annotation":{"meta":null,"sourceSpan":{"end":[104,4],"start":[91,1]}},"moduleName":["Hydrogen","Schema","Motion","TimeRemap","Construction"]},{"annotation":{"meta":null,"sourceSpan":{"end":[115,4],"start":[106,1]}},"moduleName":["Hydrogen","Schema","Motion","TimeRemap","Evaluation"]},{"annotation":{"meta":null,"sourceSpan":{"end":[89,4],"start":[85,1]}},"moduleName":["Hydrogen","Schema","Motion","TimeRemap","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[143,4],"start":[135,1]}},"moduleName":["Hydrogen","Schema","Motion","TimeRemap","Utilities"]},{"annotation":{"meta":null,"sourceSpan":{"end":[143,4],"start":[68,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Motion","TimeRemap"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Motion/TimeRemap.purs","reExports":{"Hydrogen.Schema.Motion.TimeRemap.Composition":["averageSpeed","blend","bounce","chain","compose","fastForward","hold","isConstantSpeed","loop","maxSpeed","minSpeed","pingPong","sampleRemap","sampleSpeed","slowMotion"],"Hydrogen.Schema.Motion.TimeRemap.Construction":["addSpeedKeyframe","freezeAt","fromSpeedKeyframes","identity","removeSpeedKeyframe","reverse","speedRamp","speedRampIn","speedRampInOut","speedRampOut","timeStretch","uniformSpeed"],"Hydrogen.Schema.Motion.TimeRemap.Evaluation":["apply","applyInverse","applyToProgress","derivativeAt","originalDuration","remappedDuration","setOriginalDuration","speedAt"],"Hydrogen.Schema.Motion.TimeRemap.Types":["CurveRemap","FreezeRemap","KeyframeRemap","LinearRemap","LoopRemap","PingPongRemap","SpeedKeyframe","TimeRemap"],"Hydrogen.Schema.Motion.TimeRemap.Utilities":["combineRemaps","defaultSpeed","hasSpeedChange","isValidRemap","normalizeRemap","speedKeyframe","speedMagnitude"]},"sourceSpan":{"end":[143,4],"start":[68,1]}}