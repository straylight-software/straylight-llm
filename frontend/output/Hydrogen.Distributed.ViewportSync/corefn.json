{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                   // hydrogen // distributed // viewport-sync"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | ViewportSync — Multi-viewport coordination for distributed rendering."},{"LineComment":" |"},{"LineComment":" | ## Purpose"},{"LineComment":" |"},{"LineComment":" | When multiple viewports render the same scene (collaborative editing,"},{"LineComment":" | multi-monitor displays, distributed rendering farms), they must:"},{"LineComment":" |"},{"LineComment":" | - Agree on the current frame"},{"LineComment":" | - Compensate for drift between local clocks"},{"LineComment":" | - Share effect state (animations, transitions)"},{"LineComment":" | - Handle disconnection gracefully"},{"LineComment":" |"},{"LineComment":" | ## Architecture"},{"LineComment":" |"},{"LineComment":" | Each viewport has a ViewportSync state that tracks:"},{"LineComment":" |"},{"LineComment":" | 1. Which time authority it follows"},{"LineComment":" | 2. How many frames ahead/behind the authority it is"},{"LineComment":" | 3. Current sync state (synchronized, drifting, resynchronizing, disconnected)"},{"LineComment":" | 4. Subscriptions to shared effects"},{"LineComment":" |"},{"LineComment":" | ## Drift Compensation"},{"LineComment":" |"},{"LineComment":" | Drift occurs when:"},{"LineComment":" | - Local clock runs faster/slower than authority"},{"LineComment":" | - Network latency varies"},{"LineComment":" | - Frame drops cause desync"},{"LineComment":" |"},{"LineComment":" | Compensation strategies:"},{"LineComment":" | - Skip frames to catch up"},{"LineComment":" | - Interpolate to smooth transitions"},{"LineComment":" | - Pause and wait for authority"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" |"},{"LineComment":" | - `ViewportSync.Types` — Core type definitions"},{"LineComment":" | - `ViewportSync.Core` — ViewportSync record and operations"},{"LineComment":" | - `ViewportSync.Drift` — Drift compensation"},{"LineComment":" | - `ViewportSync.Effects` — Shared effect state"},{"LineComment":" | - `ViewportSync.Cluster` — Multi-viewport coordination"},{"LineComment":" | - `ViewportSync.Reconciliation` — Frame reconciliation"},{"LineComment":" | - `ViewportSync.Integration` — TimeAuthority subsystem integration"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[154,15],"start":[145,1]}},"moduleName":["Hydrogen","Distributed","ViewportSync","Cluster"]},{"annotation":{"meta":null,"sourceSpan":{"end":[119,12],"start":[106,1]}},"moduleName":["Hydrogen","Distributed","ViewportSync","Core"]},{"annotation":{"meta":null,"sourceSpan":{"end":[126,13],"start":[121,1]}},"moduleName":["Hydrogen","Distributed","ViewportSync","Drift"]},{"annotation":{"meta":null,"sourceSpan":{"end":[143,15],"start":[128,1]}},"moduleName":["Hydrogen","Distributed","ViewportSync","Effects"]},{"annotation":{"meta":null,"sourceSpan":{"end":[185,19],"start":[162,1]}},"moduleName":["Hydrogen","Distributed","ViewportSync","Integration"]},{"annotation":{"meta":null,"sourceSpan":{"end":[160,22],"start":[156,1]}},"moduleName":["Hydrogen","Distributed","ViewportSync","Reconciliation"]},{"annotation":{"meta":null,"sourceSpan":{"end":[104,13],"start":[60,1]}},"moduleName":["Hydrogen","Distributed","ViewportSync","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[185,19],"start":[50,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Distributed","ViewportSync"],"modulePath":"../../hydrogen/src/Hydrogen/Distributed/ViewportSync.purs","reExports":{"Hydrogen.Distributed.ViewportSync.Cluster":["addViewport","broadcastFrame","computeClusterState","getAllViewports","getViewport","m