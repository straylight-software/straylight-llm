{"comments":"Modern color space conversions: OKLAB, OKLCH, HWB, YUV\n\n**OKLAB:** Björn Ottosson's perceptually uniform color space (2020).\nSuperior to CIE LAB for hue preservation during lightness changes.\n\n**OKLCH:** Cylindrical form of OKLAB. CSS Color Level 4 standard.\nThe recommended space for programmatic color manipulation.\n\n**HWB:** Hue-Whiteness-Blackness. CSS Color Level 4.\nIntuitive for humans: \"add white to tint, add black to shade.\"\n\n**YUV:** Luma-chroma for video applications.\nITU-R BT.601 standard definition coefficients.\n","declarations":[{"children":[],"comments":"RGB → OKLAB (modern perceptual uniform space)\nUses linear RGB → LMS → OKLAB transformation\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","OKLAB"],"OKLAB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[75,37],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Conversion/Modern.purs","start":[75,1]},"title":"rgbToOklab"},{"children":[],"comments":"OKLAB → RGB\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","OKLAB"],"OKLAB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[108,37],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Conversion/Modern.purs","start":[108,1]},"title":"oklabToRgb"},{"children":[],"comments":"OKLAB → OKLCH (rectangular → cylindrical)\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","OKLAB"],"OKLAB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","OKLCH"],"OKLCH"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[146,43],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Conversion/Modern.purs","start":[146,1]},"title":"oklabToOklch"},{"children":[],"comments":"OKLCH → OKLAB (cylindrical → rectangular)\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","OKLCH"],"OKLCH"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","OKLAB"],"OKLAB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[167,43],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Conversion/Modern.purs","start":[167,1]},"title":"oklchToOklab"},{"children":[],"comments":"RGB → OKLCH (convenience)\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","OKLCH"],"OKLCH"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[188,37],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Conversion/Modern.purs","start":[188,1]},"title":"rgbToOklch"},{"children":[],"comments":"OKLCH → RGB (convenience)\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","OKLCH"],"OKLCH"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[192,37],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Conversion/Modern.purs","start":[192,1]},"title":"oklchToRgb"},{"children":[],"comments":"RGB → HWB (direct conversion)\n\n**Algorithm:**\n- Hue: same as HSL hue (derived from RGB)\n- Whiteness: min(R, G, B) / 255 as percentage\n- Blackness: 1 - max(R, G, B) / 255 as percentage\n\nThis is a direct calculation, not via HSL intermediate.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","HWB"],"HWB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[207,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Conversion/Modern.purs","start":[207,1]},"title":"rgbToHwb"},{"children":[],"comments":"HWB → RGB (direct conversion)\n\n**Algorithm:**\n1. If W + B >= 100: achromatic gray = W / (W + B)\n2. Otherwise: calculate pure hue RGB, then:\n   RGB' = RGB * (1 - W/100 - B/100) + W/100\n\nThis avoids HSL intermediate for better precision.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","HWB"],"HWB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[240,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Conversion/Modern.purs","start":[240,1]},"title":"hwbToRgb"},{"children":[],"comments":"RGB → YUV (video color space)\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","YUV"],"YUV"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[281,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Conversion/Modern.purs","start":[281,1]},"title":"rgbToYuv"},{"children":[],"comments":"YUV → RGB\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","YUV"],"YUV"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[296,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Conversion/Modern.purs","start":[296,1]},"title":"yuvToRgb"}],"name":"Hydrogen.Schema.Color.Conversion.Modern","reExports":[]}