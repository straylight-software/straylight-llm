rker"},{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Prim"],"String"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"String"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[366,23],"name":"../../hydrogen/src/Hydrogen/Schema/Motion/Lottie.purs","start":[366,3]},"title":"SegmentMarkerRange"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Eq"],"Eq"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Motion","Lottie"],"LottieSegment"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[368,52],"name":"../../hydrogen/src/Hydrogen/Schema/Motion/Lottie.purs","start":[368,1]},"title":"eqLottieSegment"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Show"],"Show"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Motion","Lottie"],"LottieSegment"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[377,38],"name":"../../hydrogen/src/Hydrogen/Schema/Motion/Lottie.purs","start":[370,1]},"title":"showLottieSegment"}],"comments":"Segment of animation (frame range).\n\nLottie animations can be played in segments:\n- Full animation (all frames)\n- Specific frame range (startFrame to endFrame)\n- Named markers (if defined in motion graphics software)\n\n## Frame Numbers\n\nFrames are 0-indexed integers. A typical 2-second animation at 30fps\nhas frames 0-59.\n\n## Markers\n\nMotion graphics software allows naming frames with markers. These can be referenced\nby name rather than frame number, making animations more maintainable.\n\n## Examples\n\n```purescript\n-- Play frames 0-30 only\nintroSegment = frameRange 0 30\n\n-- Play from marker \"hover_start\" to \"hover_end\"\nhoverSegment = markerRange \"hover_start\" \"hover_end\"\n```\n","info":{"dataDeclType":"data","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[366,37],"name":"../../hydrogen/src/Hydrogen/Schema/Motion/Lottie.purs","start":[362,1]},"title":"LottieSegment"},{"children":[],"comments":"Create segment from frame range\n\nClamps negative frames to 0. Swaps start/end if start > end.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Int"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Int"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Motion","Lottie"],"LottieSegment"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[382,45],"name":"../../hydrogen/src/Hydrogen/Schema/Motion/Lottie.purs","start":[382,1]},"title":"lottieSegment"},{"children":[],"comments":"Full animation (all frames from start to end)\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Motion","Lottie"],"LottieSegment"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[397,31],"name":"../../hydrogen/src/Hydrogen/Schema/Motion/Lottie.purs","start":[397,1]},"title":"fullAnimation"},{"children":[],"comments":"Specific frame range\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Int"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Int"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"ann