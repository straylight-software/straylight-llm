{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                // hydrogen // schema // motion // path-motion"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | PathMotion — Animate objects along spline paths."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | PathMotion provides cinema-grade motion path animation like professional motion graphics software,"},{"LineComment":" | professional 3D and vector graphics software. Objects follow paths with:"},{"LineComment":" |"},{"LineComment":" | - **Arc-length parameterization**: Uniform speed along path"},{"LineComment":" | - **Easing integration**: Apply easing curves to path progress"},{"LineComment":" | - **Orient to path**: Auto-rotate object to face movement direction"},{"LineComment":" | - **Banking**: Tilt into turns like aircraft"},{"LineComment":" | - **Time remapping**: Variable speed along path"},{"LineComment":" |"},{"LineComment":" | ## Motion Path Workflow"},{"LineComment":" |"},{"LineComment":" | 1. Create a path (Spline, NURBS, or Bezier)"},{"LineComment":" | 2. Wrap in MotionPath with timing parameters"},{"LineComment":" | 3. Evaluate at any frame to get position, rotation, scale"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Schema.Motion.PathMotion as PM"},{"LineComment":" | import Hydrogen.Schema.Geometry.Spline as Spline"},{"LineComment":" |"},{"LineComment":" | -- Create path from points"},{"LineComment":" | path = Spline.catmullRomSpline points"},{"LineComment":" |"},{"LineComment":" | -- Create motion path (2 second duration at 30fps = 60 frames)"},{"LineComment":" | motion = PM.motionPath path (PM.Duration 60) PM.easeInOut"},{"LineComment":" |"},{"LineComment":" | -- Get position at frame 30 (halfway)"},{"LineComment":" | pos = PM.positionAtFrame 30 motion"},{"LineComment":" |"},{"LineComment":" | -- Get full transform (position + rotation)"},{"LineComment":" | transform = PM.transformAtFrame 30 motion"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" |"},{"LineComment":" | - `PathMotion.Types` — Core type definitions"},{"LineComment":" | - `PathMotion.Core` — Construction, configuration, accessors"},{"LineComment":" | - `PathMotion.Evaluation` — Position, tangent, rotation, sampling"},{"LineComment":" | - `PathMotion.Internal` — Helper functions (not re-exported)"},{"LineComment":" |"},{"LineComment":" | ## Dependencies"},{"LineComment":" |"},{"LineComment":" | - Schema.Geometry.Spline (CatmullRomSpline, BSpline)"},{"LineComment":" | - Schema.Geometry.Point (Point2D)"},{"LineComment":" | - Schema.Geometry.Vector (Vector2D for tangents)"},{"LineComment":" | - Schema.Geometry.Angle (Degrees for rotation)"},{"LineComment":" | - Schema.Motion.Easing (easing curves)"},{"LineComment":" | - Schema.Dimension.Temporal (Frames)"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[72,54],"start":[72,1]}},"moduleName":["Hydrogen","Schema","Motion","PathMotion","Core"]},{"annotation":{"meta":null,"sourceSpan":{"end":[73,66],"start":[73,1]}},"moduleName":["Hydrogen","Schema","Motion","PathMotion","Evaluation"]},{"annotation":{"meta":null,"sourceSpan":{"end":[71,56],"start":[71,1]}},"moduleName":["Hydrogen","Schema","Motion","PathMotion","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[73,66],"start":[61,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Motion","PathMotion"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Motion/PathMotion.purs","reExports":{"Hydrogen.Schema.Motion.PathMotion.Core":["defaultEasing","duration","durationToFrames","easing","framesToDuration","isLooping","isPingPong","motionPath","motionPathSimple","motionPathWithBank","orientMode","pathSource","setAutoOrient","setBankAngle","setDuration","setEasing","setLoop","setOffset","setOrientMode","setPingPong"],"Hydrogen.Schema.Motion.PathMotion.Evaluation":["arcLengthToProgress","filterActiveFrames","frameToProgress","isActiveAtFrame","mapSampledPositions","pathLength","positionAtFrame","positionAtProgress","positionAtTime","progressToArcLength","progressToFrame","rotationAtFrame","sampleAtFrame","sampleAtProgress","sampleFrameRange","samplePoints","tangentAtFrame","tangentAtProgress"],"Hydrogen.Schema.Motion.PathMotion.Types":["MotionPath","MotionSample","NoOrient","OrientCustomOffset","OrientPerpendicular","OrientToPath","OrientToPathFlipped","BSplineSource","CatmullRomSource","PointArraySource","unwrapMotionPath","unwrapMotionSample"]},"sourceSpan":{"end":[73,66],"start":[61,1]}}