udget?\n\nReturns true if experiential time ≤ maxTimeRatio × infrastructure time.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","World"],"World"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Boolean"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[881,40],"name":"../../hydrogen/src/Hydrogen/Schema/Game/World.purs","start":[881,1]},"title":"isWorldWithinBudget"},{"children":[],"comments":"Get the current time ratio (experiential / infrastructure).\n\nReturns 0.0 if infrastructure time is zero.\nA ratio > maxTimeRatio indicates a violation (should be impossible\nif using tickSafe).\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","World"],"World"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[889,34],"name":"../../hydrogen/src/Hydrogen/Schema/Game/World.purs","start":[889,1]},"title":"worldTimeRatio"},{"children":[],"comments":"Get the maximum allowed time ratio.\n\nThis is the constitutional limit: experiential time cannot exceed\nmaxTimeRatio × infrastructure time. Currently 10.0, meaning 10 seconds\nof subjective experience per 1 second of real time maximum.\n\nExposed so agents can:\n- Display warnings when approaching limit\n- Calculate remaining budget\n- Make informed decisions about time allocation\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[913,28],"name":"../../hydrogen/src/Hydrogen/Schema/Game/World.purs","start":[913,1]},"title":"worldMaxTimeRatio"},{"children":[],"comments":"Calculate remaining experiential time budget.\n\nReturns: (maxTimeRatio × infraTime) - experientialTime\n\nA positive value means experiential time can still accumulate.\nZero or negative means budget exhausted (should not happen with tickSafe).\n\nExample: With maxTimeRatio=10, infraTime=1.0, experientialTime=8.0\n         Remaining = (10 × 1.0) - 8.0 = 2.0 seconds\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","World"],"World"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[925,40],"name":"../../hydrogen/src/Hydrogen/Schema/Game/World.purs","start":[925,1]},"title":"worldRemainingBudget"},{"children":[],"comments":"Calculate budget utilization as a percentage (0.0 to 1.0+).\n\nReturns: experientialTime / (maxTimeRatio × infraTime)\n\n- 0.0 = no experiential time consumed\n- 0.5 = half budget used\n- 1.0 = budget exhausted\n- >1.0 = budget exceeded (violation, should not happen with tickSafe)\n\nUseful for UI warnings: \"You are at 80% temporal budget\"\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","World"],"World"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[946,42],"name":"../../hydrogen/src/Hydrogen/Schema/Game/World.purs","start":[946,1]},"title":"worldBudgetUtilization"}],"name":"Hydrogen.Schema.Game.World","reExports":[]}