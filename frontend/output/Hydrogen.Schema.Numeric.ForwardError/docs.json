ε₂ ≥ ε₁.\n\n## Lean Proof\n\n`weaken_preserves: weaken preserves ideal and approx` (proven)\n","info":{"declType":"value","type":{"annotation":[],"contents":{"identifier":"a","kind":null,"skolem":null,"type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Numeric","Grade"],"Grade"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Hydrogen","Schema","Numeric","ForwardError"],"ForwardError"],"tag":"TypeConstructor"},{"annotation":[],"contents":"a","tag":"TypeVar"}],"tag":"TypeApp"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Hydrogen","Schema","Numeric","ForwardError"],"ForwardError"],"tag":"TypeConstructor"},{"annotation":[],"contents":"a","tag":"TypeVar"}],"tag":"TypeApp"}],"tag":"TypeApp"}],"tag":"TypeApp"},"visibility":"TypeVarInvisible"},"tag":"ForAll"}},"kind":null,"sourceSpan":{"end":[211,64],"name":"../../hydrogen/src/Hydrogen/Schema/Numeric/ForwardError.purs","start":[211,1]},"title":"weaken"},{"children":[],"comments":"Attempt to strengthen the error bound (decrease it).\n\nFor Numbers, this recomputes the actual error and uses it if smaller\nthan both the current bound and the requested bound.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Numeric","Grade"],"Grade"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Hydrogen","Schema","Numeric","ForwardEr