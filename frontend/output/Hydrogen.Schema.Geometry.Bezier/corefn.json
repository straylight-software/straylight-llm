{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                   // hydrogen // schema // geometry // bezier"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Bezier — Quadratic and cubic Bezier curves."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | Bezier curves are the mathematical foundation for smooth motion in digital"},{"LineComment":" | systems. Every animation, easing function, and path is built on them."},{"LineComment":" |"},{"LineComment":" | Two variants are provided:"},{"LineComment":" | - **QuadBezier**: 3 control points (P0, P1, P2) — simpler, cheaper"},{"LineComment":" | - **CubicBezier**: 4 control points (P0, P1, P2, P3) — more flexible, standard"},{"LineComment":" |"},{"LineComment":" | Both use the De Casteljau algorithm for evaluation and subdivision."},{"LineComment":" |"},{"LineComment":" | ## Mathematical Foundation"},{"LineComment":" |"},{"LineComment":" | Quadratic: B(t) = (1-t)²P0 + 2(1-t)tP1 + t²P2"},{"LineComment":" | Cubic:     B(t) = (1-t)³P0 + 3(1-t)²tP1 + 3(1-t)t²P2 + t³P3"},{"LineComment":" |"},{"LineComment":" | Parameter t ∈ [0, 1] traces the curve from start to end."},{"LineComment":" |"},{"LineComment":" | ## Use Cases"},{"LineComment":" |"},{"LineComment":" | - Animation easing curves (CSS cubic-bezier)"},{"LineComment":" | - Path segments in vector graphics"},{"LineComment":" | - Motion trajectories for agents"},{"LineComment":" | - Smooth interpolation between states"},{"LineComment":" | - Font glyph outlines"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This leader module re-exports from:"},{"LineComment":" | - `Bezier.Types`: Core types and constructors"},{"LineComment":" | - `Bezier.Evaluation`: Point evaluation, tangents, subdivision"},{"LineComment":" | - `Bezier.Geometry`: Bounding box, arc length, curvature"},{"LineComment":" | - `Bezier.HitTest`: Closest point and distance calculations"},{"LineComment":" | - `Bezier.Easing`: Common animation easing curves"},{"LineComment":" |"},{"LineComment":" | ## Dependencies"},{"LineComment":" |"},{"LineComment":" | - Schema.Geometry.Point (Point2D for control points)"},{"LineComment":" | - Schema.Geometry.Vector (tangent vectors)"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[115,14],"start":[107,1]}},"moduleName":["Hydrogen","Schema","Geometry","Bezier","Easing"]},{"annotation":{"meta":null,"sourceSpan":{"end":[89,18],"start":[82,1]}},"moduleName":["Hydrogen","Schema","Geometry","Bezier","Evaluation"]},{"annotation":{"meta":null,"sourceSpan":{"end":[98,16],"start":[91,1]}},"moduleName":["Hydrogen","Schema","Geometry","Bezier","Geometry"]},{"annotation":{"meta":null,"sourceSpan":{"end":[105,15],"start":[100,1]}},"moduleName":["Hydrogen","Schema","Geometry","Bezier","HitTest"]},{"annotation":{"meta":null,"sourceSpan":{"end":[80,13],"start":[68,1]}},"moduleName":["Hydrogen","Schema","Geometry","Bezier","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[115,14],"start":[47,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Geometry","Bezier"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Geometry/Bezier.purs","reExports":{"Hydrogen.Schema.Geometry.Bezier.Easing":["easeInCubic","easeInOutCubic","easeInOutQuad","easeInQuad","easeLinear","easeOutCubic","easeOutQuad"],"Hydrogen.Schema.Geometry.Bezier.Evaluation":["cubicPointAt","cubicSplitAt","cubicTangentAt","quadPointAt","quadSplitAt","quadTangentAt"],"Hydrogen.Schema.Geometry.Bezier.Geometry":["cubicBoundingBox","cubicCurvatureAt","cubicLength","quadBoundingBox","quadCurvatureAt","quadLength"],"Hydrogen.Schema.Geometry.Bezier.HitTest":["cubicClosestParameter","cubicDistanceToPoint","quadClosestParameter","quadDistanceToPoint