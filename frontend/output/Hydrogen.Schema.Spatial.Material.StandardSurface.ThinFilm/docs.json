ating. Different thicknesses\ncreate different interference colors:\n- ~100nm: Blues and purples\n- ~200nm: Greens and yellows\n- ~300nm: Oranges and reds\n- ~400nm+: Cycles through colors again\n\nAt 0.0, no thin film effect.\nWe clamp to 2000nm to cover multiple interference cycles.\n","info":{"dataDeclType":"newtype","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[53,53],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Material/StandardSurface/ThinFilm.purs","start":[53,1]},"title":"ThinFilmThickness"},{"children":[{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Eq"],"Eq"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Material","StandardSurface","ThinFilm"],"ThinFilmIOR"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[80,48],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Material/StandardSurface/ThinFilm.purs","start":[80,1]},"title":"eqThinFilmIOR"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Ord"],"Ord"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Material","StandardSurface","ThinFilm"],"ThinFilmIOR"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[81,50],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Material/StandardSurface/ThinFilm.purs","start":[81,1]},"title":"ordThinFilmIOR"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Show"],"Show"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Material","StandardSurface","ThinFilm"],"ThinFilmIOR"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[84,57],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Material/StandardSurface/ThinFilm.purs","start":[83,1]},"title":"showThinFilmIOR"}],"comments":"Thin film IOR [1.0, 3.0] — index of refraction for the film.\n\nThe IOR of the thin film relative to the surrounding medium.\nCombined with thickness, determines the interference pattern.\n\nCommon values:\n- Soap film: ~1.33 (water)\n- Oil film: ~1.5\n- Oxide coatings: ~1.5-2.5\n","info":{"dataDeclType":"newtype","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[78,41],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Material/StandardSurface/ThinFilm.purs","start":[78,1]},"title":"ThinFilmIOR"},{"children":[],"comments":"Construct thin film thickness, clamping to [0.0, 2000.0].\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Material","StandardSurface","ThinFilm"],"ThinFilmThickness"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[62,49],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Material/StandardSurface/ThinFilm.purs","start":[62,1]},"title":"thinFilmThickness"},{"children":[],"comments":"Construct thin film IOR, clamping to [1.0, 3.0].\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Material","StandardSurface","ThinFilm"],"ThinFilmIOR"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[87,37],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Material/StandardSurface/ThinFilm.purs","start":[87,1]},"title":"thinFilmIOR"}],"name":"Hydrogen.Schema.Spatial.Material.S