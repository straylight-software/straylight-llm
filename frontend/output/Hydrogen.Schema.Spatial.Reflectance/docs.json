{"comments":"Reflectance - dielectric reflectance at normal incidence (F0) for PBR materials.\n\nRange: 0.0 to 1.0 (clamps)\n- **0.0**: No reflection (unphysical, but allowed)\n- **0.04**: Common dielectrics (plastic, wood, ~1.5 IOR)\n- **0.08**: Higher IOR dielectrics (glass, water, ~2.0 IOR)\n- **1.0**: Perfect mirror (theoretical maximum)\n\nThis controls the base reflectivity of NON-METALLIC materials.\nFor metals, reflectance comes from the albedo color instead.\nCommon range: 0.02 to 0.16 for real-world dielectrics.\n","declarations":[{"children":[{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Eq"],"Eq"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Reflectance"],"Reflectance"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[42,48],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Reflectance.purs","start":[42,1]},"title":"eqReflectance"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Ord"],"Ord"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Reflectance"],"Reflectance"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[43,50],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Reflectance.purs","start":[43,1]},"title":"ordReflectance"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Show"],"Show"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Reflectance"],"Reflectance"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[46,32],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Reflectance.purs","start":[45,1]},"title":"showReflectance"}],"comments":"Dielectric reflectance factor for PBR (0.0 to 1.0)\n\nF0 value for non-metals. Controls base reflectivity before Fresnel effect.\n","info":{"dataDeclType":"newtype","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[40,41],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Reflectance.purs","start":[40,1]},"title":"Reflectance"},{"children":[],"comments":"Create a reflectance value, clamping to 0.0-1.0\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Reflectance"],"Reflectance"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[53,37],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Reflectance.purs","start":[53,1]},"title":"reflectance"},{"children":[],"comments":"Extract the raw Number value\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Reflectance"],"Reflectance"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[81,32],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Reflectance.purs","start":[81,1]},"title":"unwrap"},{"children":[],"comments":"Convert to Number (passthrough for this type)\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Reflectance"],"Reflectance"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[85