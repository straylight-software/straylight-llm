{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                               // hydrogen // schema // dimension // objectfit"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | ObjectFit — How replaced content (images, videos) fits within its container."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | ObjectFit defines the behavior when content has a different aspect ratio"},{"LineComment":" | than its container. This is a bounded enum (5 values) that maps directly"},{"LineComment":" | to CSS object-fit."},{"LineComment":" |"},{"LineComment":" | ## Values"},{"LineComment":" |"},{"LineComment":" | | Value     | Behavior                                       |"},{"LineComment":" | |-----------|------------------------------------------------|"},{"LineComment":" | | Fill      | Stretch to fill container (distorts aspect)    |"},{"LineComment":" | | Contain   | Scale to fit inside, maintaining aspect ratio  |"},{"LineComment":" | | Cover     | Scale to cover container, clipping overflow    |"},{"LineComment":" | | None      | No scaling, content at natural size            |"},{"LineComment":" | | ScaleDown | Like None, but shrink if larger than container |"},{"LineComment":" |"},{"LineComment":" | ## Use Cases"},{"LineComment":" |"},{"LineComment":" | - **Fill**: Background images where distortion is acceptable"},{"LineComment":" | - **Contain**: Product images, thumbnails"},{"LineComment":" | - **Cover**: Hero images, avatars, backgrounds"},{"LineComment":" | - **None**: Icons at fixed size, pixel art"},{"LineComment":" | - **ScaleDown**: Responsive images that shouldn't upscale"},{"LineComment":" |"},{"LineComment":" | ## At Billion-Agent Scale"},{"LineComment":" |"},{"LineComment":" | ObjectFit is a bounded enum (5 values). Agents can enumerate all possibilities."},{"LineComment":" | No strings, no invalid states."}],"decls":[{"annotation":{"meta":null,"sourceSpan":{"end":[79,14],"start":[74,1]}},"bindType":"NonRec","expression":{"annotation":{"meta":null,"sourceSpan":{"end":[79,14],"start":[74,1]}},"constructorName":"Fill","fieldNames":[],"type":"Constructor","typeName":"ObjectFit"},"identifier":"Fill"},{"annotation":{"meta":null,"sourceSpan":{"end":[79,14],"start":[74,1]}},"bindType":"NonRec","expression":{"annotation":{"meta":null,"sourceSpan":{"end":[79,14],"start":[74,1]}},"constructorName":"Contain","fieldNames":[],"type":"Constructor","typeName":"ObjectFit"},"identifier":"Contain"},{"annotation":{"meta":null,"sourceSpan":{"end":[79,14],"start":[74,1]}},"bindType":"NonRec","expression":{"annotation":{"meta":null,"sourceSpan":{"end":[79,14],"start":[74,1]}},"constructorName":"Cover","fieldNames":[],"type":"Constructor","typeName":"ObjectFit"},"identifier":"Cover"},{"annotation":{"meta":null,"sourceSpan":{"end":[79,14],"start":[74,1]}},"bindType":"NonRec","expression":{"annotation":{"meta":null,"sourceSpan":{"end":[79,14],"start":[74,1]}},"constructorName":"None","fieldNames":[],"type":"Constructor","typeName":"ObjectFit"},"identifier":"None"},{"annotation":{"meta":null,"sourceSpan":{"end":[79,14],"start":[74,1]}},"bindType":"NonRec","expression":{"annotation":{"meta":null,"sourceSpan":{"end":[79,14],"start":[74,1]}},"constructorName":"ScaleDown","fieldNames":[],"type":"Constructor","typeName":"ObjectFit"},"identifier":"ScaleDown"},{"annotation":{"meta":null,"sourceSpan":{"end":[89,43],"start":[84,1]}},"bindType":"NonRec","expression":{"abstraction":{"annotation":{"meta":{"metaType":"IsNewtype"},"sourceSpan":{"end":[89,43],"start":[84,1]}},"type":"Var","value":{"identifier":"Show$Dict","moduleName":["Data","Show"]}},"annotation":{"meta":null,"sourceSpan":{"end":[89,43],"start":[84,1]}},"argument":{"annotation":{"meta":null,"sourceSpan":{"end":[89,43],"start":[84,1]}},"type":"Literal","value":{"literalTyp