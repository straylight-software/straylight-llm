{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                // hydrogen // schema // network // websocket"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | WebSocket Schema — Pure data types for bidirectional communication."},{"LineComment":" |"},{"LineComment":" | Models the WebSocket protocol state machine as algebraic data types."},{"LineComment":" | The runtime interprets these types to manage actual connections."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | WebSocket at billion-agent scale requires:"},{"LineComment":" | - Explicit state machine (no implicit connection states)"},{"LineComment":" | - Type-safe message handling (text vs binary)"},{"LineComment":" | - Bounded reconnection strategies"},{"LineComment":" | - Deterministic close codes"},{"LineComment":" |"},{"LineComment":" | ## State Machine"},{"LineComment":" |"},{"LineComment":" | ```"},{"LineComment":" |   ┌──────────┐"},{"LineComment":" |   │Connecting│"},{"LineComment":" |   └────┬─────┘"},{"LineComment":" |        │ connected"},{"LineComment":" |        ▼"},{"LineComment":" |   ┌────────┐  close requested"},{"LineComment":" |   │  Open  │─────────────────┐"},{"LineComment":" |   └────┬───┘                 │"},{"LineComment":" |        │ close received      ▼"},{"LineComment":" |        │                ┌─────────┐"},{"LineComment":" |        └───────────────►│ Closing │"},{"LineComment":" |                         └────┬────┘"},{"LineComment":" |                              │ closed"},{"LineComment":" |                              ▼"},{"LineComment":" |                         ┌────────┐"},{"LineComment":" |                         │ Closed │"},{"LineComment":" |                         └────────┘"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Schema.Network.WebSocket as WS"},{"LineComment":" |"},{"LineComment":" | config = WS.config (WS.wsURL \"wss://api.example.com/ws\")"},{"LineComment":" |   { protocols = [\"v1\", \"v2\"]"},{"LineComment":" |   , reconnect = Just WS.defaultReconnect"},{"LineComment":" |   }"},{"LineComment":" |"},{"LineComment":" | -- Handle incoming messages"},{"LineComment":" | case msg of"},{"LineComment":" |   WS.TextMessage text -> handleText text"},{"LineComment":" |   WS.BinaryMessage bytes -> handleBinary bytes"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from:"},{"LineComment":" | - Types: Core types (WebSocketState, WebSocketURL, Protocol, Bytes)"},{"LineComment":" | - Messages: Message types and operations"},{"LineComment":" | - Close: Close codes and events (RFC 6455)"},{"LineComment":" | - Reconnect: Reconnection strategy"},{"LineComment":" | - Events: WebSocket lifecycle events"},{"LineComment":" | - Config: Connection configuration"},{"LineComment":" | - State: Connection state compound"},{"LineComment":" | - Bounds: Bounded value definitions"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[175,14],"start":[172,1]}},"moduleName":["Hydrogen","Schema","Network","WebSocket","Bounds"]},{"annotation":{"meta":null,"sourceSpan":{"end":[140,13],"start":[117,1]}},"moduleName":["Hydrogen","Schema","Network","WebSocket","Close"]},{"annotation":{"meta":null,"sourceSpan":{"end":[162,14],"start":[156,1]}},"moduleName":["Hydrogen","Schema","Network","WebSocket","Config"]},{"annotation":{"meta":null,"sourceSpan":{"end":[154,14],"start":[152,1]}},"moduleName":["Hydrogen","Schema","Network","WebSocket","Events"]},{"annotation":{"meta":null,"sourceSpan":{"end":[115,16],"start":[108,1]}},"moduleName":["Hyd