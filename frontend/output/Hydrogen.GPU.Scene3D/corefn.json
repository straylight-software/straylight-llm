{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                                 // hydrogen // gpu // scene3d"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Scene3D — Pure Data Description of 3D Scenes"},{"LineComment":" |"},{"LineComment":" | This is the **leader module** that re-exports all Scene3D sub-modules."},{"LineComment":" | Import this module to get the complete 3D scene vocabulary."},{"LineComment":" |"},{"LineComment":" | ## Sub-Modules"},{"LineComment":" | - `Scene3D.Position` — Position3D (picometer precision), Direction3D"},{"LineComment":" | - `Scene3D.Camera` — Perspective and orthographic cameras"},{"LineComment":" | - `Scene3D.Background` — Solid, gradient, and environment backgrounds"},{"LineComment":" | - `Scene3D.Light` — Ambient, directional, point, spot, hemisphere lights"},{"LineComment":" | - `Scene3D.Material` — Basic, standard PBR, physical PBR materials"},{"LineComment":" | - `Scene3D.Mesh` — All geometry primitives and buffer geometry"},{"LineComment":" | - `Scene3D.Transform` — Transform parameters and clip planes"},{"LineComment":" | - `Scene3D.Grid` — GridScale (Planck to Parsec), Grid3D, Axes3D"},{"LineComment":" | - `Scene3D.Core` — SceneCommand, Scene3D type, PickId, buffer operations"},{"LineComment":" | - `Scene3D.Identity` — UUID5 deterministic identity for all types"},{"LineComment":" |"},{"LineComment":" | ## Design Principles"},{"LineComment":" |"},{"LineComment":" | 1. **Flat, not nested**: Arrays of commands, not scene graphs"},{"LineComment":" | 2. **Immediate mode**: Each frame is a complete description"},{"LineComment":" | 3. **Schema atoms only**: All parameters use bounded Schema types"},{"LineComment":" | 4. **GPU-native**: Commands map directly to WebGL2/WebGPU operations"},{"LineComment":" | 5. **Pick buffer ready**: Every interactive mesh carries a PickId"},{"LineComment":" |"},{"LineComment":" | ## Coordinate System"},{"LineComment":" |"},{"LineComment":" | Right-handed (OpenGL/WebGL convention):"},{"LineComment":" | - X: positive to the right"},{"LineComment":" | - Y: positive upward  "},{"LineComment":" | - Z: positive toward the viewer (out of screen)"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.GPU.Scene3D as S3D"},{"LineComment":" |"},{"LineComment":" | myScene :: S3D.Scene3D MyMsg"},{"LineComment":" | myScene = S3D.emptyScene"},{"LineComment":" |   # S3D.withCamera (S3D.perspectiveCamera cameraParams)"},{"LineComment":" |   # S3D.withBackground (S3D.solidBackground backgroundColor)"},{"LineComment":" |   # S3D.withLight (S3D.ambientLight3D ambientParams)"},{"LineComment":" |   # S3D.withMesh meshParams"},{"LineComment":" | ```"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[127,18],"start":[118,1]}},"moduleName":["Hydrogen","GPU","Scene3D","Background"]},{"annotation":{"meta":null,"sourceSpan":{"end":[116,14],"start":[107,1]}},"moduleName":["Hydrogen","GPU","Scene3D","Camera"]},{"annotation":{"meta":null,"sourceSpan":{"end":[304,12],"start":[270,1]}},"moduleName":["Hydrogen","GPU","Scene3D","Core"]},{"annotation":{"meta":null,"sourceSpan":{"end":[268,12],"start":[243,1]}},"moduleName":["Hydrogen","GPU","Scene3D","Grid"]},{"annotation":{"meta":null,"sourceSpan":{"end":[329,16],"start":[306,1]}},"moduleName":["Hydrogen","GPU","Scene3D","Identity"]},{"annotation":{"meta":null,"sourceSpan":{"end":[147,13],"start":[129,1]}},"moduleName":["Hydrogen","GPU","Scene3D","Light"]},{"annotation":{"meta":null,"sourceSpan":{"end":[161,16],"start":[149,1]}},"moduleName":["Hydrogen","GPU","Scene3D","Material"]},{"annotation":{"meta":null,"sourceSpan":{"end":[234,12],"start":[163,1]}},"moduleName":["Hydrogen","GPU","Scene3D","Mesh"]},{"annotation":{"meta