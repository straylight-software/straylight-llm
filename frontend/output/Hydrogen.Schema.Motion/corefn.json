{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                           // hydrogen // schema // motion"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Motion Graphics Schema - Atoms for animation and video production"},{"LineComment":" |"},{"LineComment":" | This module provides the foundational types for motion graphics:"},{"LineComment":" | - **Timecode**: SMPTE timecode representation"},{"LineComment":" | - **TimeRange**: In/out point pairs for clips and layers"},{"LineComment":" | - **Keyframe**: Animation keyframe data with tangents"},{"LineComment":" | - **Easing**: Interpolation curves"},{"LineComment":" | - **ZoomLevel**: Timeline zoom state"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | Import submodules with qualification:"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Schema.Motion.Timecode as TC"},{"LineComment":" | import Hydrogen.Schema.Motion.TimeRange as TR"},{"LineComment":" | import Hydrogen.Schema.Motion.Keyframe as KF"},{"LineComment":" | import Hydrogen.Schema.Motion.Easing as Easing"},{"LineComment":" | import Hydrogen.Schema.Motion.ZoomLevel as Zoom"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Integration with Temporal"},{"LineComment":" |"},{"LineComment":" | Motion types integrate with `Hydrogen.Schema.Dimension.Temporal`:"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Schema.Dimension.Temporal (Frames, FrameRate, fps24)"},{"LineComment":" | import Hydrogen.Schema.Motion.Timecode as TC"},{"LineComment":" |"},{"LineComment":" | -- Convert between frames and timecode"},{"LineComment":" | tc = TC.fromFrames (frames 2880.0) fps24 false"},{"LineComment":" | -- Result: 00:02:00:00 (2 minutes at 24fps)"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## For LATTICE"},{"LineComment":" |"},{"LineComment":" | These types are the foundation for LATTICE motion graphics components:"},{"LineComment":" | - AnimationTimeline uses Timecode, TimeRange, ZoomLevel"},{"LineComment":" | - KeyframeMarker uses Keyframe, Easing"},{"LineComment":" | - CurveEditor uses Keyframe, Easing"},{"LineComment":" |"},{"LineComment":" | Do NOT import this module directly. Import submodules with qualification."},{"LineComment":" |"},{"LineComment":" | This module exists for documentation purposes. Use qualified imports:"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Schema.Motion.Timecode as TC"},{"LineComment":" | import Hydrogen.Schema.Motion.TimeRange as TR"},{"LineComment":" | ```"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[67,69],"start":[67,1]}},"moduleName":["Hydrogen","Schema","Motion","Easing"]},{"annotation":{"meta":null,"sourceSpan":{"end":[66,145],"start":[66,1]}},"moduleName":["Hydrogen","Schema","Motion","Keyframe"]},{"annotation":{"meta":null,"sourceSpan":{"end":[65,65],"start":[65,1]}},"moduleName":["Hydrogen","Schema","Motion","TimeRange"]},{"annotation":{"meta":null,"sourceSpan":{"end":[64,82],"start":[64,1]}},"moduleName":["Hydrogen","Schema","Motion","Timecode"]},{"annotation":{"meta":null,"sourceSpan":{"end":[68,65],"start":[68,1]}},"moduleName":["Hydrogen","Schema","Motion","ZoomLevel"]},{"annotation":{"meta":null,"sourceSpan":{"end":[68,65],"start":[54,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Motion"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Motion.purs","reExports":{"Hydrogen.Schema.Motion.Easing":[],"Hydrogen.Schema.Motion.Keyframe":["Auto","Bezier","Hold","Linear"],"Hydrogen.Schema.Motion.TimeRange":[],"Hydrogen.Schema.Motion.Timecode":[],"Hydrogen.Schema.Motion.ZoomLevel":[]},"sourceSpan":{"end":[68,65],"start":[54,1]}}