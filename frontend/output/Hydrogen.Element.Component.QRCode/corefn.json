 | ```"},{"LineComment":" | Content → encode → BitStream → interleave → Matrix → render → Element"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | Pure data in, Element out. Deterministic. Same input = same pixels."}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[118,20],"start":[72,1]}},"moduleName":["Hydrogen","Element","Component","QRCode","Content","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[69,17],"start":[64,1]}},"moduleName":["Hydrogen","Element","Component","QRCode","QRCode"]},{"annotation":{"meta":null,"sourceSpan":{"end":[163,17],"start":[151,1]}},"moduleName":["Hydrogen","Element","Component","QRCode","Render","SVG"]},{"annotation":{"meta":null,"sourceSpan":{"end":[148,13],"start":[121,1]}},"moduleName":["Hydrogen","Element","Component","QRCode","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[163,17],"start":[45,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Element","Component","QRCode"],"modulePath":"../../hydrogen/src/Hydrogen/Element/Compound/QRCode.purs","reExports":{"Hydrogen.Element.Component.QRCode.Content.Types":["ContentBitcoin","ContentCalendar","ContentDeepLink","ContentEmail","ContentGeo","ContentPhone","ContentSMS","ContentSlack","ContentText","ContentURL","ContentVCard","ContentWebhook","ContentWiFi","NoPassword","WEP","WPA","WPA2","WPA3","bitcoinContent","bitcoinFull","bitcoinWithAmount","calendarContent","contentToString","deepLink","deepLinkWithFallback","emailContent","emailFull","emailWithBody","emailWithSubject","geoContent","geoWithAltitude","geoWithQuery","phoneContent","slackChannel","slackCompose","slackUser","smsContent","smsWithBody","textContent","urlContent","urlWithLabel","vCardContent","vCardFull","webhookGet","webhookPost","wifiContent","wifiHidden"],"Hydrogen.Element.Component.QRCode.QRCode":["defaultConfig","qrCode","qrCodeWith"],"Hydrogen.Element.Component.QRCode.Render.SVG":["Classic","Dots","Rounded","defaultColors","def