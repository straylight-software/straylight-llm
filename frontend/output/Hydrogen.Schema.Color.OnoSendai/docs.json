% — hand-tuned default\n- **Night**: L=8% — OLED threshold\n- **Carbon**: L=11% — good default (recommended)\n- **GitHub**: L=16% — highly robust\n","info":{"dataDeclType":"data","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[105,11],"name":"../../hydrogen/src/Hydrogen/Schema/Color/OnoSendai.purs","start":[100,1]},"title":"BlackLevel"},{"children":[],"comments":"Complete Base16 palette with 16 slots.\n\nEach slot is an RGB color generated from the hero/axis hue configuration.\n","info":{"arguments":[],"declType":"typeSynonym","type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Record"],"tag":"TypeConstructor"},{"annotation":[],"contents":["slug",{"annotation":[],"contents":[["Prim"],"String"],"tag":"TypeConstructor"},{"annotation":[],"contents":["name",{"annotation":[],"contents":[["Prim"],"String"],"tag":"TypeConstructor"},{"annotation":[],"contents":["base00",{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"},{"annotation":[],"contents":["base01",{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"},{"annotation":[],"contents":["base02",{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"},{"annotation":[],"contents":["base03",{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"},{"annotation":[],"contents":["base04",{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"},{"annotation":[],"contents":["base05",{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"},{"annotation":[],"contents":["base06",{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"},{"annotation":[],"contents":["base07",{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"},{"annotation":[],"contents