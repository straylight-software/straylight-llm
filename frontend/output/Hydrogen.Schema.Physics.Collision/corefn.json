{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                 // hydrogen // schema // physics // collision"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Collision — Collision detection and contact resolution primitives."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | Collision detection is fundamental to physics simulation and UI interaction."},{"LineComment":" | This module provides bounded, composable collision primitives that work at"},{"LineComment":" | billion-agent scale — deterministic detection with no edge cases."},{"LineComment":" |"},{"LineComment":" | ## Collision Categories"},{"LineComment":" |"},{"LineComment":" | **Bounding Volumes**: AABB, Sphere, Capsule, OBB"},{"LineComment":" | **Detection Results**: Contact points, normals, penetration depth"},{"LineComment":" | **Response Types**: Bounce, slide, stick, separate"},{"LineComment":" |"},{"LineComment":" | ## Bounded Design"},{"LineComment":" |"},{"LineComment":" | All collision results are bounded:"},{"LineComment":" | - Penetration depth is clamped to prevent numerical explosion"},{"LineComment":" | - Contact normals are always unit vectors"},{"LineComment":" | - Contact counts are finite and bounded"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" | - Collision.Point — 2D point primitives"},{"LineComment":" | - Collision.Volumes — Bounding volume types (AABB, Circle, Capsule, OBB)"},{"LineComment":" | - Collision.Contact — Contact information"},{"LineComment":" | - Collision.Detection — Collision detection algorithms"},{"LineComment":" | - Collision.Response — Response types and calculations"},{"LineComment":" | - Collision.Layers — Layer filtering system"},{"LineComment":" | - Collision.State — Collision state tracking"},{"LineComment":" |"},{"LineComment":" | ## Dependencies"},{"LineComment":" |"},{"LineComment":" | - Prelude (Eq, Ord, Show)"},{"LineComment":" | - Data.Number (sqrt, abs)"},{"LineComment":" |"},{"LineComment":" | ## Dependents"},{"LineComment":" |"},{"LineComment":" | - Motion.Physics (physics engine)"},{"LineComment":" | - Component.Draggable (drag boundaries)"},{"LineComment":" | - Component.Sortable (item collision)"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[121,15],"start":[112,1]}},"moduleName":["Hydrogen","Schema","Physics","Collision","Contact"]},{"annotation":{"meta":null,"sourceSpan":{"end":[133,17],"start":[123,1]}},"moduleName":["Hydrogen","Schema","Physics","Collision","Detection"]},{"annotation":{"meta":null,"sourceSpan":{"end":[152,14],"start":[146,1]}},"moduleName":["Hydrogen","Schema","Physics","Collision","Layers"]},{"annotation":{"meta":null,"sourceSpan":{"end":[85,13],"start":[75,1]}},"moduleName":["Hydrogen","Schema","Physics","Collision","Point"]},{"annotation":{"meta":null,"sourceSpan":{"end":[144,16],"start":[135,1]}},"moduleName":["Hydrogen","Schema","Physics","Collision","Response"]},{"annotation":{"meta":null,"sourceSpan":{"end":[159,13],"start":[154,1]}},"moduleName":["Hydrogen","Schema","Physics","Collision","State"]},{"annotation":{"meta":null,"sourceSpan":{"end":[110,15],"start":[87,1]}},"moduleName":["Hydrogen","Schema","Physics","Collision","Volumes"]},{"annotation":{"meta":null,"sourceSpan":{"end":[159,13],"start":[48,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Physics","Collision"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Physics/Collision.purs","reExports":{"Hydrogen.Schema.Physics.Collision.Contact":["Contact","NoContact","contact","contactDepth","contactNormal","contactPoint","flipContact","hasContact","noContact"],"Hydrogen.Schema.Physics.Collisio