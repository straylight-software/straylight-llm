{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                                // hydrogen // target // webgl"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | WebGL2 Rendering Target"},{"LineComment":" |"},{"LineComment":" | Renders DrawCommands via WebGL2 for GPU-accelerated graphics."},{"LineComment":" | This is the fallback when WebGPU is not available."},{"LineComment":" |"},{"LineComment":" | ## Browser Support"},{"LineComment":" |"},{"LineComment":" | WebGL2 is supported on:"},{"LineComment":" | - iOS Safari 15+ (2021)"},{"LineComment":" | - Android Chrome 58+ (2017)"},{"LineComment":" | - Desktop Chrome 56+ (2017)"},{"LineComment":" | - Firefox 51+ (2017)"},{"LineComment":" | - Edge 79+ (2020)"},{"LineComment":" |"},{"LineComment":" | ## Performance Characteristics"},{"LineComment":" |"},{"LineComment":" | WebGL2 is true GPU rendering with:"},{"LineComment":" | - Programmable shaders (GLSL ES 3.0)"},{"LineComment":" | - Instanced rendering for particles"},{"LineComment":" | - Texture atlases for text"},{"LineComment":" | - Hardware anti-aliasing"},{"LineComment":" |"},{"LineComment":" | Good for:"},{"LineComment":" | - 10,000+ particles"},{"LineComment":" | - Complex effects (blur, glow)"},{"LineComment":" | - Smooth animations at 60fps"},{"LineComment":" |"},{"LineComment":" | ## Architecture"},{"LineComment":" |"},{"LineComment":" | DrawCommands are batched by type and rendered in passes:"},{"LineComment":" | 1. Opaque geometry (front-to-back)"},{"LineComment":" | 2. Transparent geometry (back-to-front)"},{"LineComment":" | 3. Post-processing effects"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Target.WebGL as WebGL"},{"LineComment":" | import Hydrogen.GPU.Flatten as Flatten"},{"LineComment":" |"},{"LineComment":" | renderWithWebGL :: Element Msg -> Effect Unit"},{"LineComment":" | renderWithWebGL element = do"},{"LineComment":" |   ctx <- WebGL.getContext \"my-canvas\""},{"LineComment":" |   case ctx of"},{"LineComment":" |     Left err -> Console.log err"},{"LineComment":" |     Right gl -> do"},{"LineComment":" |       let result = Flatten.flatten element"},{"LineComment":" |       WebGL.render gl result.commands"},{"LineComment":" | ```"}],"decls":[{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"bindType":"NonRec","expression":{"abstraction":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[171,7],"start":[171,3]}},"type":"Var","value":{"identifier":"pure","moduleName":["Control","Applicative"]}},"annotation":{"meta":{"metaType":"IsSyntheticApp"},"sourceSpan":{"end":[171,12],"start":[171,3]}},"argument":{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"type":"Var","value":{"identifier":"applicativeEffect","moduleName":["Effect"]}},"type":"App"},"identifier":"pure"},{"annotation":{"meta":null,"sourceSpan":{"end":[166,73],"start":[166,1]}},"bindType":"NonRec","expression":{"annotation":{"meta":null,"sourceSpan":{"end":[166,73],"start":[166,1]}},"argument":"renderer","body":{"annotation":{"meta":null,"sourceSpan":{"end":[166,73],"start":[166,1]}},"argument":"commands","body":{"abstraction":{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"type":"Var","value":{"identifier":"pure","moduleName":["Hydrogen","Target","WebGL"]}},"annotation":{"meta":null,"sourceSpan":{"end":[171,12],"start":[171,3]}},"argument":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[171,12],"start":[171,8]}},"type":"Var","value":{"identifier":"unit","moduleName":["Data","Unit"]}},"type":"App"},"type":"Abs"},"type":"Abs"},"identifier":"render"},{"annotation":{"meta":null,"sourceSpan":{"end":[126,36],"start":[126,1]}},"bindType":"NonRec","expression":{"annotation":{"meta"