{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                      // hydrogen // schema // gpu // landauer"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Landauer — Entropy-based precision selection."},{"LineComment":" |"},{"LineComment":" | ## Core Insight"},{"LineComment":" |"},{"LineComment":" | Precision is not a hyperparameter to optimize — it is a **physical quantity"},{"LineComment":" | to measure**. Drawing on Landauer's principle: the computational cost of"},{"LineComment":" | precision transitions is determined by the mismatch between representation"},{"LineComment":" | capacity and actual information content."},{"LineComment":" |"},{"LineComment":" | ## Landauer's Principle"},{"LineComment":" |"},{"LineComment":" | Erasing one bit of information requires dissipating at least kT ln 2 joules."},{"LineComment":" | "},{"LineComment":" | ```"},{"LineComment":" | E_min = kT ln 2 · (H_in - H_out)"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | **Crucially**: If H_out = H_in, the operation is thermodynamically reversible"},{"LineComment":" | and can be performed at ZERO energy cost. This includes:"},{"LineComment":" | - Bijective mappings"},{"LineComment":" | - Any transformation preserving information content"},{"LineComment":" |"},{"LineComment":" | ## Natural Precision"},{"LineComment":" |"},{"LineComment":" | Given tolerance ε, the **natural precision** at a point is:"},{"LineComment":" |"},{"LineComment":" | ```"},{"LineComment":" | b* = min{ b ∈ ℕ : E[D(φ(x), φ(Q_b(x)))] ≤ ε }"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | This is the minimum bits needed to stay within tolerated distortion."},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | -- Measure entropy and derive precision"},{"LineComment":" | let entropy = measureEntropy activations"},{"LineComment":" | let precision = naturalPrecision entropy tolerance"},{"LineComment":" | "},{"LineComment":" | -- Check if precision transition is free"},{"LineComment":" | let cost = landauerCost sourceEntropy targetBits"},{"LineComment":" | if cost == freeBoundary then fusedEpilogue else spillToMemory"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Semantic Types"},{"LineComment":" |"},{"LineComment":" | Different data types have natural entropy bounds:"},{"LineComment":" | - Pixel: ~24 bits"},{"LineComment":" | - Latent: ~4 bits (highly compressed)"},{"LineComment":" | - Attention: ~8 bits"},{"LineComment":" | - Probability: ≤ log₂(classes) bits"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module re-exporting from:"},{"LineComment":" | - `Types` — Core types: Entropy, NaturalPrecision, LandauerCost"},{"LineComment":" | - `Tolerance` — Distortion tolerance and dual sensitivity"},{"LineComment":" | - `Format` — Hardware precision formats"},{"LineComment":" | - `Semantic` — Semantic types and information bundles"},{"LineComment":" | - `Domain` — Domain boundaries and gauge transformations"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[78,53],"start":[78,1]}},"moduleName":["Hydrogen","Schema","GPU","Landauer","Domain"]},{"annotation":{"meta":null,"sourceSpan":{"end":[76,53],"start":[76,1]}},"moduleName":["Hydrogen","Schema","GPU","Landauer","Format"]},{"annotation":{"meta":null,"sourceSpan":{"end":[77,57],"start":[77,1]}},"moduleName":["Hydrogen","Schema","GPU","Landauer","Semantic"]},{"annotation":{"meta":null,"sourceSpan":{"end":[75,59],"start":[75,1]}},"moduleName":["Hydrogen","Schema","GPU","Landauer","Tolerance"]},{"annotation":{"meta":null,"sourceSpan":{"end":[74,51],"start":[74,1]}},"moduleName":["Hydrogen","Schema","GPU","Landauer","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[78,53],"start":[66,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","GPU","Landauer"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/GPU/Landauer.purs","reExports":{"Hydrogen.Schema.GPU.Landauer.Domain":["bijectiveRemap","boundary","boundaryCost","boundaryIsFree","domain","domainEntropy","domainPrecision","gaugeTransformCost","isInjective"],"Hydrogen.Schema.GPU.Landauer.Format":["BF16","FP16","FP32","FP4","FP8E4M3","FP8E5M2","INT4","INT8","formatBits","formatCapacity","formatForEntropy"],"Hydrogen.Schema.GPU.Landauer.Semantic":["Accumulator","Attention","Embedding","Gradient","Latent","Pixel","Probability","Token","bundleEntropy","bundleSemanticType","bundleShape","infoBundle","semanticTypeBits","semanticTypeEntropy"],"Hydrogen.Schema.GPU.Landauer.Tolerance":["backwardSensitivity","distortionTolerance","effectivePrecision","effectivePrecisionSymmetric","forwardSensitivity","operationalPrecision","satisfiesBackwardTolerance","satisfiesDualTolerance","satisfiesForwardTolerance","symmetricTolerance","toleranceBackward","toleranceForward"],"Hydrogen.Schema.GPU.Landauer.Types":["boltzmannConstant","ceilInt","costInJoules","entropy","entropyBits","entropyBounds","entropyUnsafe","freeBoundary","intToNumber","isFree","landauerCost","landauerCostNumber","naturalPrecision","precisionBits","precisionFromEntropy","roomTemperature","thermalEnergy","truncateNumber","unwrapEntropy","unwrapPrecision"]},"sourceSpan":{"end":[78,53],"start":[66,1]}}