{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                                  // hydrogen // gpu // binary"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Binary Serialization Format for GPU Commands"},{"LineComment":" |"},{"LineComment":" | This module defines the binary wire format for DrawCommands. Any GPU"},{"LineComment":" | runtime that consumes Hydrogen output reads this format."},{"LineComment":" |"},{"LineComment":" | ## Design Principles"},{"LineComment":" |"},{"LineComment":" | 1. **Fixed-size records**: Every command type has a known byte size."},{"LineComment":" |    No variable-length encoding on the hot path."},{"LineComment":" |"},{"LineComment":" | 2. **Little-endian**: Matches WebGPU/native GPU expectations."},{"LineComment":" |"},{"LineComment":" | 3. **Aligned**: All fields are naturally aligned (f32 on 4-byte, etc.)"},{"LineComment":" |"},{"LineComment":" | 4. **Deterministic**: Same DrawCommand produces identical bytes."},{"LineComment":" |    Enables caching, hashing, deduplication."},{"LineComment":" |"},{"LineComment":" | 5. **Schema atoms map to GPU types**:"},{"LineComment":" |    - Pixel -> f32"},{"LineComment":" |    - RGB channels -> u8 (packed) or f32 (unpacked)"},{"LineComment":" |    - PickId -> u32"},{"LineComment":" |    - Radius -> f32"},{"LineComment":" |"},{"LineComment":" | ## Wire Format Overview"},{"LineComment":" |"},{"LineComment":" | ```"},{"LineComment":" | CommandBuffer := Header + Array Command"},{"LineComment":" |"},{"LineComment":" | Header (16 bytes):"},{"LineComment":" |   magic     : u32 = 0x48594447 (\"HYDG\")"},{"LineComment":" |   version   : u32 = 1"},{"LineComment":" |   count     : u32 = number of commands"},{"LineComment":" |   flags     : u32 = reserved"},{"LineComment":" |"},{"LineComment":" | Command := CommandType (u8) + Padding (alignment) + Payload"},{"LineComment":" |"},{"LineComment":" | CommandType:"},{"LineComment":" |   0x01 = DrawRect"},{"LineComment":" |   0x02 = DrawQuad"},{"LineComment":" |   0x03 = DrawGlyph"},{"LineComment":" |   0x04 = DrawPath (variable size - stored separately)"},{"LineComment":" |   0x05 = DrawParticle"},{"LineComment":" |   0x10 = PushClip"},{"LineComment":" |   0x11 = PopClip"},{"LineComment":" |   0x00 = Noop"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This leader module re-exports from:"},{"LineComment":" | - `Hydrogen.GPU.Binary.Types` - Core types"},{"LineComment":" | - `Hydrogen.GPU.Binary.Constants` - Magic numbers and sizes"},{"LineComment":" | - `Hydrogen.GPU.Binary.LowLevel` - Byte read/write operations"},{"LineComment":" | - `Hydrogen.GPU.Binary.Primitives` - Core serializers"},{"LineComment":" | - `Hydrogen.GPU.Binary.Typography` - V2 typography serializers"},{"LineComment":" | - `Hydrogen.GPU.Binary.Media` - Media serializers"},{"LineComment":" | - `Hydrogen.GPU.Binary.Deserialize` - Deserialization"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.GPU.Binary as Binary"},{"LineComment":" | import Hydrogen.GPU.DrawCommand as DC"},{"LineComment":" |"},{"LineComment":" | -- Serialize a command buffer"},{"LineComment":" | bytes :: Binary.Bytes"},{"LineComment":" | bytes = Binary.serialize commands"},{"LineComment":" |"},{"LineComment":" | -- Get raw byte array for transmission"},{"LineComment":" | raw :: Array Int"},{"LineComment":" | raw = Binary.toByteArray bytes"},{"LineComment":" | ```"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[134,17],"start":[121,1]}},"moduleName":["Hydrogen","GPU","Binary","Constants"]},{"annotation":{"meta":null,"sourceSpan":{"end":[195,19],"start":[191,1]}},"moduleName":["Hydrogen","GPU","Binary","Deserialize"]},{"annotation":{"meta":null,"sourceSpan":{"end":[148,16],"start":[136,1]}},"moduleName":["Hydrogen","GPU","Binary","LowLevel"]},{"annotation":{"meta":null,"sourceSpan":{"end":[189,13],"start":[185,1]}},"moduleName":["Hydrogen","GPU","Binary","Media"]},{"annotation":{"meta":null,"sourceSpan":{"end":[166,18],"start":[150,1]}},"moduleName":["Hydrogen","GPU","Binary","Primitives"]},{"annotation":{"meta":null,"sourceSpan":{"end":[119,13],"start":[101,1]}},"moduleName":["Hydrogen","GPU","Binary","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[183,18],"start":[168,1]}},"moduleName":["Hydrogen","GPU","Binary","Typography"]},{"annotation":{"meta":null,"sourceSpan":{"end":[195,19],"start":[78,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","GPU","Binary"],"modulePath":"../../hydrogen/src/Hydrogen/GPU/Binary.purs","reExports":{"Hydrogen.GPU.Binary.Constants":["animationStateHeaderSize","glyphInstancePayloadSize","glyphPathHeaderSize","glyphPayloadSize","headerSize","magic","particlePayloadSize","pathDataHeaderSize","quadPayloadSize","rectPayloadSize","version","wordHeaderSize"],"Hydrogen.GPU.Binary.Deserialize":["deserialize","deserializeCommand","deserializeHeader"],"Hydrogen.GPU.Binary.LowLevel":["fromByteArray","readF32","readU32","readU8","stringToBytes","toByteArray","writeF32","writeI8","writeU16","writeU32","writeU8"],"Hydrogen.GPU.Binary.Media":["serialize3D","serializeImage","serializeVideo"],"Hydrogen.GPU.Binary.Primitives":["pad","pickIdToInt","radiusToNumber","serialize","serializeClipRegion","serializeCommand","serializeGlyph","serializeHeader","serializeMaybeColor","serializeParticle","serializePath","serializePathSegment","serializeQuad","serializeRect","unwrapPixel"],"Hydrogen.GPU.Binary.Types":["Bytes","CmdDefinePathData","CmdDrawGlyph","CmdDrawGlyphInstance","CmdDrawGlyphPath","CmdDrawParticle","CmdDrawPath","CmdDrawQuad","CmdDrawRect","CmdDrawWord","CmdNoop","CmdPopClip","CmdPushClip","CmdUpdateAnimationState"