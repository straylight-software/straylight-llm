{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                        // hydrogen // schema // brush // tip"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Brush Tip — Shape and geometry of the brush mark."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | A brush tip defines the shape of a single \"dab\" — the mark left when the"},{"LineComment":" | brush touches the canvas once. All brush strokes are sequences of dabs"},{"LineComment":" | placed along a path at intervals defined by spacing."},{"LineComment":" |"},{"LineComment":" | ## Professional Brush Tip Categories"},{"LineComment":" |"},{"LineComment":" | 1. **Round**: Circular with adjustable hardness (soft/hard edges)"},{"LineComment":" | 2. **Flat**: Rectangular, good for calligraphy"},{"LineComment":" | 3. **Fan**: Multiple bristle groups, for blending"},{"LineComment":" | 4. **Chisel**: Angled flat tip"},{"LineComment":" | 5. **Rake**: Multiple parallel bristles"},{"LineComment":" | 6. **Texture**: Image-based tip shapes"},{"LineComment":" |"},{"LineComment":" | ## Key Properties"},{"LineComment":" |"},{"LineComment":" | - **Diameter**: Size in pixels (1-5000)"},{"LineComment":" | - **Hardness**: Edge falloff (0% = soft gaussian, 100% = hard circle)"},{"LineComment":" | - **Roundness**: Ellipse ratio (100% = circle, 1% = line)"},{"LineComment":" | - **Angle**: Rotation of ellipse (0-360°)"},{"LineComment":" | - **Spacing**: Distance between dabs as % of diameter (1-1000%)"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" |"},{"LineComment":" | - **Types**: TipShape ADT and predicates"},{"LineComment":" | - **Parameters**: Bounded numeric parameters (Diameter, Hardness, etc.)"},{"LineComment":" | - **Compound**: BrushTip record type and preset configurations"},{"LineComment":" | - **Operations**: Accessors, modifiers, and query functions"},{"LineComment":" |"},{"LineComment":" | ## Dependencies"},{"LineComment":" |"},{"LineComment":" | - Tip.Types"},{"LineComment":" | - Tip.Parameters"},{"LineComment":" | - Tip.Compound"},{"LineComment":" | - Tip.Operations"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[130,16],"start":[121,1]}},"moduleName":["Hydrogen","Schema","Brush","Tip","Compound"]},{"annotation":{"meta":null,"sourceSpan":{"end":[159,18],"start":[132,1]}},"moduleName":["Hydrogen","Schema","Brush","Tip","Operations"]},{"annotation":{"meta":null,"sourceSpan":{"end":[119,18],"start":[75,1]}},"moduleName":["Hydrogen","Schema","Brush","Tip","Parameters"]},{"annotation":{"meta":null,"sourceSpan":{"end":[73,13],"start":[57,1]}},"moduleName":["Hydrogen","Schema","Brush","Tip","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[159,18],"start":[46,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Brush","Tip"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Brush/Tip.purs","reExports":{"Hydrogen.Schema.Brush.Tip.Compound":["airbrushTip","brushTip","calligraphyTip","defaultBrushTip","flatBrushTip","pencilTip","roundBrushTip"],"Hydrogen.Schema.Brush.Tip.Operations":["dabsPerDiameter","hasSignificantAngle","isBroadCoverage","isCircular","isDense","isElliptical","isFineDetail","isHardEdge","isMediumEdge","isSoftEdge","isSparse","tipAngleValue","tipDiameter","tipFlipX","tipFlipY","tipHardness","tipRoundness","tipShape","tipSpacing","withAngle","withDiameter","withFlipX","withFlipY","withHardness","withRoundness","withSpacing"],"Hydrogen.Schema.Brush.Tip.Parameters":["Diameter","FlipX","FlipY","Hardness","Roundness","Spacing","TipAngle","airbrushSpacing","circularRoundness","defaultDiameter","defaultSpacing","diagonalAngle","diameter","dia