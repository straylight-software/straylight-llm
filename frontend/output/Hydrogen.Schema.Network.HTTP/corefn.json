{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                     // hydrogen // schema // network // http"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | HTTP Request/Response Schema — Pure data types for HTTP communication."},{"LineComment":" |"},{"LineComment":" | Provides bounded, deterministic types for HTTP operations without"},{"LineComment":" | requiring JavaScript FFI. The runtime interprets these pure data"},{"LineComment":" | structures to execute actual network requests."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | HTTP communication at billion-agent scale requires:"},{"LineComment":" | - Deterministic request construction (same config = same request)"},{"LineComment":" | - Bounded timeout values (no infinite waits)"},{"LineComment":" | - Explicit error states (no magic error strings)"},{"LineComment":" | - Complete response representation (headers, status, body)"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Schema.Network.HTTP as HTTP"},{"LineComment":" |"},{"LineComment":" | -- Build a request"},{"LineComment":" | request = HTTP.request"},{"LineComment":" |   { method: HTTP.GET"},{"LineComment":" |   , url: HTTP.url \"https://api.example.com/users\""},{"LineComment":" |   , headers: [HTTP.header \"Authorization\" \"Bearer token\"]"},{"LineComment":" |   , body: Nothing"},{"LineComment":" |   , timeout: Just (HTTP.timeoutSeconds 30)"},{"LineComment":" |   }"},{"LineComment":" |"},{"LineComment":" | -- Pattern match on result"},{"LineComment":" | case result of"},{"LineComment":" |   HTTP.HTTPOk response -> handleSuccess response"},{"LineComment":" |   HTTP.HTTPTimeout -> handleTimeout"},{"LineComment":" |   HTTP.HTTPNetworkError -> handleNetworkError"},{"LineComment":" |   HTTP.HTTPCORSError -> handleCORS"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Module Organization"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" | - `HTTP.Methods` — HTTP method types (GET, POST, etc.)"},{"LineComment":" | - `HTTP.URL` — URL type and manipulation"},{"LineComment":" | - `HTTP.Headers` — Header types and common headers"},{"LineComment":" | - `HTTP.Body` — Request body types"},{"LineComment":" | - `HTTP.Timeout` — Timeout configuration"},{"LineComment":" | - `HTTP.Status` — Status codes and predicates"},{"LineComment":" | - `HTTP.Request` — HTTP request construction"},{"LineComment":" | - `HTTP.Response` — HTTP response types"},{"LineComment":" | - `HTTP.Result` — Result/error handling"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[108,12],"start":[102,1]}},"moduleName":["Hydrogen","Schema","Network","HTTP","Body"]},{"annotation":{"meta":null,"sourceSpan":{"end":[100,15],"start":[85,1]}},"moduleName":["Hydrogen","Schema","Network","HTTP","Headers"]},{"annotation":{"meta":null,"sourceSpan":{"end":[75,15],"start":[70,1]}},"moduleName":["Hydrogen","Schema","Network","HTTP","Methods"]},{"annotation":{"meta":null,"sourceSpan":{"end":[153,15],"start":[146,1]}},"moduleName":["Hydrogen","Schema","Network","HTTP","Request"]},{"annotation":{"meta":null,"sourceSpan":{"end":[161,16],"start":[155,1]}},"moduleName":["Hydrogen","Schema","Network","HTTP","Response"]},{"annotation":{"meta":null,"sourceSpan":{"end":[170,14],"start":[163,1]}},"moduleName":["Hydrogen","Schema","Network","HTTP","Result"]},{"annotation":{"meta":null,"sourceSpan":{"end":[144,14],"start":[121,1]}},"moduleName":["Hydrogen","Schema","Network","HTTP","Status"]},{"annotation":{"meta":null,"sourceSpan":{"end":[119,15],"start":[110,1]}},"moduleName":["Hydrogen","Schema","Network","HTTP","Time