{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                                            // hydrogen // tour"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Product Tour Component — The ULTIMATE Tour System"},{"LineComment":" |"},{"LineComment":" | Type-safe, accessible, animated product tours for Hydrogen applications."},{"LineComment":" |"},{"LineComment":" | ## Features"},{"LineComment":" |"},{"LineComment":" | - **Type-Safe**: All configuration via ADTs, not strings"},{"LineComment":" | - **Accessible**: WCAG 2.1 AA compliant, keyboard navigation, screen reader support"},{"LineComment":" | - **Elm Architecture**: Pure state management with `State × Msg → State × [Cmd]`"},{"LineComment":" | - **Flexible Targeting**: CSS selectors, test IDs, ARIA roles, multi-element"},{"LineComment":" | - **Spring Physics**: Natural motion with spring animations"},{"LineComment":" | - **Spotlight Morphing**: Smooth transitions between target elements"},{"LineComment":" | - **Persistent**: \"Don't show again\", snooze, completion tracking"},{"LineComment":" | - **Reduced Motion**: Respects prefers-reduced-motion"},{"LineComment":" |"},{"LineComment":" | ## Quick Start"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Tour as Tour"},{"LineComment":" |"},{"LineComment":" | -- Define your steps"},{"LineComment":" | mySteps :: Array (Tour.Step MyMsg)"},{"LineComment":" | mySteps ="},{"LineComment":" |   [ Tour.step (Tour.mkStepId \"welcome\")"},{"LineComment":" |       [ Tour.target (Tour.ByTestId (Tour.mkTestId \"welcome-btn\"))"},{"LineComment":" |       , Tour.title \"Welcome!\""},{"LineComment":" |       , Tour.body \"Let's take a quick tour.\""},{"LineComment":" |       , Tour.buttons"},{"LineComment":" |           [ Tour.nextButton \"Get Started\""},{"LineComment":" |           , Tour.skipButton \"Skip\""},{"LineComment":" |           ]"},{"LineComment":" |       ]"},{"LineComment":" |   , Tour.step (Tour.mkStepId \"feature\")"},{"LineComment":" |       [ Tour.target (Tour.BySelector (Tour.unsafeSelector \"#main-feature\"))"},{"LineComment":" |       , Tour.title \"Main Feature\""},{"LineComment":" |       , Tour.body \"This is where the magic happens.\""},{"LineComment":" |       , Tour.placement Tour.Right Tour.Center"},{"LineComment":" |       , Tour.buttons"},{"LineComment":" |           [ Tour.prevButton \"Back\""},{"LineComment":" |           , Tour.completeButton \"Done\""},{"LineComment":" |           ]"},{"LineComment":" |       ]"},{"LineComment":" |   ]"},{"LineComment":" |"},{"LineComment":" | -- Initialize tour state"},{"LineComment":" | tourState :: Tour.TourState MyMsg"},{"LineComment":" | tourState = Tour.initTour (Tour.mkTourId \"onboarding\") mySteps"},{"LineComment":" |"},{"LineComment":" | -- Render the tour"},{"LineComment":" | view :: forall w. AppState -> HH.HTML w AppMsg"},{"LineComment":" | view state = HH.div_"},{"LineComment":" |   [ mainContent"},{"LineComment":" |   , map TourAction (Tour.tour state.tourState)"},{"LineComment":" |   ]"},{"LineComment":" |"},{"LineComment":" | -- Handle tour messages"},{"LineComment":" | handleAction :: AppMsg -> H.HalogenM ..."},{"LineComment":" | handleAction = case _ of"},{"LineComment":" |   TourAction msg -> do"},{"LineComment":" |     result <- Tour.update msg <$> H.gets _.tourState"},{"LineComment":" |     H.modify_ _ { tourState = result.state }"},{"LineComment":" |     -- Handle commands (scrolling, analytics, etc.)"},{"LineComment":" |     for_ result.cmds handleTourCmd"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Architecture"},{"LineComment":" |"},{"LineComment":" | The tour follows the Elm architecture:"},{"LineComment":" |"},{"LineComment":" | ```"},{"LineComment":" | TourState × TourMsg → TourState × [TourCmd]"},{"LineComment":" | view :: TourState → Element TourMsg"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | State changes are pure and predictable. Side effects (DOM manipulation,"},{"LineComment":" | storage, analytics) are represented as commands that the runtime executes."},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | - **Hydrogen.Tour.Types** - Core ADTs (identifiers, targets, placement)"},{"LineComment":" | - **Hydrogen.Tour.Step** - Step configuration"},{"LineComment":" | - **Hydrogen.Tour.State** - State and configuration types"},{"LineComment":" | - **Hydrogen.Tour.Update** - State machine"},{"LineComment":" | - **Hydrogen.Tour.View** - UI components (Halogen)"},{"LineComment":" | - **Hydrogen.Tour.Storage** - Persistence"},{"LineComment":" | - **Hydrogen.Tour.Animation** - Motion system (springs, easing, morph)"},{"LineComment":" | - **Hydrogen.Tour.Target** - Target resolution"},{"LineComment":" | - **Hydrogen.Tour.Highlight** - Spotlight and overlay"},{"LineComment":" | - **Hydrogen.Tour.Navigation** - Progress and buttons"},{"LineComment":" | - **Hydrogen.Tour.Msg** - Complete message algebra"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[204,4],"start":[181,1]}},"moduleName":["Hydrogen","Tour","State"]},{"annotation":{"meta":null,"sourceSpan":{"end":[179,4],"start":[144,1]}},"moduleName":["Hydrogen","Tour","Step"]},{"annotation":{"meta":null,"sourceSpan":{"end":[247,4],"start":[234,1]}},"moduleName":["Hydrogen","Tour","Storage"]},{"annotation":{"meta":null,"sourceSpan":{"end":[142,4],"start":[110,1]}},"moduleName":["Hydrogen","Tour","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[212,4],"start":[206,1]}},"moduleName":["Hydrogen","Tour","Update"]},{"annotation":{"meta":null,"sourceSpan":{"end":[232,4],"start":[214,1]}},"moduleName":["Hydrogen","Tour","View"]},{"annotation":{"meta":null,"sourceSpan":{"end":[247,4],"start":[