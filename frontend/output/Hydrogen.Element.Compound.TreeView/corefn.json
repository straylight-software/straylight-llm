{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                           // hydrogen // element // tree-view"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | TreeView — Schema-native hierarchical tree component."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | This component is a **compound** of Schema atoms, composed from:"},{"LineComment":" | - Color: icon colors, selection highlight, focus ring"},{"LineComment":" | - Dimension: indent spacing per depth level, node height"},{"LineComment":" | - Geometry: selection corners/radius"},{"LineComment":" | - Reactive: SelectionState, FocusManagement for selection/focus"},{"LineComment":" | - Gestural: keyboard navigation, drag-drop"},{"LineComment":" | - Graph: layout algorithms, connections, viewport"},{"LineComment":" |"},{"LineComment":" | ## Architecture"},{"LineComment":" |"},{"LineComment":" | TreeView is organized into submodules following the Carousel pattern:"},{"LineComment":" |"},{"LineComment":" | | Module        | Purpose                                    |"},{"LineComment":" | |---------------|--------------------------------------------|"},{"LineComment":" | | Types         | NodeId, SelectionMode, CheckState, etc.    |"},{"LineComment":" | | State         | Runtime state (expanded, selected, etc.)   |"},{"LineComment":" | | Node          | Tree data structure and queries            |"},{"LineComment":" | | Navigation    | Keyboard navigation logic                  |"},{"LineComment":" | | Selection     | Selection and checkbox logic               |"},{"LineComment":" | | DragDrop      | Drag and drop reordering                   |"},{"LineComment":" | | Layout        | Position computation for all layout types  |"},{"LineComment":" | | Connection    | Visual connections between nodes           |"},{"LineComment":" | | Content       | Slot-based content rendering               |"},{"LineComment":" | | Viewport      | Virtualization for 100k+ nodes             |"},{"LineComment":" | | Animation     | Motion and transitions                     |"},{"LineComment":" | | Accessibility | ARIA, announcements, RTL support           |"},{"LineComment":" | | Render        | Pure Element rendering                     |"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Element.Compound.TreeView as TreeView"},{"LineComment":" |"},{"LineComment":" | -- Build tree data"},{"LineComment":" | let tree = TreeView.emptyTree"},{"LineComment":" |              # TreeView.insertNode (TreeView.branchNode (TreeView.nodeId \"root\") \"Root\" [])"},{"LineComment":" |              # TreeView.insertNode (TreeView.leafNode (TreeView.nodeId \"child1\") \"Child 1\")"},{"LineComment":" |"},{"LineComment":" | -- Initial state"},{"LineComment":" | let state = TreeView.initialState"},{"LineComment":" |"},{"LineComment":" | -- Render"},{"LineComment":" | TreeView.renderTreeView"},{"LineComment":" |   [ TreeView.selectedColor brand.primaryLight"},{"LineComment":" |   , TreeView.focusRingColor brand.primaryColor"},{"LineComment":" |   , TreeView.indentSize (Device.pixel 24)"},{"LineComment":" |   ]"},{"LineComment":" |   tree"},{"LineComment":" |   state"},{"LineComment":" | ```"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[568,21],"start":[529,1]}},"moduleName":["Hydrogen","Element","Compound","TreeView","Accessibility"]},{"annotation":{"meta":null,"sourceSpan":{"end":[527,17],"start":[479,1]}},"moduleName":["Hydrogen","Element","Compound","TreeView","Animation"]},{"annotation":{"meta":null,"sourceSpan":{"end":[409,18],"start":[390,1]}},"moduleName":["Hydrogen","Element","Compound","TreeView","Connection"]},{"annotation":