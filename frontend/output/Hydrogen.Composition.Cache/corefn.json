{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                            // hydrogen // composition // cache"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Composition Cache — Event-driven stable state caching."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | The composition layer is **event-driven, not frame-driven**. UI is stable"},{"LineComment":" | until an event occurs. This means:"},{"LineComment":" |"},{"LineComment":" | 1. **Stable states don't recalculate** — Cache composition results until"},{"LineComment":" |    a trigger fires"},{"LineComment":" | 2. **Content-addressed** — Same Node tree = same cache key (UUID5)"},{"LineComment":" | 3. **Generation-aware** — Track when compositions change"},{"LineComment":" | 4. **Tiered** — Hot path (L0) vs composition results (L1) vs computed (L2)"},{"LineComment":" |"},{"LineComment":" | ## Cache Tiers"},{"LineComment":" |"},{"LineComment":" | - **L0 (Stable State)**: Hot path, <1ms, short TTL"},{"LineComment":" |   Currently visible compositions, immediate access"},{"LineComment":" |   "},{"LineComment":" | - **L1 (Composition)**: Rendered compositions, <5ms, medium TTL"},{"LineComment":" |   Fully composed nodes ready for GPU submission"},{"LineComment":" |   "},{"LineComment":" | - **L2 (Computed)**: Derived properties, <10ms, longer TTL"},{"LineComment":" |   Layout calculations, bounding boxes, hit testing data"},{"LineComment":" |"},{"LineComment":" | ## Invalidation Strategies"},{"LineComment":" |"},{"LineComment":" | 1. **Generation-based**: Entity updated → generation bumped → cache miss"},{"LineComment":" | 2. **TTL-based**: Entries expire after configured duration"},{"LineComment":" | 3. **Tag-based**: Invalidate related entries (e.g., brand change)"},{"LineComment":" | 4. **Memory pressure**: Evict LRU when at capacity"},{"LineComment":" |"},{"LineComment":" | ## At Billion-Agent Scale"},{"LineComment":" |"},{"LineComment":" | Content-addressed caching is critical:"},{"LineComment":" | - Same composition across agents → same cache key → shared computation"},{"LineComment":" | - Diff by ID, not content → O(1) change detection"},{"LineComment":" | - Hierarchical grouping → 1000 agents moving = 1 invalidation"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" | - `Cache.Types`: Core type definitions"},{"LineComment":" | - `Cache.Config`: Default configurations"},{"LineComment":" | - `Cache.LRU`: LRU tracking operations"},{"LineComment":" | - `Cache.Operations`: Core get/put/invalidate/evict"},{"LineComment":" | - `Cache.Query`: Read-only queries and filtering"},{"LineComment":" | - `Cache.Stats`: Hit/miss rates and metrics"},{"LineComment":" | - `Cache.Identified`: Content-addressed integration"},{"LineComment":" | - `Cache.Debug`: Debugging utilities"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[72,51],"start":[72,1]}},"moduleName":["Hydrogen","Composition","Cache","Config"]},{"annotation":{"meta":null,"sourceSpan":{"end":[78,49],"start":[78,1]}},"moduleName":["Hydrogen","Composition","Cache","Debug"]},{"annotation":{"meta":null,"sourceSpan":{"end":[77,59],"start":[77,1]}},"moduleName":["Hydrogen","Composition","Cache","Identified"]},{"annotation":{"meta":null,"sourceSpan":{"end":[73,45],"start":[73,1]}},"moduleName":["Hydrogen","Composition","Cache","LRU"]},{"annotation":{"meta":null,"sourceSpan":{"end":[74,59],"start":[74,1]}},"moduleName":["Hydrogen","Composition","Cache","Operations"]},{"annotation":{"meta":null,"sourceSpan":{"end":[75,49],"start":[75,1]}},"moduleName":["Hydrogen","Composition","Cache","Query"]},{"annotation":{"meta":null,"sourceSpan":{"end":[76,49],"start":[76,1]}},"moduleName":["Hydrogen","Composition","Cache","Stats"]},{"annotation":{"meta":null,"sourceSpan":{"end":[71,49],"start":[71,1]}},"moduleName":["Hydrogen","Composition","Cache","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[78,49],"start":[55,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Composition","Cache"],"modulePath":"../../hydrogen/src/Hydrogen/Composition/Cache.purs","reExports":{"Hydrogen.Composition.Cache.Config":["defaultConfig","defaultTierConfig","tierConfigL0","tierConfigL1","tierConfigL2"],"Hydrogen.Composition.Cache.Debug":["compareByGeneration","entryScore","sameEntryContent","showCacheEntry"],"Hydrogen.Composition.Cache.Identified":["bumpEntryGeneration","cacheGetIdentified","cachePutIdentified","identifiedToCacheKey","initialEntryGeneration","makeCacheKeyPair"],"Hydrogen.Composition.Cache.LRU":["emptyLRU","lruAdd","lruOldest","lruRemove","lruSize","lruTouch"],"Hydrogen.Composition.Cache.Operations":["addToTagIndex","cacheEvictLRU","cacheGet","cacheInvalidate","cacheInvalidateByTag","cachePut","cacheStats","emptyCache","removeFromTagIndex","updateTierCount"],"Hydrogen.Composition.Cache.Query":["cacheContains","cacheGetByTier","cacheGetTop","cacheLength","cacheNeedsEviction","cachePruneExpired","cacheSize","cacheSizeBytes","filterEntries"],"Hydrogen.Composition.Cache.Stats":["evictionRate","hitRate","memoryUtilization","missRate","showCacheStats"],"Hydrogen.Composition.Cache.Types":["TagBrand","TagComposition","TagCustom","TagNode","TagTrigger","TierL0","TierL1","TierL2"]},"sourceSpan":{"end":[78,49],"start":[55,1]}}