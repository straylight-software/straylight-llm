ema","Dimension","Vector","Vec3"],"Vec3"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[262,46],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Triangle.purs","start":[262,1]},"title":"normalUnnormalized"},{"children":[],"comments":"Squared length of the normal (4 * area²)\nProof reference: Triangle.lean normalLengthSq\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Triangle"],"Triangle"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[267,37],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Triangle.purs","start":[267,1]},"title":"normalLengthSq"},{"children":[],"comments":"Area of the triangle: |AB × AC| / 2\nProof reference: Triangle.lean area, area_nonneg, unit_area, degenerate_area\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Triangle"],"Triangle"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[272,35],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Triangle.purs","start":[272,1]},"title":"areaTriangle"},{"children":[],"comments":"Check if triangle is degenerate (zero area)\nProof reference: Triangle.lean IsDegenerate\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Triangle"],"Triangle"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Boolean"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[277,36],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Triangle.purs","start":[277,1]},"title":"isDegenerate"},{"children":[],"comments":"Midpoint of edge AB\nProof reference: Triangle.lean midpointAB\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Triangle"],"Triangle"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Hydrogen","Schema","Dimension","Vector","Vec3"],"Vec3"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[286,38],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Triangle.purs","start":[286,1]},"title":"midpointAB"},{"children":[],"comments":"Midpoint of edge BC\nProof reference: Triangle.lean midpointBC\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Triangle"],"Triangle"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Hydrogen","Schema","Dimension","Vector","Vec3"],"Vec3"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[291,38],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Triangle.purs","start":[291,1]},"title":"midpointBC"},{"children":[],"comments":"Midpoint of edge CA\nProof reference: Triangle.lean midpointCA\n","info":{"de