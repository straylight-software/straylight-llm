ts":[["Prim"],"Number"],"tag":"TypeConstructor"},{"annotation":[],"contents":["b",{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"},{"annotation":[],"tag":"REmpty"}],"tag":"RCons"}],"tag":"RCons"}],"tag":"RCons"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[177,61],"name":"../../hydrogen/src/Hydrogen/Schema/Color/LAB.purs","start":[177,1]},"title":"toRecord"},{"children":[],"comments":"Lighten by percentage (perceptually accurate)\n\nIncrease LAB L* (luminance) by percentage - PERCEPTUALLY UNIFORM.\n\nUnlike HSL.increaseLightness, this produces consistent perceived brightness changes.\nAdding 10 to L* actually looks 10% lighter to the human eye.\n\n**Semantically explicit:** `increaseLuminance` makes clear this operates on L* (luminance),\nnot HSL lightness. Critical for billion-agent disambiguation.\n\n```purescript\nincreaseLuminance 10.0 color  -- Actually looks 10% lighter (perceptual)\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","LAB"],"LAB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","LAB"],"LAB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[201,42],"name":"../../hydrogen/src/Hydrogen/Schema/Color/LAB.purs","start":[201,1]},"title":"increaseLuminance"},{"children":[],"comments":"Decrease LAB L* (luminance) by percentage - PERCEPTUALLY UNIFORM.\n\nUnlike HSL.decreaseLightness, this produces consistent perceived brightness changes.\nSubtracting 10 from L* actually looks 10% darker to the human eye.\n\n```purescript\ndecreaseLuminance 10.0 color  -- Actually looks 10% darker (perceptual)\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","LAB"],"LAB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","LAB"],"LAB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[215,42],"name":"../../hydrogen/src/Hydrogen/Schema/Color/LAB.purs","start":[215,1]},"title":"decreaseLuminance"},{"children":[],"comments":"Calculate color difference (ΔE - Delta E)\n\nReturns perceptual distance between two colors:\n- 0: Identical colors\n- < 1: Imperceptible difference\n- 1-2: Just noticeable difference\n- 2-10: Perceptible at a glance\n- 11-49: Colors are more similar than opposite\n- 100: Maximum difference (black to white)\n\nUses CIE76 formula: ΔE = √[(L2-L1)² + (a2-a1)² + (b2-b1)²]\n\n```purescript\ndeltaE color1 color2  -- How different are these colors?\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","LAB"],"LAB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","LAB"],"LAB"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[238,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/LAB.purs","start":[238,1]},"title":"deltaE"}],"name":"Hydrogen.Schema.Color.LAB","reExports":[]}