{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                           // hydrogen // composition // bridge"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Composition Bridge — Connect Element.Core to the Composition system."},{"LineComment":" |"},{"LineComment":" | ## Purpose"},{"LineComment":" |"},{"LineComment":" | Element.Core provides pure data shapes (Rectangle, Ellipse, Path, Text)."},{"LineComment":" | The Composition system provides the rendering pipeline (Sources, Effects,"},{"LineComment":" | Blend modes, Mattes, Triggers)."},{"LineComment":" |"},{"LineComment":" | This bridge connects them:"},{"LineComment":" | - `elementToSource` wraps Element as a composition Source"},{"LineComment":" | - `elementToNode` creates a complete composition Node from Element"},{"LineComment":" | - `elementsToGroup` combines multiple Elements into a grouped Node"},{"LineComment":" |"},{"LineComment":" | ## Architecture"},{"LineComment":" |"},{"LineComment":" | ```"},{"LineComment":" | Element.Core (pure data)"},{"LineComment":" |       │"},{"LineComment":" |       ▼ elementToSource"},{"LineComment":" | Source.SourceElement"},{"LineComment":" |       │"},{"LineComment":" |       ▼ layer constructor"},{"LineComment":" | Node (composition tree)"},{"LineComment":" |       │"},{"LineComment":" |       ▼ renderer"},{"LineComment":" | GPU commands → pixels"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Element.Core as E"},{"LineComment":" | import Hydrogen.Composition.Bridge as Bridge"},{"LineComment":" |"},{"LineComment":" | myRect = E.rectangle { shape: ..., fill: ..., stroke: Nothing, opacity: ... }"},{"LineComment":" |"},{"LineComment":" | -- Create a composition node from an element"},{"LineComment":" | myNode = Bridge.elementToNode \"rect-1\" \"My Rectangle\" myRect"},{"LineComment":" |"},{"LineComment":" | -- Add effects, triggers, etc."},{"LineComment":" | myNodeWithEffects = myNode"},{"LineComment":" |   # Bridge.withBlur 5.0"},{"LineComment":" |   # Bridge.withTrigger onHoverTrigger"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Debug Utilities"},{"LineComment":" |"},{"LineComment":" | This module exports `showDebug` for consistent debugging across"},{"LineComment":" | the composition system."}],"decls":[{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"bindType":"NonRec","expression":{"abstraction":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[219,60],"start":[219,58]}},"type":"Var","value":{"identifier":"append","moduleName":["Data","Semigroup"]}},"annotation":{"meta":{"metaType":"IsSyntheticApp"},"sourceSpan":{"end":[219,97],"start":[219,32]}},"argument":{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"type":"Var","value":{"identifier":"semigroupString","moduleName":["Data","Semigroup"]}},"type":"App"},"identifier":"append"},{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"bindType":"NonRec","expression":{"abstraction":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[219,65],"start":[219,61]}},"type":"Var","value":{"identifier":"show","moduleName":["Data","Show"]}},"annotation":{"meta":{"metaType":"IsSyntheticApp"},"sourceSpan":{"end":[219,89],"start":[219,61]}},"argument":{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"type":"Var","value":{"identifier":"showInt","moduleName":["Data","Show"]}},"type":"App"},"identifier":"show"},{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"bindType":"NonRec","expression":{"abstraction":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[162,52],"start":[162,49]}},"type":"Var","value":{"identifier":"map","mo