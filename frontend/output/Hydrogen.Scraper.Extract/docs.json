position (assuming no skew for simplicity):\n  scaleX = sqrt(a² + b²)\n  scaleY = sqrt(c² + d²)  \n  rotation = atan2(b, a)\n  translateX = e\n  translateY = f\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Scraper","Capture"],"CapturedTransform"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Transform"],"Transform2D"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[764,78],"name":"../../hydrogen/src/Hydrogen/Scraper/Extract.purs","start":[764,1]},"title":"capturedTransformToSchema"},{"children":[],"comments":"Convert CapturedColor to OKLCHA Schema atom (with alpha)\n\nCapturedColor has { l, c, h, a } where:\n- l: Lightness (0.0-1.0)\n- c: Chroma (0.0-0.4 typical)\n- h: Hue as Number (degrees 0-360)\n- a: Alpha (0.0-1.0)\n\nOKLCHA expects h as Int and a as Number (0.0-1.0).\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Maybe"],"Maybe"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Scraper","Capture"],"CapturedColor"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Maybe"],"Maybe"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Alpha"],"OKLCHA"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[528,61],"name":"../../hydrogen/src/Hydrogen/Scraper/Extract.purs","start":[528,1]},"title":"capturedColorToOKLCHA"},{"children":[],"comments":"Convert CapturedColor to OKLCH Schema atom (opaque, drops alpha)\n\nFor cases where alpha is not needed. Uses oklch which expects\nhue as Int (0-359).\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Maybe"],"Maybe"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Scraper","Capture"],"CapturedColor"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Maybe"],"Maybe"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","OKLCH"],"OKLCH"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[539,59],"name":"../../hydrogen/src/Hydrogen/Scraper/Extract.purs","start":[539,1]},"title":"capturedColorToOKLCH"},{"children":[],"comments":"Convert Animation EasingFunction to Schema Easing\n\nMaps the Scraper's EasingFunction (extracted from CSS) to\nHydrogen Schema's unified Easing type.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Scraper","Animation"],"EasingFunction"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Temporal","Easing"],"Easing"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[851,64],"name":"../../hydrogen/src/Hydrogen/Scraper/Extract.purs","start":[851,1]},"title":"easingFunctionToSchema"},{"children":[],"comments":"Simple result of a scrape operation (legacy)\n","info":{"arguments":[],"declType":"typeSynonym","type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Record"],"tag":"TypeConstructor"},{"annotation":[],"contents":["url",{"annotation":[],"contents":[["Prim"],"String"],"tag":"TypeConstructor"},{"annotation":[],"contents":["title",{"annotation":[],"contents":[