ing         | Dimension  | Device.Pixel            | padding                 |"},{"LineComment":" | | maxWidth        | Dimension  | Device.Pixel            | max-width               |"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Element.Compound.ChatBubble as ChatBubble"},{"LineComment":" | import Hydrogen.Schema.Color as Color"},{"LineComment":" | import Hydrogen.Schema.Geometry as Geometry"},{"LineComment":" | import Hydrogen.Schema.Elevation.Shadow as Shadow"},{"LineComment":" |"},{"LineComment":" | -- Minimal usage"},{"LineComment":" | ChatBubble.chatBubble"},{"LineComment":" |   [ ChatBubble.message \"Hello, world!\""},{"LineComment":" |   , ChatBubble.direction ChatBubble.Sent"},{"LineComment":" |   ]"},{"LineComment":" |"},{"LineComment":" | -- With brand atoms"},{"LineComment":" | ChatBubble.chatBubble"},{"LineComment":" |   [ ChatBubble.message \"Hello!\""},{"LineComment":" |   , ChatBubble.direction ChatBubble.Sent"},{"LineComment":" |   , ChatBubble.backgroundColor brand.primary"},{"LineComment":" |   , ChatBubble.textColor brand.onPrimary"},{"LineComment":" |   , ChatBubble.borderRadius brand.bubbleRadius"},{"LineComment":" |   , ChatBubble.shadow brand.bubbleShadow"},{"LineComment":" |   , ChatBubble.glow brand.accentGlow"},{"LineComment":" |   ]"},{"LineComment":" |"},{"LineComment":" | -- With status and metadata"},{"LineComment":" | ChatBubble.chatBubble"},{"LineComment":" |   [ ChatBubble.message \"Did you see the update?\""},{"LineComment":" |   , ChatBubble.direction ChatBubble.Sent"},{"LineComment":" |   , ChatBubble.timestamp \"10:42 AM\""},{"LineComment":" |   , ChatBubble.status ChatBubble.Delivered"},{"LineComment":" |   ]"},{"LineComment":" |"},{"LineComment":" | -- Received message with avatar"},{"LineComment":" | ChatBubble.chatBubble"},{"LineComment":" |   [ ChatBubble.message \"I'm doing great, thanks!\""},{"LineComment":" |   , ChatBubble.direction ChatBubble.Received"},{"LineComment":" |   , ChatBubble.sender \"Alice\""},{"LineComment":" |   , ChatBubble.avatarUrl \"https://...\""},{"LineComment":" |   , ChatBubble.backgroundColor (Color.rgb 241 245 249)"},{"LineComment":" |   , ChatBubble.textColor (Color.rgb 15 23 42)"},{"LineComment":" |   ]"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" | - `ChatBubble.Types`: Direction, Status, Props, prop builders"},{"LineComment":" | - `ChatBubble.Render`: Internal rendering functions"},{"LineComment":" | - `ChatBubble.Companion`: chatContainer, typingIndicator, dateDivider"},{"LineComment":" | - `ChatBubble.Icons`: SVG status icons"}],"decls":[{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"bindType":"NonRec","expression":{"abstraction":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[176,32],"start":[176,30]}},"type":"Var","value":{"identifier":"eq","moduleName":["Data","Eq"]}},"annotation":{"meta":{"metaType":"IsSyntheticApp"},"sourceSpan":{"end":[176,43],"start":[176,14]}},"argument":{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"type":"Var","value":{"identifier":"eqDirection","moduleName":["Hydrogen","Element","Compound","ChatBubble","Types"]}},"type":"App"},"identifier":"eq"},{"annotation":{"meta":null,"sourceSpan":{"end":[172,76],"start":[172,1]}},"bindType":"NonRec","expression":{"annotation":{"meta":null,"sourceSpan":{"end":[172,76],"start":[172,1]}},"argument":"propMods","body":{"annotation":{"meta":null,"sourceSpan":{"end":[180,44],"start":[174,3]}},"binds":[{"annotation":{"meta":null,"sourceSpan":{"end":[175,60],"start":[175,5]}},"bindType":"NonRec","expression":{"abstraction":{"abstraction":{"abstraction":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[175,18],"start":[175,13]}},"type":"Var","value":{"identi