216,14],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[213,1]},"title":"LineCap"},{"children":[],"comments":"Convert line cap to CSS/SVG string\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"LineCap"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"String"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[227,34],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[227,1]},"title":"lineCapToCss"},{"children":[],"comments":"Parse line cap from string\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"String"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Maybe"],"Maybe"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"LineCap"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[234,45],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[234,1]},"title":"lineCapFromString"},{"children":[],"comments":"All line caps (for UI generation)\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Array"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"LineCap"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[242,29],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[242,1]},"title":"allLineCaps"},{"children":[{"comments":null,"info":{"arguments":[],"declType":"dataConstructor"},"sourceSpan":{"end":[260,14],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[260,3]},"title":"JoinMiter"},{"comments":null,"info":{"arguments":[],"declType":"dataConstructor"},"sourceSpan":{"end":[261,14],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[261,3]},"title":"JoinRound"},{"comments":null,"info":{"arguments":[],"declType":"dataConstructor"},"sourceSpan":{"end":[262,14],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[262,3]},"title":"JoinBevel"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Eq"],"Eq"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"LineJoin"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[264,42],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[264,1]},"title":"eqLineJoin"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Ord"],"Ord"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"LineJoin"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[265,44],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[265,1]},"title":"ordLineJoin"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Show"],"Show"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"LineJoin"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[270,38],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[267,1]},"title":"showLineJoin"}],"comments":"SVG/Canvas line corner connection style\n\nDefines how two line segments connect at a corner:\n\n- **miter**: Sharp corner extended to a point (default)\n- **round**: Rounded corner with radius = half stroke width\n- **bevel**: Flat corner cut at 45 degrees\n\nNote: Miter joins can become very long at acute angles. Use MiterLimit\nto control when miters convert to bevels.\n","info":{"dataDeclType":"data","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[262,14],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[259,1]},"title":"LineJoin"},{"children":[],"comments":"Convert line join to CSS/SVG string\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"LineJoin"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"String"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[273,36],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[273,1]},"title":"lineJoinToCss"},{"children":[],"comments":"Parse line join from string\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"String"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Maybe"],"Maybe"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"LineJoin"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[280,47],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[280,1]},"title":"lineJoinFromString"},{"children":[],"comments":"All line joins (for UI generation)\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Array"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"LineJoin"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[288,31],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[288,1]},"title":"allLineJoins"},{"children":[{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Eq"],"Eq"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"MiterLimit"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[313,46],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[313,1]},"title":"eqMiterLimit"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Ord"],"Ord"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"MiterLimit"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[314,48],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[314,1]},"title":"ordMiterLimit"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Show"],"Show"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"MiterLimit"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[317,56],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[316,1]},"title":"showMiterLimit"}],"comments":"Miter limit — controls when miter joins become bevel joins\n\nWhen two lines meet at a sharp angle, a miter join can extend very far.\nThe miter limit is the ratio of miter length to stroke width. When this\nratio is exceeded, the join converts to a bevel.\n\nBounds:\n- Minimum: 1.0 (always bevel, miter length = stroke width)\n- Maximum: 100.0 (allow very sharp miters)\n- Default: 4.0 (CSS/SVG default, bevel at ~29 degree angles)\n- Behavior: clamps\n\nMathematical note: miter limit = 1 / sin(angle/2)\n- Limit 1.0: bevel at all angles\n- Limit 4.0: bevel below ~29 degrees\n- Limit 10.0: bevel below ~11 degrees\n","info":{"dataDeclType":"newtype","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[311,39],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[311,1]},"title":"MiterLimit"},{"children":[],"comments":"Create a miter limit, clamping to valid range [1.0, 100.0]\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"MiterLimit"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[325,35],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[325,1]},"title":"miterLimit"},{"children":[],"comments":"Default miter limit (4.0, CSS/SVG default)\nConverts to bevel at angles below ~29 degrees\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"MiterLimit"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[333,32],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[333,1]},"title":"miterLimitDefault"},{"children":[],"comments":"Sharp miter limit (10.0)\nAllows miters down to ~11 degree angles\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"MiterLimit"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[338,30],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[338,1]},"title":"miterLimitSharp"},{"children":[],"comments":"Round-ish miter limit (2.0)\nConverts to bevel at angles below ~60 degrees\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"MiterLimit"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[343,30],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[343,1]},"title":"miterLimitRound"},{"children":[],"comments":"Extract the numeric value\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"MiterLimit"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[347,40],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[347,1]},"title":"miterLimitValue"},{"children":[],"comments":"Convert to CSS string (unitless number)\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Stroke"],"MiterLimit"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"String"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[351,40],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[351,1]},"title":"miterLimitToCss"},{"children":[],"comments":"Miter limit bounds documentation\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Bounded"],"NumberBounds"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[320,41],"name":"../../hydrogen/src/Hydrogen/Schema/Geometry/Stroke.purs","start":[320,1]},"title":"miterLimitBounds"}],"name":"Hydrogen.Schema.Geometry.Stroke","reExports":[]}