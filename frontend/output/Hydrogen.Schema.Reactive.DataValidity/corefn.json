{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                            // hydrogen // schema // reactive // data-validity"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | DataValidity — Graduated failure modes for safety-critical systems."},{"LineComment":" |"},{"LineComment":" | ## Purpose"},{"LineComment":" |"},{"LineComment":" | In safety-critical domains (avionics DO-178C DAL-A, medical FDA 21 CFR Part 11),"},{"LineComment":" | a simple boolean \"stale\" flag is insufficient. Systems must distinguish between:"},{"LineComment":" |"},{"LineComment":" | - Data that is current and trustworthy"},{"LineComment":" | - Data that is aging but still usable"},{"LineComment":" | - Data that is stale and requires visual indication"},{"LineComment":" | - Data that has failed and must be removed from display"},{"LineComment":" | - Data from redundant sources that disagree"},{"LineComment":" |"},{"LineComment":" | ## DO-178C Requirements"},{"LineComment":" |"},{"LineComment":" | Avionics displays must show:"},{"LineComment":" | - Fresh data (< 250ms): normal display"},{"LineComment":" | - Aging data (250ms - 2s): yellow cross-hatch overlay"},{"LineComment":" | - Stale data (2s - 10s): X through display element"},{"LineComment":" | - Invalid data (> 10s or sensor failure): remove from display entirely"},{"LineComment":" |"},{"LineComment":" | ## FDA Requirements"},{"LineComment":" |"},{"LineComment":" | Medical displays must:"},{"LineComment":" | - Track data provenance (which sensor, which timestamp)"},{"LineComment":" | - Show signal quality indicators"},{"LineComment":" | - Provide audible alarms for data failure"},{"LineComment":" | - Never display potentially misleading information without warning"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports all submodules:"},{"LineComment":" | - Types: Core types (DataValidity, FailureMode, DegradationReason)"},{"LineComment":" | - Display: Display response types and computation"},{"LineComment":" | - DataAge: Data age classification per DO-178C"},{"LineComment":" | - SignalQuality: Signal quality indicators for medical displays"},{"LineComment":" | - SensorSource: Sensor source tracking for redundancy"},{"LineComment":" | - Operations: Constructors, queries, comparisons, combining"},{"LineComment":" | - Arithmetic: Numeric operations for validity calculations"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[217,4],"start":[201,1]}},"moduleName":["Hydrogen","Schema","Reactive","DataValidity","Arithmetic"]},{"annotation":{"meta":null,"sourceSpan":{"end":[136,4],"start":[126,1]}},"moduleName":["Hydrogen","Schema","Reactive","DataValidity","DataAge"]},{"annotation":{"meta":null,"sourceSpan":{"end":[124,4],"start":[103,1]}},"moduleName":["Hydrogen","Schema","Reactive","DataValidity","Display"]},{"annotation":{"meta":null,"sourceSpan":{"end":[199,4],"start":[164,1]}},"moduleName":["Hydrogen","Schema","Reactive","DataValidity","Operations"]},{"annotation":{"meta":null,"sourceSpan":{"end":[162,4],"start":[150,1]}},"moduleName":["Hydrogen","Schema","Reactive","DataValidity","SensorSource"]},{"annotation":{"meta":null,"sourceSpan":{"end":[148,4],"start":[138,1]}},"moduleName":["Hydrogen","Schema","Reactive","DataValidity","SignalQuality"]},{"annotation":{"meta":null,"sourceSpan":{"end":[101,4],"start":[68,1]}},"moduleName":["Hydrogen","Schema","Reactive","DataValidity","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[217,4],"start":[45,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Reactive","DataValidity"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Reactive/DataValidity.purs","reExports":{"Hydrogen.Schema.Reactive.DataValidity.Arithmetic":["absNum","ageExceeds