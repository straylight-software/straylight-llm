{"comments":"The core Element type — pure data describing visual elements.\n\n## Purpose\n\nThis module defines the Element ADT itself, along with:\n- GroupSpec, TransformSpec (which reference Element, hence here)\n- Eq, Show, Semigroup, Monoid instances\n- Smart constructors\n\n## Architecture\n\nElement is pure data that flows:\n  Haskell backend → PureScript types → WebGPU execution\n\nThere is no browser in this stack. JavaScript is treated as legacy\nbytecode only at the export boundary for broken legacy formats.\n\n## Dependencies\n\n- Hydrogen.Element.Core.Stroke (StrokeSpec)\n- Hydrogen.Element.Core.Specs (shape and text specs)\n- Hydrogen.Element.Core.Media (media specs)\n- Hydrogen.Schema.Geometry.Transform (Transform2D)\n- Hydrogen.Schema.Color.Opacity (Opacity)\n","declarations":[{"children":[{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Hydrogen","Element","Core","Specs"],"RectangleSpec"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[179,14],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[179,3]},"title":"Rectangle"},{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Hydrogen","Element","Core","Specs"],"EllipseSpec"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[180,12],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[180,3]},"title":"Ellipse"},{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Hydrogen","Element","Core","Specs"],"PathSpec"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[181,9],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[181,3]},"title":"Path"},{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Hydrogen","Element","Core","Specs"],"TextSpec"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[182,9],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[182,3]},"title":"Text"},{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Hydrogen","Element","Core","Media"],"ImageSpec"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[183,10],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[183,3]},"title":"Image"},{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Hydrogen","Element","Core","Media"],"VideoSpec"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[184,10],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[184,3]},"title":"Video"},{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Hydrogen","Element","Core","Media"],"AudioSpec"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[185,10],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[185,3]},"title":"Audio"},{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Hydrogen","Element","Core","Media"],"Model3DSpec"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[186,12],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[186,3]},"title":"Model3D"},{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"GroupSpec"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[187,10],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[187,3]},"title":"Group"},{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"TransformSpec"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[188,14],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[188,3]},"title":"Transform"},{"comments":null,"info":{"arguments":[],"declType":"dataConstructor"},"sourceSpan":{"end":[189,10],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[189,3]},"title":"Empty"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Show"],"Show"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[206,33],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[195,1]},"title":"showElement"},{"comments":"Eq instance for Element.\n\nTwo Elements are equal if they have the same structure and all\ncorresponding atoms are equal. This is essential for:\n- Diffing (only re-render what changed)\n- Caching (memoization of rendered output)\n- Testing (assert expected Element equals actual)\n\nNote: Comparing large Element trees is O(n) in tree size.\nFor performance-critical code, consider structural hashing.\n","info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Eq"],"Eq"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[234,17],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[222,1]},"title":"eqElement"},{"comments":"Semigroup: combining two elements creates a group.\n","info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Semigroup"],"Semigroup"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[403,64],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[397,1]},"title":"semigroupElement"},{"comments":"Monoid: Empty is the identity element.\n","info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Monoid"],"Monoid"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[407,17],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[406,1]},"title":"monoidElement"}],"comments":"The core Element type — pure data describing visual elements.\n\nElement is a complete GPU instruction set as pure data. Every variant\nis composed entirely from Schema atoms. No strings. No CSS. No DOM.\nNo JavaScript. Serializable. Deterministic.\n\n## Variants\n\n**Primitives** (shapes with fill/stroke):\n- `Rectangle` — Axis-aligned rectangles with optional corner radius\n- `Ellipse` — Ellipses and circles\n- `Path` — Arbitrary vector paths (beziers, lines, arcs)\n- `Text` — Pre-laid-out text with positioned glyphs\n\n**Media**:\n- `Image` — Raster images (photos, icons)\n- `Video` — Moving pictures (video files, streams)\n- `Audio` — Sound sources with optional visualization\n- `Model3D` — 3D models rendered via WebGL\n\n**Composition**:\n- `Group` — Combine multiple elements\n- `Transform` — Apply 2D transform to an element\n\n**Identity**:\n- `Empty` — No-op element (identity for composition)\n\n## Determinism Guarantee\n\nSame Element value = same pixels. Always. This is guaranteed because\nevery field is a bounded Schema atom with deterministic behavior.\nTwo agents constructing the same Element get identical rendering.\n\n## Monoid Structure\n\nElement forms a Monoid where:\n- `mempty` = `Empty`\n- `<>` = grouping (creates a Group from two elements)\n\nThis allows: `element1 <> element2 <> element3` to compose naturally.\n","info":{"dataDeclType":"data","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[189,10],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[178,1]},"title":"Element"},{"children":[],"comments":"Specification for groups of elements.\n\nGroups compose multiple elements into a single unit.\nThe group itself can have opacity applied (affects all children).\n","info":{"arguments":[],"declType":"typeSynonym","type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Record"],"tag":"TypeConstructor"},{"annotation":[],"contents":["children",{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Array"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":["opacity",{"annotation":[],"contents":[["Hydrogen","Schema","Color","Opacity"],"Opacity"],"tag":"TypeConstructor"},{"annotation":[],"tag":"REmpty"}],"tag":"RCons"}],"tag":"RCons"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[122,4],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[119,1]},"title":"GroupSpec"},{"children":[],"comments":"Specification for transformed elements.\n\nWraps an Element with a 2D transform from Schema.Geometry.Transform.\nTransform2D includes: translate, rotate, scale, skew, origin\nAll transform values are bounded (scale: -10 to 10, skew: -89 to 89, etc).\n","info":{"arguments":[],"declType":"typeSynonym","type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Record"],"tag":"TypeConstructor"},{"annotation":[],"contents":["transform",{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Transform"],"Transform2D"],"tag":"TypeConstructor"},{"annotation":[],"contents":["child",{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"},{"annotation":[],"tag":"REmpty"}],"tag":"RCons"}],"tag":"RCons"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[132,4],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[129,1]},"title":"TransformSpec"},{"children":[],"comments":"Create a rectangle element.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Specs"],"RectangleSpec"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[414,38],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[414,1]},"title":"rectangle"},{"children":[],"comments":"Create an ellipse element.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Specs"],"EllipseSpec"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[418,34],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[418,1]},"title":"ellipse"},{"children":[],"comments":"Create a path element.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Specs"],"PathSpec"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[422,28],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[422,1]},"title":"path"},{"children":[],"comments":"Create a text element.\n\nText is rendered from a pre-laid-out TextBlock. Use the typography\nlayout functions to create the TextBlock, then wrap it here.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Specs"],"TextSpec"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[429,28],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[429,1]},"title":"text"},{"children":[],"comments":"Create an image element.\n\nImages render external raster content. The bounds define the\ndestination rectangle, and ObjectFit controls scaling behavior.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Media"],"ImageSpec"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[444,30],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[444,1]},"title":"image"},{"children":[],"comments":"Create a video element.\n\nVideos render moving picture content. Playback state is controlled\nvia the VideoPlayback record — the runtime interprets this to\ncontrol actual video elements.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Media"],"VideoSpec"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[452,30],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[452,1]},"title":"video"},{"children":[],"comments":"Create an audio element.\n\nAudio elements represent sound sources. When visualBounds is provided,\na waveform/spectrum visualization is rendered. Otherwise the audio\nis purely auditory with spatial positioning.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Media"],"AudioSpec"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[460,30],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[460,1]},"title":"audio"},{"children":[],"comments":"Create a 3D model element.\n\n3D models are rendered via WebGL into a texture, then composited\ninto the 2D canvas. Camera controls the viewport, and animations\nare controlled via animationProgress.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Media"],"Model3DSpec"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[468,34],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[468,1]},"title":"model3D"},{"children":[],"comments":"Create a group of elements.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Array"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[433,34],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[433,1]},"title":"group"},{"children":[],"comments":"Apply a transform to an element.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Geometry","Transform"],"Transform2D"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[437,47],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[437,1]},"title":"transform"},{"children":[],"comments":"The empty element (identity for composition).\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Element","Core","Element"],"Element"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[472,17],"name":"../../hydrogen/src/Hydrogen/Element/Core/Element.purs","start":[472,1]},"title":"empty"}],"name":"Hydrogen.Element.Core.Element","reExports":[]}