"sourceSpan":{"end":[106,4],"name":"../../hydrogen/src/Hydrogen/Optimize/Submodular/Types/Classification.purs","start":[103,43]},"title":"CurvatureWitness"}],"comments":"A witness that a function has specific curvature.\n\nThe witness encodes a proof (or certificate) that the function\nsatisfies the curvature bound. This enables the type system to\ntrack curvature through compositions.\n","info":{"dataDeclType":"newtype","declType":"data","roles":["Phantom"],"typeArguments":[["κ",{"annotation":[],"contents":[["Hydrogen","Optimize","Submodular","Types","Classification"],"Curvature"],"tag":"TypeConstructor"}]]},"kind":{"keyword":"newtype","kind":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Optimize","Submodular","Types","Classification"],"Curvature"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Type"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[106,4],"name":"../../hydrogen/src/Hydrogen/Optimize/Submodular/Types/Classification.purs","start":[103,1]},"title":"CurvatureWitness"}],"name":"Hydrogen.Optimize.Submodular.Types.Classification","reExports":[]}