{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                            // hydrogen // gpu // effect-event"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | EffectEvent — Triggers, Events, and State Snapshots for Effects"},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | Hyper-responsive UIs need predictable event handling:"},{"LineComment":" |"},{"LineComment":" | - **Triggers**: Conditions that start effects (hover, focus, scroll, time)"},{"LineComment":" | - **Events**: Discrete happenings during effect lifecycle"},{"LineComment":" | - **Snapshots**: Serializable state for undo/save/replay"},{"LineComment":" |"},{"LineComment":" | ## Why This Matters at Billion-Agent Scale"},{"LineComment":" |"},{"LineComment":" | With billions of agents, effects must be:"},{"LineComment":" | 1. **Deterministic**: Same trigger → same effect (always)"},{"LineComment":" | 2. **Serializable**: State can be saved, replayed, debugged"},{"LineComment":" | 3. **Composable**: Triggers combine with boolean algebra"},{"LineComment":" | 4. **UUID5 identified**: Same effect config → same identity"},{"LineComment":" |"},{"LineComment":" | ## Architecture"},{"LineComment":" |"},{"LineComment":" | ```"},{"LineComment":" | Trigger → EffectEvent → StateTransition → Snapshot"},{"LineComment":" |    ↓          ↓              ↓              ↓"},{"LineComment":" |  Input     Emitted       Applied        Saved/Undo"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | All pure data. No callbacks. No side effects."},{"LineComment":" | The runtime interprets these at 60/120fps."},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module re-exporting from:"},{"LineComment":" | - `Hydrogen.GPU.EffectEvent.Trigger` — Trigger types"},{"LineComment":" | - `Hydrogen.GPU.EffectEvent.Event` — Event types"},{"LineComment":" | - `Hydrogen.GPU.EffectEvent.Snapshot` — Snapshot types"},{"LineComment":" | - `Hydrogen.GPU.EffectEvent.Transition` — State transition types"},{"LineComment":" | - `Hydrogen.GPU.EffectEvent.Evaluate` — Trigger evaluation functions"},{"LineComment":" | - `Hydrogen.GPU.EffectEvent.Operations` — Snapshot and event operations"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[152,16],"start":[141,1]}},"moduleName":["Hydrogen","GPU","EffectEvent","Evaluate"]},{"annotation":{"meta":null,"sourceSpan":{"end":[119,13],"start":[95,1]}},"moduleName":["Hydrogen","GPU","EffectEvent","Event"]},{"annotation":{"meta":null,"sourceSpan":{"end":[172,18],"start":[154,1]}},"moduleName":["Hydrogen","GPU","EffectEvent","Operations"]},{"annotation":{"meta":null,"sourceSpan":{"end":[128,16],"start":[121,1]}},"moduleName":["Hydrogen","GPU","EffectEvent","Snapshot"]},{"annotation":{"meta":null,"sourceSpan":{"end":[139,18],"start":[130,1]}},"moduleName":["Hydrogen","GPU","EffectEvent","Transition"]},{"annotation":{"meta":null,"sourceSpan":{"end":[93,15],"start":[57,1]}},"moduleName":["Hydrogen","GPU","EffectEvent","Trigger"]},{"annotation":{"meta":null,"sourceSpan":{"end":[172,18],"start":[44,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","GPU","EffectEvent"],"modulePath":"../../hydrogen/src/Hydrogen/GPU/EffectEvent.purs","reExports":{"Hydrogen.GPU.EffectEvent.Evaluate":["evaluateTimeTrigger","evaluateTrigger","evaluateTriggerWithTime","isConditionMet","isConditionNotMet","triggerAll","triggerAnd","triggerAny","triggerNot","triggerOr"],"Hydrogen.GPU.EffectEvent.Event":["Backward","Forward","AnimationDirectionChange","AnimationKeyframe","AnimationLoop","AnimationTick","EventAnimation","EventInteraction","EventLifecycle","EffectCancelled","EffectCompleted","EffectPaused","EffectResumed","EffectStarted","Effect