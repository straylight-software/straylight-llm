{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                       // hydrogen // schema // physical"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Physical pillar — real-world material properties for accurate simulation."},{"LineComment":" |"},{"LineComment":" | ## Overview"},{"LineComment":" |"},{"LineComment":" | The Physical pillar provides scientifically accurate material properties"},{"LineComment":" | for rendering, haptics, physics simulation, and sensor feedback. Every"},{"LineComment":" | value is bounded and sourced from peer-reviewed data."},{"LineComment":" |"},{"LineComment":" | ## Submodules"},{"LineComment":" |"},{"LineComment":" | ### Element"},{"LineComment":" | Periodic table elements with complete atomic data."},{"LineComment":" |"},{"LineComment":" | ### Optical"},{"LineComment":" | Light interaction properties:"},{"LineComment":" | - IOR: Index of Refraction for ~100 materials"},{"LineComment":" | - Dispersion: Abbe number and gemstone \"fire\""},{"LineComment":" |"},{"LineComment":" | ### Mechanical"},{"LineComment":" | Physical structure properties:"},{"LineComment":" | - Hardness: Mohs scale (1-15, extended for synthetics)"},{"LineComment":" | - Density: kg/m³ database (~100 materials)"},{"LineComment":" |"},{"LineComment":" | ### Thermal"},{"LineComment":" | Heat transfer properties:"},{"LineComment":" | - Conductivity: W/(m·K) for ~80 materials"},{"LineComment":" |"},{"LineComment":" | ### Haptic"},{"LineComment":" | Touch feedback primitives:"},{"LineComment":" | - Force: Newton-based haptic effects"},{"LineComment":" | - Vibration, texture, impact, resistance presets"},{"LineComment":" |"},{"LineComment":" | ### Material"},{"LineComment":" | Complete material definitions:"},{"LineComment":" | - StandardSurface: MaterialX-compatible PBR shader"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Schema.Physical as Physical"},{"LineComment":" | import Hydrogen.Schema.Physical.Optical.IOR as IOR"},{"LineComment":" | import Hydrogen.Schema.Physical.Mechanical.Density as Density"},{"LineComment":" | "},{"LineComment":" | -- Create a gold material description"},{"LineComment":" | goldProperties ="},{"LineComment":" |   { ior: IOR.gold"},{"LineComment":" |   , density: Density.gold"},{"LineComment":" |   , hardness: Hardness.gold"},{"LineComment":" |   , thermalK: Conductivity.gold"},{"LineComment":" |   }"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## At Billion-Agent Scale"},{"LineComment":" |"},{"LineComment":" | Agents creating virtual materials compose from these atoms. Same properties"},{"LineComment":" | = same physical behavior across all simulations. No ambiguity about what"},{"LineComment":" | \"gold\" means — it's the same density, hardness, and thermal conductivity"},{"LineComment":" | everywhere."}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[85,15],"start":[76,1]}},"moduleName":["Hydrogen","Schema","Physical","Element"]},{"annotation":{"meta":null,"sourceSpan":{"end":[91,13],"start":[87,1]}},"moduleName":["Hydrogen","Schema","Physical","Element","Block"]},{"annotation":{"meta":null,"sourceSpan":{"end":[113,16],"start":[109,1]}},"moduleName":["Hydrogen","Schema","Physical","Element","Category"]},{"annotation":{"meta":null,"sourceSpan":{"end":[107,13],"start":[101,1]}},"moduleName":["Hydrogen","Schema","Physical","Element","Group"]},{"annotation":{"meta":null,"sourceSpan":{"end":[99,14],"start":[93,1]}},"moduleName":["Hydrogen","Schema","Physical","Element","Period"]},{"annotation":{"meta":null,"sourceSpan":{"end":[119,14],"start":[115,1]}},"moduleName":["Hydrogen","Schema","Physical","Element","Symbol"]},{"annotation":{"meta":null,"sourceSpan