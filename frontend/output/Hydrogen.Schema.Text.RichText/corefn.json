{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                       // hydrogen // schema // text // richtext"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | RichText — Pure document model for rich text editing."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | Rich text documents are hierarchical data structures, NOT HTML strings."},{"LineComment":" | This module provides a complete, typed model for rich text that can be:"},{"LineComment":" | - Rendered to any target (DOM, static HTML, canvas, terminal)"},{"LineComment":" | - Serialized/deserialized without information loss"},{"LineComment":" | - Transformed algebraically (fold, map, filter)"},{"LineComment":" | - Validated at compile time for structural correctness"},{"LineComment":" |"},{"LineComment":" | ## Architecture"},{"LineComment":" |"},{"LineComment":" | Documents contain Blocks (paragraph-level elements)."},{"LineComment":" | Blocks contain Inlines (character-level formatting)."},{"LineComment":" | This two-level hierarchy matches most rich text editors (ProseMirror, Slate)."},{"LineComment":" |"},{"LineComment":" | ```"},{"LineComment":" | RichTextDocument"},{"LineComment":" |   └── Block (Paragraph, Heading, CodeBlock, etc.)"},{"LineComment":" |         └── Inline (TextNode, Bold, Italic, Link, etc.)"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Why Not HTML?"},{"LineComment":" |"},{"LineComment":" | HTML strings are unbounded and ambiguous. Two different HTML strings can"},{"LineComment":" | represent the same visual output. Our model is canonical: same content ="},{"LineComment":" | same representation. This enables deterministic diffing and collaboration."},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" | - Types: Core type definitions (URL, Language, Inline, Block, etc.)"},{"LineComment":" | - Inline: Inline constructors and operations"},{"LineComment":" | - Block: Block constructors and operations"},{"LineComment":" | - Document: Document operations and serialization"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[98,13],"start":[86,1]}},"moduleName":["Hydrogen","Schema","Text","RichText","Block"]},{"annotation":{"meta":null,"sourceSpan":{"end":[112,16],"start":[100,1]}},"moduleName":["Hydrogen","Schema","Text","RichText","Document"]},{"annotation":{"meta":null,"sourceSpan":{"end":[84,14],"start":[70,1]}},"moduleName":["Hydrogen","Schema","Text","RichText","Inline"]},{"annotation":{"meta":null,"sourceSpan":{"end":[68,13],"start":[53,1]}},"moduleName":["Hydrogen","Schema","Text","RichText","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[112,16],"start":[42,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Text","RichText"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Text/RichText.purs","reExports":{"Hydrogen.Schema.Text.RichText.Block":["appendInline","blockIsEmpty","blockQuote","blockToInlines","bulletList","codeBlock","heading","horizontalRule","numberedList","paragraph","prependInline"],"Hydrogen.Schema.Text.RichText.Document":["appendBlock","blockToPlainText","documentBlockCount","documentToPlainText","filterBlocks","getBlockAt","inlineToPlainText","insertBlockAt","mapBlocks","prependBlock","removeBlockAt"],"Hydrogen.Schema.Text.RichText.Inline":["bold","code","flattenInlines","flattenInlinesToText","inlineLength","inlineText","italic","link","strikethrough","subscript","superscript","textNode","underline"],"Hydrogen.Schema.Text.RichText.Types":["BlockQuote","CodeBlock","Heading","HorizontalRule","List","Paragraph","H1","H2","H3","H4","H5","H6","Bold","Code","Italic","Link","Strikethro