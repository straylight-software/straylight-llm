ypeApp"}},"kind":null,"sourceSpan":{"end":[177,31],"name":"../../hydrogen/src/Hydrogen/Schema/Color/HSL.purs","start":[177,1]},"title":"rotateHue"},{"children":[],"comments":"Get the complementary color (opposite on color wheel).\n\n```purescript\ncomplement (hsl 0 100 50)   -- Red → Cyan (180°)\ncomplement (hsl 60 100 50)  -- Yellow → Blue (240°)\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","HSL"],"HSL"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","HSL"],"HSL"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[190,25],"name":"../../hydrogen/src/Hydrogen/Schema/Color/HSL.purs","start":[190,1]},"title":"complement"},{"children":[],"comments":"Increase HSL lightness by percentage points.\n\n**WARNING:** HSL lightness is NOT perceptually uniform. For accurate \"looks 10% lighter\"\noperations, convert to LAB via Conversion module and use `LAB.increaseLuminance`.\n\n```purescript\nincreaseLightness 20 (hsl 0 100 50)  -- L: 50 → 70 (HSL space, not perceptual)\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Int"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","HSL"],"HSL"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","HSL"],"HSL"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[201,39],"name":"../../hydrogen/src/Hydrogen/Schema/Color/HSL.purs","start":[201,1]},"title":"increaseLightness"},{"children":[],"comments":"Decrease HSL lightness by percentage points.\n\n**WARNING:** HSL lightness is NOT perceptually uniform. For accurate \"looks 10% darker\"\noperations, convert to LAB via Conversion module and use `LAB.decreaseLuminance`.\n\n```purescript\ndecreaseLightness 20 (hsl 0 100 50)  -- L: 50 → 30 (HSL space, not perceptual)\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Int"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","HSL"],"HSL"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","HSL"],"HSL"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[216,39],"name":"../../hydrogen/src/Hydrogen/Schema/Color/HSL.purs","start":[216,1]},"title":"decreaseLightness"},{"children":[],"comments":"Increase HSL saturation by percentage points.\n\n**NOTE:** HSL saturation differs from LCH chroma. For perceptually uniform saturation\nadjustments, use LCH.increaseChroma.\n\n```purescript\nincreaseSaturation 20 (hsl 0 50 50)  -- S: 50 → 70\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Int"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","HSL"],"HSL"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","C