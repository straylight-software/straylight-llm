{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                        // hydrogen // schema // motion // animated-transform"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | AnimatedTransform — Complete Motion Graphics Transform Model."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | This module provides the COMPLETE transform model for motion graphics,"},{"LineComment":" | matching motion graphics capabilities:"},{"LineComment":" |"},{"LineComment":" | - **Position** (X, Y, Z) — Object location, animatable along spline paths"},{"LineComment":" | - **Rotation** (Z for 2D, X/Y/Z for 3D) — Object orientation with wrap"},{"LineComment":" | - **Scale** (X, Y, Z) — Size as percentage, with flip via negative"},{"LineComment":" | - **Anchor Point** — Transform origin relative to object bounds"},{"LineComment":" | - **Opacity** — Visibility (0-100%)"},{"LineComment":" |"},{"LineComment":" | All properties are **animatable** with:"},{"LineComment":" | - Keyframes at specific frame positions"},{"LineComment":" | - Bezier tangent handles for easing"},{"LineComment":" | - Spatial tangents for motion path curves (position only)"},{"LineComment":" | - Speed graph control for temporal manipulation"},{"LineComment":" | - Expressions for procedural animation"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is the leader module that re-exports from submodules:"},{"LineComment":" |"},{"LineComment":" | - **Core** — PropertyKeyframe, AnimatableValue, SpeedGraph, MotionPathMode"},{"LineComment":" | - **Properties** — AnimatedPosition, Scale, Rotation, Anchor, Opacity"},{"LineComment":" | - **Transform** — AnimatedTransform2D, AnimatedTransform3D"},{"LineComment":" | - **Evaluation** — evaluateAt, evaluateTransform2DAt, evaluateTransform3DAt"},{"LineComment":" | - **Keyframe** — addKeyframe, removeKeyframe, moveKeyframe, etc."},{"LineComment":" | - **Layer** — LayerDimensionality, RotationOrder, Parenting, NullObject"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Schema.Motion.AnimatedTransform as AT"},{"LineComment":" |"},{"LineComment":" | -- Create default transform"},{"LineComment":" | transform = AT.defaultAnimatedTransform2D"},{"LineComment":" |"},{"LineComment":" | -- Add keyframe to position X"},{"LineComment":" | withKeyframe = AT.addPositionXKeyframe (frames 0.0) 100.0 transform"},{"LineComment":" |"},{"LineComment":" | -- Evaluate at frame 30"},{"LineComment":" | posX = AT.evaluatePositionX (frames 30.0) withKeyframe"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Dependencies"},{"LineComment":" |"},{"LineComment":" | - Schema.Motion.Keyframe (Keyframe, KeyframeValue)"},{"LineComment":" | - Schema.Motion.Easing (Easing, evaluate)"},{"LineComment":" | - Schema.Motion.Interpolation (FullInterpolationType, BezierHandle)"},{"LineComment":" | - Schema.Motion.Transform (Position2D, Position3D, Scale2D, etc.)"},{"LineComment":" | - Schema.Dimension.Temporal (Frames)"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[111,12],"start":[83,1]}},"moduleName":["Hydrogen","Schema","Motion","AnimatedTransform","Core"]},{"annotation":{"meta":null,"sourceSpan":{"end":[156,18],"start":[150,1]}},"moduleName":["Hydrogen","Schema","Motion","AnimatedTransform","Evaluation"]},{"annotation":{"meta":null,"sourceSpan":{"end":[164,16],"start":[158,1]}},"moduleName":["Hydrogen","Schema","Motion","AnimatedTransform","Keyframe"]},{"annotation":{"meta":null,"sourceSpan":{"end":[201,13],"start":[166,1]}},"moduleName":["Hydrogen","Schema","Motion","AnimatedTransform","Layer"]},{"annotation":{"meta":null,"sourceSpan":{"end":[1