{"comments":"Elo rating system calculations.\n\nImplements the standard Elo rating formulas for competitive games:\n- Expected score calculation\n- Rating updates after games\n- K-factor determination by rating level\n\nAll calculations use bounded domains to ensure deterministic behavior.\nThe formulas follow standard statistical game theory.\n","declarations":[{"children":[],"comments":"Determine K-factor based on rating level.\n\nFIDE-style rules:\n- Under 2100: K=40\n- 2100-2400: K=20\n- Above 2400: K=10\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Score","Types"],"EloRating"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Score","Types"],"KFactor"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[64,40],"name":"../../hydrogen/src/Hydrogen/Schema/Game/Score/Elo.purs","start":[64,1]},"title":"kFactorByRating"},{"children":[],"comments":"Calculate expected score using Elo formula.\n\nE_A = 1 / (1 + 10^((R_B - R_A) / 400))\n\nReturns a probability between 0 and 1.\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Score","Types"],"EloRating"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Game","Score","Types"],"EloRating"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[82,50],"name":"../../hydrogen/src/Hydrogen/Schema