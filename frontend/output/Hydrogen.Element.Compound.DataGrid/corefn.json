{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                              // hydrogen // element // component // data-grid"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | DataGrid — Schema-native full-featured data grid component."},{"LineComment":" |"},{"LineComment":" | A powerful, accessible data grid with sorting, filtering, pagination,"},{"LineComment":" | row selection, row expansion, and more. All visual styling is controlled"},{"LineComment":" | by Schema atoms from the 12 pillars — no hardcoded CSS values."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | This component accepts **concrete Schema atoms**, not semantic tokens."},{"LineComment":" | Every visual property maps directly to atoms from Color, Geometry,"},{"LineComment":" | Dimension, and Typography pillars. When an atom is `Nothing`, no style"},{"LineComment":" | is emitted — the element inherits from its parent or browser defaults."},{"LineComment":" |"},{"LineComment":" | ## Features"},{"LineComment":" |"},{"LineComment":" | - Column definitions with sorting, filtering, resizing"},{"LineComment":" | - Fixed columns (left/right sticky)"},{"LineComment":" | - Multi-column sorting (shift+click)"},{"LineComment":" | - Per-column and global filtering"},{"LineComment":" | - Row selection (single, multiple, checkbox)"},{"LineComment":" | - Row expansion with detail views"},{"LineComment":" | - Built-in and external pagination"},{"LineComment":" | - Custom cell renderers"},{"LineComment":" | - Keyboard navigation"},{"LineComment":" | - ARIA grid pattern for accessibility"},{"LineComment":" | - Export to CSV"},{"LineComment":" |"},{"LineComment":" | ## Schema Atoms Accepted"},{"LineComment":" |"},{"LineComment":" | | Property              | Pillar     | Type                 |"},{"LineComment":" | |-----------------------|------------|----------------------|"},{"LineComment":" | | headerBgColor         | Color      | Color.RGB            |"},{"LineComment":" | | headerTextColor       | Color      | Color.RGB            |"},{"LineComment":" | | rowBgColor            | Color      | Color.RGB            |"},{"LineComment":" | | rowAltBgColor         | Color      | Color.RGB            |"},{"LineComment":" | | rowHoverBgColor       | Color      | Color.RGB            |"},{"LineComment":" | | rowSelectedBgColor    | Color      | Color.RGB            |"},{"LineComment":" | | cellTextColor         | Color      | Color.RGB            |"},{"LineComment":" | | borderColor           | Color      | Color.RGB            |"},{"LineComment":" | | containerBorderRadius | Geometry   | Geometry.Corners     |"},{"LineComment":" | | cellPaddingX          | Dimension  | Device.Pixel         |"},{"LineComment":" | | cellPaddingY          | Dimension  | Device.Pixel         |"},{"LineComment":" | | fontSize              | Typography | FontSize.FontSize    |"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Element.Compound.DataGrid as Grid"},{"LineComment":" | import Hydrogen.Element.Compound.DataGrid.Column as Col"},{"LineComment":" | import Hydrogen.Element.Compound.DataGrid.Types (CellType(..))"},{"LineComment":" |"},{"LineComment":" | -- Define columns"},{"LineComment":" | columns ="},{"LineComment":" |   [ Col.column \"id\" \"ID\" [ Col.colWidth 80, Col.sortable ]"},{"LineComment":" |   , Col.column \"name\" \"Name\" [ Col.sortable, Col.filterable ]"},{"LineComment":" |   , Col.column \"status\" \"Status\" [ Col.cellType CellBadge ]"},{"LineComment":" |   , Col.column \"actions\" \"\" [ Col.cellType CellActions, Col.colWidth 100 ]"},{"LineComment":" |   ]"},{"LineComment":" |"},{"LineComment":" | -- Render grid with brand atoms"},{"LineComment":" | Grid.dataGrid"},{"LineComment":" |   [ Grid.columns columns"},{"LineComment":" |   , Grid.rows myData"},{"LineComment":" |   , Grid.headerBgColor brand.muted"},{"LineComment":" |   , Grid.headerTextColor brand.foreground"},{"LineComment":" |   , Grid.borderColor brand.border"},{"LineComment":" |   , Grid.onRowSelect HandleSelect"},{"LineComment":" |   , Grid.pagination (Grid.BuiltIn { pageSize: 25 })"},{"LineComment":" |   ]"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | The DataGrid is split across multiple submodules:"},{"LineComment":" |"},{"LineComment":" | - `DataGrid` (this module) — Main component and re-exports"},{"LineComment":" | - `DataGrid.Types` — Type definitions"},{"LineComment":" | - `DataGrid.Column` — Column definition builders"},{"LineComment":" | - `DataGrid.Props` — Grid prop builders"},{"LineComment":" | - `DataGrid.Render` — Internal rendering functions"},{"LineComment":" | - `DataGrid.Cell` — Cell rendering"},{"LineComment":" | - `DataGrid.Processing` — Data processing (sort, filter, paginate)"}],"decls":[{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"bindType":"NonRec","expression":{"abstraction":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[228,41],"start":[228,38]}},"type":"Var","value":{"identifier":"not","moduleName":["Data","HeytingAlgebra"]}},"annotation":{"meta":{"metaType":"IsSyntheticApp"},"sourceSpan":{"end":[228,52],"start":[228,38]}},"argument":{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"type":"Var","value":{"identifier":"heytingAlgebraBoolean","moduleName":["Data","HeytingAlgebra"]}},"type":"App"},"identifier":"not"},{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"bindType":"NonRec","expression":{"abstraction":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[239,11],"start":[239,9]}},"type":"Var","value":{"identifier":"append","moduleName":["Data","Semigrou