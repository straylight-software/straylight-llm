om submodules:"},{"LineComment":" | - Selection.Types: Core type definitions"},{"LineComment":" | - Selection.HitTest: Hit testing operations"},{"LineComment":" | - Selection.Lasso: Lasso path operations"},{"LineComment":" | - Selection.Handle: Handle and frame operations"},{"LineComment":" | - Selection.Marquee: Marquee state management"},{"LineComment":" | - Selection.Operations: High-level selection operations"},{"LineComment":" | - Selection.Drag: Handle drag operations"},{"LineComment":" | - Selection.Internal: Internal helpers (not re-exported)"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[141,12],"start":[136,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Selection","Drag"]},{"annotation":{"meta":null,"sourceSpan":{"end":[116,14],"start":[106,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Selection","Handle"]},{"annotation":{"meta":null,"sourceSpan":{"end":[92,15],"start":[86,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Selection","HitTest"]},{"annotation":{"meta":null,"sourceSpan":{"end":[146,16],"start":[144,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Selection","Internal"]},{"annotation":{"meta":null,"sourceSpan":{"end":[103,13],"start":[95,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Selection","Lasso"]},{"annotation":{"meta":null,"sourceSpan":{"end":[125,15],"start":[119,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Selection","Marquee"]},{"annotation":{"meta":null,"sourceSpan":{"end":[133,18],"start":[128,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Selection","Operations"]},{"annotation":{"meta":null,"sourceSpan":{"end":[83,13],"start":[64,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Selection","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[146,16],"start":[48,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Element","Compound","Canvas","Selection"],"modulePath"