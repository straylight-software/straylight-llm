 and activations both INT8"},{"LineComment":" | - W4A16: Weights INT4, activations FP16"},{"LineComment":" | - W4A8_NVFP4_FP8: Weights NVFP4, activations FP8"},{"LineComment":" | - W4A8_MXFP4_FP8: Weights MXFP4, activations FP8"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from:"},{"LineComment":" | - `DType.Types`: Core type definitions and constructors"},{"LineComment":" | - `DType.QuantMode`: Quantization mode specifications"},{"LineComment":" | - `DType.Properties`: Type property queries"},{"LineComment":" | - `DType.Operations`: Comparison and transformation"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[63,61],"start":[63,1]}},"moduleName":["Hydrogen","Schema","Tensor","DType","Operations"]},{"annotation":{"meta":null,"sourceSpan":{"end":[62,61],"start":[62,1]}},"moduleName":["Hydrogen","Schema","Tensor","DType","Properties"]},{"annotation":{"meta":null,"sourceSpan":{"end":[61,59],"start":[61,1]}},"moduleName":["Hydrogen","Schema","Tensor","DType","QuantMode"]},{"annotation":{"meta":null,"sourceSpan":{"end":[60,51],"start":[60,1]}},"moduleName":["Hydrogen","Schema","Tensor","DType","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[63,61],"start":[49,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Tensor","DType"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Tensor/DType.purs","reExports":{"Hydrogen.Schema.Tensor.DType.Operations":["canCastTo","commonType","describeType","higherPrecision","isCompatiblePair","lowerPrecision","mapBaseType","promoteTo"],"Hydrogen.Schema.Tensor.DType.Properties":["bitWidth","bitWidths","byteWidth","bytesForElements","elementsPerByte","exponentBits","hasInfNaN","isFloatingPoint","isInteger","isNumeric","isQuantized","isSigned","mantissaBits"],"Hydrogen.Schema.Tensor.DType.QuantMode":["FP8_Full","FP8_Linear","NoQuant","W4A16","W4A16_AWQ","W4A16_GPTQ","W4A8_MX