{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                    // hydrogen // schema // brand // compound"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Brand Compound System — Token compositions for UI components."},{"LineComment":" |"},{"LineComment":" | ## Architecture"},{"LineComment":" |"},{"LineComment":" | Brand Compounds bridge the gap between:"},{"LineComment":" | - **Tokens**: Named values (color.primary.500, spacing.md, radius.lg)"},{"LineComment":" | - **Element Compounds**: Rendering components that accept Schema atoms"},{"LineComment":" |"},{"LineComment":" | A Brand Compound defines \"this component uses these tokens\":"},{"LineComment":" |"},{"LineComment":" | ```"},{"LineComment":" | ButtonCompound = {"},{"LineComment":" |   background: \"color.primary.500\""},{"LineComment":" |   text: \"color.on-primary\""},{"LineComment":" |   radius: \"radius.md\""},{"LineComment":" |   paddingX: \"spacing.4\""},{"LineComment":" |   ..."},{"LineComment":" | }"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Complete Component Coverage"},{"LineComment":" |"},{"LineComment":" | This module provides compounds for EVERY UI component:"},{"LineComment":" |"},{"LineComment":" | **Interactive:**"},{"LineComment":" | - Button, IconButton, Link, Toggle, Switch"},{"LineComment":" | - Checkbox, Radio, Select, Slider"},{"LineComment":" |"},{"LineComment":" | **Containers:**"},{"LineComment":" | - Card, Alert, Modal, Dialog, Sheet"},{"LineComment":" | - Accordion, Collapsible, Tabs"},{"LineComment":" |"},{"LineComment":" | **Data Display:**"},{"LineComment":" | - Badge, Avatar, Tag, Chip"},{"LineComment":" | - Table, DataGrid, List"},{"LineComment":" | - Tooltip, Popover"},{"LineComment":" |"},{"LineComment":" | **Form:**"},{"LineComment":" | - Input, Textarea, SearchInput"},{"LineComment":" | - DatePicker, TimePicker, ColorPicker"},{"LineComment":" | - NumberInput, PhoneInput, OTPInput"},{"LineComment":" |"},{"LineComment":" | **Feedback:**"},{"LineComment":" | - Toast, Alert, Progress, Skeleton"},{"LineComment":" | - Spinner, LoadingBar"},{"LineComment":" |"},{"LineComment":" | **Navigation:**"},{"LineComment":" | - Breadcrumb, Tabs, Menu, Sidebar"},{"LineComment":" | - Pagination, Stepper"},{"LineComment":" |"},{"LineComment":" | ## At Billion-Agent Scale"},{"LineComment":" |"},{"LineComment":" | When Agent A composes a form with buttons, inputs, and cards, they reference"},{"LineComment":" | compound styles by semantic name. Agent B rendering the same form gets"},{"LineComment":" | identical visual output because both resolve through the same compound"},{"LineComment":" | definitions."},{"LineComment":" |"},{"LineComment":" | Compounds are pure data. No side effects. No ambiguity. Same compounds,"},{"LineComment":" | same output — guaranteed."}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[70,44],"start":[70,1]}},"moduleName":["Hydrogen","Schema","Brand","Compound","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[70,44],"start":[65,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Brand","Compound"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Brand/Compound.purs","reExports":{"Hydrogen.Schema.Brand.Compound.Types":["Size2XL","SizeLG","SizeMD","SizeSM","SizeXL","SizeXS","VariantDestructive","VariantGhost","VariantInfo","VariantLink","VariantOutline","VariantPrimary","VariantSecondary","VariantSuccess","VariantTertiary","VariantWarning","CategoryContainer","CategoryDataDisplay","CategoryFeedback","CategoryForm","CategoryInteractive","CategoryLayout","CategoryNavigation","CategoryOverlay","PropBackground","PropBackgroundActive","PropBackgroundDisabled","PropBackgroundHover","PropBorder","PropBorderFocus","PropBorderHover","PropBorderRadius","PropBor