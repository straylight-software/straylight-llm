{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                            // hydrogen // schema // elevation"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Elevation pillar — depth, shadow, and visual hierarchy."},{"LineComment":" |"},{"LineComment":" | ## Physical Model"},{"LineComment":" |"},{"LineComment":" | Elevation simulates the z-axis in a 2D interface. Higher elevation means:"},{"LineComment":" |"},{"LineComment":" | - **Closer to light source** → More prominent shadow"},{"LineComment":" | - **Above other elements** → Higher z-index"},{"LineComment":" | - **More visual emphasis** → Draws user attention"},{"LineComment":" |"},{"LineComment":" | ## Atoms"},{"LineComment":" |"},{"LineComment":" | This pillar provides concrete, typed atoms:"},{"LineComment":" |"},{"LineComment":" | - **Shadow**: Box shadow parameters (offset, blur, spread, color)"},{"LineComment":" | - **ZIndex**: Stacking order integers"},{"LineComment":" |"},{"LineComment":" | ## Concrete Values, Not Semantics"},{"LineComment":" |"},{"LineComment":" | These atoms are **concrete typed parameters**. Semantic elevation scales"},{"LineComment":" | (\"flat\", \"raised\", \"floating\", \"modal\") belong in BrandSchema where the"},{"LineComment":" | brand defines what each level means for their design system."},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | -- BrandSchema defines semantic elevation"},{"LineComment":" | brand.elevationCard = Shadow.layered"},{"LineComment":" |   [ Shadow.boxShadow { offsetX: 0.0, offsetY: 1.0, blur: 3.0, ... }"},{"LineComment":" |   , Shadow.boxShadow { offsetX: 0.0, offsetY: 4.0, blur: 6.0, ... }"},{"LineComment":" |   ]"},{"LineComment":" |"},{"LineComment":" | brand.elevationModal = Shadow.layered"},{"LineComment":" |   [ Shadow.boxShadow { offsetX: 0.0, offsetY: 10.0, blur: 25.0, ... }"},{"LineComment":" |   ]"},{"LineComment":" |"},{"LineComment":" | brand.zIndexDropdown = ZIndex.z 100"},{"LineComment":" | brand.zIndexModal = ZIndex.z 1000"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | Always use qualified imports:"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Schema.Elevation.Shadow as Shadow"},{"LineComment":" | import Hydrogen.Schema.Elevation.ZIndex as ZIndex"},{"LineComment":" |"},{"LineComment":" | myShadow :: Shadow.BoxShadow"},{"LineComment":" | myShadow = Shadow.boxShadow"},{"LineComment":" |   { offsetX: 0.0"},{"LineComment":" |   , offsetY: 4.0"},{"LineComment":" |   , blur: 8.0"},{"LineComment":" |   , spread: 0.0"},{"LineComment":" |   , color: Color.rgba 0 0 0 0.15"},{"LineComment":" |   , inset: false"},{"LineComment":" |   }"},{"LineComment":" |"},{"LineComment":" | myZIndex :: ZIndex.ZIndex"},{"LineComment":" | myZIndex = ZIndex.z 50"},{"LineComment":" | ```"},{"LineComment":" |"},{"LineComment":" | ## Related Pillars"},{"LineComment":" |"},{"LineComment":" | - **Color.Glow**: Emissive light effects (outward glow)"},{"LineComment":" | - **Geometry.Transform**: 3D transforms for perspective effects"},{"LineComment":" | - **Dimension.Camera**: 3D camera for true depth rendering"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[89,14],"start":[84,1]}},"moduleName":["Hydrogen","Schema","Elevation","Shadow"]},{"annotation":{"meta":null,"sourceSpan":{"end":[93,14],"start":[91,1]}},"moduleName":["Hydrogen","Schema","Elevation","ZIndex"]},{"annotation":{"meta":null,"sourceSpan":{"end":[93,14],"start":[71,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Elevation"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Elevation.purs","reExports":{"Hydrogen.Schema.Elevation.Shadow":[],"Hydrogen.Schema.Elevation.ZIndex":["ZIndexAuto","ZIndexValue"]},"sourceSpan":{"end":[93,14],"start":[71,1]}}