or contradiction (0.2)\nSmall inconsistency, easily resolvable.\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Epistemic","Coherence"],"Contradiction"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[150,36],"name":"../../hydrogen/src/Hydrogen/Schema/Epistemic/Coherence.purs","start":[150,1]},"title":"minorContradiction"},{"children":[],"comments":"Significant contradiction (0.5)\nNotable inconsistency requiring attention.\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Epistemic","Coherence"],"Contradiction"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[155,42],"name":"../../hydrogen/src/Hydrogen/Schema/Epistemic/Coherence.purs","start":[155,1]},"title":"significantContradiction"},{"children":[],"comments":"Severe contradiction (0.9)\nFundamental inconsistency, model integrity compromised.\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Epistemic","Coherence"],"Contradiction"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[160,37],"name":"../../hydrogen/src/Hydrogen/Schema/Epistemic/Coherence.purs","start":[160,1]},"title":"severeContradiction"},{"children":[],"comments":"Derive coherence from contradiction level.\nCoherence = 1.0 - Contradiction\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Epistemic","Coherence"],"Contradiction"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Epistemic","Coherence"],"Coherence"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[169,57],"name":"../../hydrogen/src/Hydrogen/Schema/Epistemic/Coherence.purs","start":[169,1]},"title":"coherenceFromContradiction"},{"children":[],"comments":"Derive contradiction from coherence level.\nCon