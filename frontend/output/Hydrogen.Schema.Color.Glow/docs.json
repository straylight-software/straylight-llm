ntents":[["Hydrogen","Schema","Color","Glow"],"Glow"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","RGB"],"RGB"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[168,29],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Glow.purs","start":[168,1]},"title":"glowToRgb"},{"children":[],"comments":"Convert to CSS drop-shadow filter\n\nRenders as `filter: drop-shadow(0 0 {spread}px rgba({r}, {g}, {b}, {alpha}))`\nwhere alpha is derived from luminance intensity.\n\n**Alpha calculation:**\n- 0-100 nits: alpha 0.0-0.3 (subtle)\n- 100-500 nits: alpha 0.3-0.7 (visible)\n- 500+ nits: alpha 0.7-1.0 (intense)\n\n```purescript\nglowToCss myGlow  -- \"drop-shadow(0 0 20px rgba(255, 200, 150, 0.6))\"\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Glow"],"Glow"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"String"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[184,28],"name":"../../hydrogen/src/Hydrogen/Schema/Color/Glow.purs","start":[184,1]},"title":"glowToCss"},{"children":[],"comments":"Update glow color temperature\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Kelvin"],"Kelvin"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Glow"],"Glow"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Color","Glow"],"Glow"],"tag":"TypeConstructor"}],"t