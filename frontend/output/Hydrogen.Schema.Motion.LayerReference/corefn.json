{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                          // hydrogen // schema // motion // layer-reference"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | LayerReference — Unified namespace for layer-to-layer relationships."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | In motion graphics, layers need to reference each other for many purposes:"},{"LineComment":" |"},{"LineComment":" | - **Track Mattes**: Alpha/luma from one layer masks another"},{"LineComment":" | - **Clipping Groups**: Layer clips to the layer directly below"},{"LineComment":" | - **Parenting**: Transform inheritance from parent layer"},{"LineComment":" | - **Effect Inputs**: Effects reference other layers (displacement, set matte)"},{"LineComment":" | - **Expression Links**: Property values driven by other layer properties"},{"LineComment":" | - **Masks**: Vector paths attached to layers"},{"LineComment":" |"},{"LineComment":" | This module provides a **unified reference system** where every layer has"},{"LineComment":" | a unique namespace (UUID5-based) and can be referenced by type-safe links."},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" |"},{"LineComment":" | - **Types**: Core reference types (LayerRef, PropertyRef, EffectRef, MaskRef)"},{"LineComment":" | - **Purpose**: Reference purpose and layer links"},{"LineComment":" | - **TrackMatte**: Track matte relationships"},{"LineComment":" | - **ClippingGroup**: Clipping group management"},{"LineComment":" | - **EffectRef**: Effect layer references and channels"},{"LineComment":" | - **Expression**: Expression links and mask modes"},{"LineComment":" | - **Stack**: Layer stack management"},{"LineComment":" | - **Validation**: Reference validation and composition namespace"},{"LineComment":" |"},{"LineComment":" | ## Dependencies"},{"LineComment":" |"},{"LineComment":" | - Schema.Motion.Composition (TrackMatteMode)"},{"LineComment":" | - Schema.Attestation.UUID5 (UUID5, namespaces)"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[114,29],"start":[106,1]}},"moduleName":["Hydrogen","Schema","Motion","LayerReference","ClippingGroup"]},{"annotation":{"meta":null,"sourceSpan":{"end":[136,25],"start":[116,1]}},"moduleName":["Hydrogen","Schema","Motion","LayerReference","EffectRef"]},{"annotation":{"meta":null,"sourceSpan":{"end":[155,26],"start":[138,1]}},"moduleName":["Hydrogen","Schema","Motion","LayerReference","Expression"]},{"annotation":{"meta":null,"sourceSpan":{"end":[96,23],"start":[78,1]}},"moduleName":["Hydrogen","Schema","Motion","LayerReference","Purpose"]},{"annotation":{"meta":null,"sourceSpan":{"end":[169,21],"start":[157,1]}},"moduleName":["Hydrogen","Schema","Motion","LayerReference","Stack"]},{"annotation":{"meta":null,"sourceSpan":{"end":[104,26],"start":[98,1]}},"moduleName":["Hydrogen","Schema","Motion","LayerReference","TrackMatte"]},{"annotation":{"meta":null,"sourceSpan":{"end":[76,21],"start":[57,1]}},"moduleName":["Hydrogen","Schema","Motion","LayerReference","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[190,26],"start":[171,1]}},"moduleName":["Hydrogen","Schema","Motion","LayerReference","Validation"]},{"annotation":{"meta":null,"sourceSpan":{"end":[190,26],"start":[39,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Motion","LayerReference"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Motion/LayerReference.purs","reExports":{"Hydrogen.Schema.Motion.LayerReference.ClippingGroup":["ClippingGroup","addToClippingGroup","clippingGroupBase","clippingGroupMembers","isInClippingGroup","mkClippingGroup","removeFromClippingGroup"],"Hydrogen.Sc