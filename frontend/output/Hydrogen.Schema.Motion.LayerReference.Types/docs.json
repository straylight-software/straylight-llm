{"comments":"Core reference types for layer-to-layer relationships.\n\n## Design Philosophy\n\nEvery layer, property, effect, and mask has a deterministic UUID5 identity.\nSame definition → same UUID5 → same reference. This enables:\n\n- Reproducible references across runs and systems\n- Deterministic diffing and caching\n- Full algebraic reasoning about layer relationships\n\n## Dependencies\n\n- Schema.Attestation.UUID5 (UUID5, namespaces)\n","declarations":[{"children":[{"comments":null,"info":{"arguments":[{"annotation":[],"contents":[["Hydrogen","Schema","Attestation","UUID5","Namespaces"],"UUID5"],"tag":"TypeConstructor"}],"declType":"dataConstructor"},"sourceSpan":{"end":[75,34],"name":"../../hydrogen/src/Hydrogen/Schema/Motion/LayerReference/Types.purs","start":[75,18]},"title":"LayerRef"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Eq"],"Eq"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Motion","LayerReference","Types"],"LayerRef"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[77,42],"name":"../../hydrogen/src/Hydrogen/Schema/Motion/LayerReference/Types.purs","start":[77,1]},"title":"eqLayerRef"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Ord"],"Ord"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Motion","LayerReference","Types"],"LayerRef"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[78,44],"name":"../../hydrogen/src/Hydrogen/Schema/Motion/LayerReference/Types.purs","start":[78,1]},"title":"ordLayerRef"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Show"],"Show"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Motion","LayerReference","Types"],"Layer