}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[153,38],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Metallic.purs","start":[153,1]},"title":"add"},{"children":[],"comments":"Subtract from metallic value (clamped)\n\nDecreases metallic factor:\n```purescript\nsubtract 0.2 (metallic 0.5)  -- Metallic 0.3\nsubtract 0.5 (metallic 0.3)  -- Metallic 0.0 (clamped)\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Metallic"],"Metallic"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Metallic"],"Metallic"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[163,43],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Metallic.purs","start":[163,1]},"title":"subtract"},{"children":[],"comments":"Check if fully dielectric (non-metal)\n\nDielectric materials (metallic = 0.0) have achromatic specular reflections\nwith Fresnel F0 ≈ 0.04 and full diffuse reflection:\n```purescript\nisDielectric dielectric  -- true\nisDielectric metal       -- false\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Metallic"],"Metallic"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Boolean"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[178,36],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Metallic.purs","start":[178,1]},"title":"isDielectric"},{"children":[],"comments":"Check if fully metallic\n\nPure metals (metallic = 1.0) have no diffuse reflection and use albedo color\nas their Fresnel F0 for colored specular reflections:\n```purescript\nisMetal metal       -- true\nisMetal dielectric  -- false\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Metallic"],"Metallic"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Boolean"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[189,31],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Metallic.purs","start":[189,1]},"title":"isMetal"},{"children":[],"comments":"Check if hybrid/partial metallic (between dielectric and metal)\n\nHybrid values (0.0 < metallic < 1.0) represent oxidized metals, coated\nsurfaces, or procedural transitions. These are common in real-world materials:\n```purescript\nisHybrid partial     -- true\nisHybrid dielectric  -- false\nisHybrid metal       -- false\n```\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Metallic"],"Metallic"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Boolean"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[201,32],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Metallic.purs","start":[201,1]},"title":"isHybrid"}],"name":"Hydrogen.Schema.Spatial.Metallic","reExports":[]}