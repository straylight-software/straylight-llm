{"comments":"Metallic - metallic factor for PBR materials.\n\nRange: 0.0 to 1.0 (clamps)\n- **0.0**: Dielectric (non-metal: plastic, wood, fabric, skin)\n- **0.5**: Partial (oxidized metal, hybrid materials)\n- **1.0**: Pure metal (gold, steel, aluminum)\n\nControls whether a surface follows metal or dielectric BRDF in PBR shading.\nMetals have no diffuse reflection and colored specular (Fresnel F0 from albedo).\nDielectrics have diffuse+specular with achromatic reflections (F0 ≈ 0.04).\n","declarations":[{"children":[{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Eq"],"Eq"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Metallic"],"Metallic"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[63,42],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Metallic.purs","start":[63,1]},"title":"eqMetallic"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Ord"],"Ord"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Metallic"],"Metallic"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[64,44],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Metallic.purs","start":[64,1]},"title":"ordMetallic"},{"comments":null,"info":{"declType":"instance","dependencies":[],"type":{"annotation":[],"contents":[{"annotation":[],"contents":[["Data","Show"],"Show"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Metallic"],"Metallic"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"sourceSpan":{"end":[67,29],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Metallic.purs","start":[66,1]},"title":"showMetallic"}],"comments":"Metallic factor for PBR (0.0 to 1.0)\n\n0 = dielectric (non-metal), 1 = pure metal. Affects Fresnel and energy conservation.\n","info":{"dataDeclType":"newtype","declType":"data","roles":[],"typeArguments":[]},"kind":null,"sourceSpan":{"end":[61,35],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Metallic.purs","start":[61,1]},"title":"Metallic"},{"children":[],"comments":"Create a metallic value, clamping to 0.0-1.0\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Metallic"],"Metallic"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[74,31],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Metallic.purs","start":[74,1]},"title":"metallic"},{"children":[],"comments":"Extract the raw Number value\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Metallic"],"Metallic"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[98,29],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Metallic.purs","start":[98,1]},"title":"unwrap"},{"children":[],"comments":"Convert to Number (passthrough for this type)\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Hydrogen","Schema","Spatial","Metallic"],"Metallic"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[102,31],"name":"../../hydrogen/src/Hydrogen/Schema/Spatial/Metallic.purs","start":[102,1]},"title":"toNumber"},{"c