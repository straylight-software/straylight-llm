{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                   // hydrogen // schema // brush // dynamics"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Brush Dynamics — Response curves and dynamics mappings."},{"LineComment":" |"},{"LineComment":" | Status: PROVEN (proofs/Hydrogen/Schema/Brush/Dynamics.lean)"},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | Dynamics control how input values (pressure, tilt, velocity) map to"},{"LineComment":" | output parameters (size, opacity, flow). Response curves shape the"},{"LineComment":" | feel — soft curves make light touches sensitive, firm curves require"},{"LineComment":" | pressure."},{"LineComment":" |"},{"LineComment":" | All curves are BOUNDED by construction: inputs in [0,1] produce"},{"LineComment":" | outputs in [0,1]. This is proven in Lean4 and critical for safety"},{"LineComment":" | when the input might come from a BMI user or uploaded mind."},{"LineComment":" |"},{"LineComment":" | ## Strong Invariants (Proven in Lean4)"},{"LineComment":" |"},{"LineComment":" | 1. BOUNDS PRESERVATION — Curves map [0,1] → [0,1]"},{"LineComment":" | 2. ENDPOINT PRESERVATION — Curves pass through (0,0) and (1,1)"},{"LineComment":" | 3. MONOTONICITY — Curves are monotonically non-decreasing"},{"LineComment":" | 4. SENSITIVITY BOUNDS — Each curve has finite maximum derivative"},{"LineComment":" | 5. GRADE DEGRADATION — Applying a curve degrades certainty"},{"LineComment":" | 6. OUTPUT RANGE VALIDITY — Mapped values land in [valueAtMin, valueAtMax]"},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from submodules:"},{"LineComment":" |"},{"LineComment":" | - **Types**: ResponseCurve ADT and DynamicsMapping record"},{"LineComment":" | - **Curve**: Curve application functions"},{"LineComment":" |"},{"LineComment":" | ## Dependencies"},{"LineComment":" |"},{"LineComment":" | - Dynamics.Types"},{"LineComment":" | - Dynamics.Curve"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[72,13],"start":[65,1]}},"moduleName":["Hydrogen","Schema","Brush","Dynamics","Curve"]},{"annotation":{"meta":null,"sourceSpan":{"end":[63,13],"start":[50,1]}},"moduleName":["Hydrogen","Schema","Brush","Dynamics","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[72,13],"start":[41,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Brush","Dynamics"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Brush/Dynamics.purs","reExports":{"Hydrogen.Schema.Brush.Dynamics.Curve":["applyCurve","applyCurveRaw","applyMapping","clampToEpsilon","epsilon","lerpUnit"],"Hydrogen.Schema.Brush.Dynamics.Types":["DynamicsMapping","Exponential","Firm","Linear","Logarithmic","SCurve","Soft","allResponseCurves","constantMapping","exponentialMapping","firmMapping","identityMapping","logarithmicMapping","responseCurveDescription","responseCurveMaxSensitivity","sCurveMapping","softMapping"]},"sourceSpan":{"end":[72,13],"start":[41,1]}}