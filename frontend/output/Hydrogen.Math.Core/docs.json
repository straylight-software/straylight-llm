unction"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[494,24],"name":"../../hydrogen/src/Hydrogen/Math/Core.purs","start":[494,1]},"title":"cos"},{"children":[],"comments":"Tangent\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[530,24],"name":"../../hydrogen/src/Hydrogen/Math/Core.purs","start":[530,1]},"title":"tan"},{"children":[],"comments":"Arcsine using Newton's method on sin\n\nFor |x| <= 0.5, use Taylor series\nFor |x| > 0.5, use identity: asin(x) = π/2 - 2*asin(sqrt((1-x)/2))\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[537,25],"name":"../../hydrogen/src/Hydrogen/Math/Core.purs","start":[537,1]},"title":"asin"},{"children":[],"comments":"Arccosine\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[566,25],"name":"../../hydrogen/src/Hydrogen/Math/Core.purs","start":[566,1]},"title":"acos"},{"children":[],"comments":"Arctangent using series expansion\n\nFor |x| <= 1: atan(x) = x - x³/3 + x⁵/5 - ...\nFor |x| > 1: atan(x) = π/2 - atan(1/x)\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[573,25],"name":"../../hydrogen/src/Hydrogen/Math/Core.purs","start":[573,1]},"title":"atan"},{"children":[],"comments":"Two-argument arctangent\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[604,36],"name":"../../hydrogen/src/Hydrogen/Math/Core.purs","start":[604,1]},"title":"atan2"},{"children":[],"comments":"Hyperbolic sine: sinh(x) = (e^x - e^(-x)) / 2\n","info":{"declType":"value","type":{"annotation":[],"contents":[{"annotation":[],"contents":[{"annotation":[],"contents":[["Prim"],"Function"],"tag":"TypeConstructor"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"},{"annotation":[],"contents":[["Prim"],"Number"],"tag":"TypeConstructor"}],"tag":"TypeApp"}},"kind":null,"sourceSpan":{"end":[619,25],"name":"../../hydrogen/src/Hydrogen/Math/Core.purs","start":[619,1]},"title":"sinh"},{"children":[],"comments":