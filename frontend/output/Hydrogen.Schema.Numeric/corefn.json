{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                               // hydrogen // schema // numeric"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Hydrogen.Schema.Numeric — Graded types for error tracking."},{"LineComment":" |"},{"LineComment":" | ## Overview"},{"LineComment":" |"},{"LineComment":" | This module provides the foundational types for tracking numerical"},{"LineComment":" | errors through computation. Based on NumFuzz (Kellison, 2025) graded"},{"LineComment":" | monads and Bean backward error comonads."},{"LineComment":" |"},{"LineComment":" | ## Core Insight"},{"LineComment":" |"},{"LineComment":" | Programs using finite-precision arithmetic are PRODUCERS of rounding error."},{"LineComment":" | The graded monad M[ε] tracks the maximum error bound ε as a type-level grade."},{"LineComment":" |"},{"LineComment":" | ## Sub-modules"},{"LineComment":" |"},{"LineComment":" | - `Grade` — Non-negative error bounds with monoid structure"},{"LineComment":" | - `ForwardError` — Graded monad for forward error tracking"},{"LineComment":" |"},{"LineComment":" | ## Lean Proofs"},{"LineComment":" |"},{"LineComment":" | All operations are proven correct in:"},{"LineComment":" |   proofs/Hydrogen/Schema/Numeric/GradedMonad.lean"},{"LineComment":" |   proofs/Hydrogen/Schema/Numeric/RelativePrecision.lean"},{"LineComment":" |   proofs/Hydrogen/Schema/Numeric/NeighborhoodMonad.lean"},{"LineComment":" |"},{"LineComment":" | ## Usage"},{"LineComment":" |"},{"LineComment":" | ```purescript"},{"LineComment":" | import Hydrogen.Schema.Numeric as N"},{"LineComment":" |"},{"LineComment":" | -- Create exact values"},{"LineComment":" | x = N.exact 42.0"},{"LineComment":" |"},{"LineComment":" | -- Operations accumulate error"},{"LineComment":" | y = N.exact 3.14"},{"LineComment":" | z = N.addReal x y  -- bound = 0 + 0 = 0 (both exact)"},{"LineComment":" |"},{"LineComment":" | -- With approximations"},{"LineComment":" | approxPi = N.fromApprox 3.14159265 3.14 N.machineEpsilon"},{"LineComment":" | result = N.addReal x approxPi  -- bound = 0 + machineEpsilon"},{"LineComment":" | ```"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[90,4],"start":[72,1]}},"moduleName":["Hydrogen","Schema","Numeric","ForwardError"]},{"annotation":{"meta":null,"sourceSpan":{"end":[70,4],"start":[58,1]}},"moduleName":["Hydrogen","Schema","Numeric","Grade"]},{"annotation":{"meta":null,"sourceSpan":{"end":[110,4],"start":[107,1]}},"moduleName":["Hydrogen","Schema","Numeric","Primitives"]},{"annotation":{"meta":null,"sourceSpan":{"end":[105,4],"start":[92,1]}},"moduleName":["Hydrogen","Schema","Numeric","Sensitivity"]},{"annotation":{"meta":null,"sourceSpan":{"end":[110,4],"start":[47,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Numeric"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Numeric.purs","reExports":{"Hydrogen.Schema.Numeric.ForwardError":["addReal","approx","bound","errorMagnitude","exact","fromApprox","fromApproxUnsafe","ideal","mapWithGrade","mulReal","negReal","scaleReal","strengthen","subReal","value","weaken"],"Hydrogen.Schema.Numeric.Grade":["add","grade","isExact","isZero","machineEpsilon","max","mul","olverEpsilon","unGrade","zero"],"Hydrogen.Schema.Numeric.Primitives":["divReal","liftNumber"],"Hydrogen.Schema.Numeric.Sensitivity":["applySensitive","compose","constant","getSensitivity","identity","isContraction","isExpansion","isIsometry","negate","scale","sensitive"]},"sourceSpan":{"end":[110,4],"start":[47,1]}}