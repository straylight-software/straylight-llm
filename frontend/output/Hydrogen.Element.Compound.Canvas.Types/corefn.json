{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                              // hydrogen // element // compound // canvas // types"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Canvas Types — Leader module re-exporting all canvas type submodules."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | The Canvas is the foundational surface for all design tools. It provides:"},{"LineComment":" |"},{"LineComment":" | - **Infinite space**: Pan in any direction, zoom from 0.1% to 6400%"},{"LineComment":" | - **Layer composition**: N-deep stacking with occlusion culling"},{"LineComment":" | - **Material backgrounds**: Each component can have diffusion-ready noise"},{"LineComment":" | - **Shape masking**: Clip paths, mattes, effects on every layer"},{"LineComment":" | - **Hyper-interactivity**: Touch, gesture, haptic, mobile-first"},{"LineComment":" |"},{"LineComment":" | ## Architecture"},{"LineComment":" |"},{"LineComment":" | Canvas wraps Schema.Graph.Viewport for viewport math and adds:"},{"LineComment":" |"},{"LineComment":" | - Tool state (select, pan, zoom, marquee, etc.)"},{"LineComment":" | - Selection management (single, multi, group)"},{"LineComment":" | - Grid/guide rendering"},{"LineComment":" | - Snap behavior"},{"LineComment":" | - History (undo/redo stack)"},{"LineComment":" |"},{"LineComment":" | ## Coordinate Systems"},{"LineComment":" |"},{"LineComment":" | - **Screen space**: Pixels on device (0,0 = top-left of canvas element)"},{"LineComment":" | - **Canvas space**: Infinite coordinate system (can be negative)"},{"LineComment":" | - **Object space**: Local to each object (0,0 = object origin)"},{"LineComment":" |"},{"LineComment":" | Conversion: screen → canvas requires viewport transform."},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | - Types.ObjectId — Object identifier (dependency-free)"},{"LineComment":" | - Types.Core — CanvasId, tools, selection state"},{"LineComment":" | - Types.Object — CanvasObject with compositing"},{"LineComment":" | - Types.Grid — Grid and snap configuration"},{"LineComment":" | - Types.Guide — Guides, canvas config, bounds"},{"LineComment":" | - Types.Selection — Selection operations requiring Object"},{"LineComment":" |"},{"LineComment":" | ## Compositing"},{"LineComment":" |"},{"LineComment":" | For compositing types (BlendMode, Mask, ClipPath), import directly:"},{"LineComment":" |"},{"LineComment":" | - Hydrogen.Schema.Color.Blend (BlendMode, CompositeOp)"},{"LineComment":" | - Hydrogen.Schema.Geometry.Mask (Mask)"},{"LineComment":" | - Hydrogen.Schema.Geometry.ClipPath (ClipPath)"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[114,20],"start":[72,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Types","Core"]},{"annotation":{"meta":null,"sourceSpan":{"end":[167,20],"start":[136,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Types","Grid"]},{"annotation":{"meta":null,"sourceSpan":{"end":[194,21],"start":[170,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Types","Guide"]},{"annotation":{"meta":null,"sourceSpan":{"end":[133,22],"start":[117,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Types","Object"]},{"annotation":{"meta":null,"sourceSpan":{"end":[69,24],"start":[67,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Types","ObjectId"]},{"annotation":{"meta":null,"sourceSpan":{"end":[199,25],"start":[197,1]}},"moduleName":["Hydrogen","Element","Compound","Canvas","Types","Selection"]},{"annotation":{"meta":null,"sourceSpan":{"end":[199,25],"start":[52,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Element","Compound","Canvas","Types"],"modulePath":"../../hydrogen/src/Hydrogen/Element