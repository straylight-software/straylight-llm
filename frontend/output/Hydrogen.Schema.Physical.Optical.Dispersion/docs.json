/Physical/Optical/Dispersion.purs","start":[285,1]},"title":"flintGlass"},{"children":[],"comments":"Dense flint — very high dispersion\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Physical","Optical","Dispersion"],"AbbeNumber"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[289,25],"name":"../../hydrogen/src/Hydrogen/Schema/Physical/Optical/Dispersion.purs","start":[289,1]},"title":"denseFlint"},{"children":[],"comments":"SF11 — dense flint (Schott)\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Physical","Optical","Dispersion"],"AbbeNumber"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[293,19],"name":"../../hydrogen/src/Hydrogen/Schema/Physical/Optical/Dispersion.purs","start":[293,1]},"title":"sf11"},{"children":[],"comments":"SF57 — extra-dense flint (Schott)\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Physical","Optical","Dispersion"],"AbbeNumber"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[297,19],"name":"../../hydrogen/src/Hydrogen/Schema/Physical/Optical/Dispersion.purs","start":[297,1]},"title":"sf57"},{"children":[],"comments":"LaSF9 — lanthanum dense flint\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Physical","Optical","Dispersion"],"AbbeNumber"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[301,20],"name":"../../hydrogen/src/Hydrogen/Schema/Physical/Optical/Dispersion.purs","start":[301,1]},"title":"lasf9"},{"children":[],"comments":"Diamond — exceptional fire, the benchmark\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Physical","Optical","Dispersion"],"FireValue"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[309,25],"name":"../../hydrogen/src/Hydrogen/Schema/Physical/Optical/Dispersion.purs","start":[309,1]},"title":"diamondFire"},{"children":[],"comments":"Moissanite — more