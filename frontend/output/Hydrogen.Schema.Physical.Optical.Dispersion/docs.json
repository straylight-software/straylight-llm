ounded"],"NumberBounds"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[231,35],"name":"../../hydrogen/src/Hydrogen/Schema/Physical/Optical/Dispersion.purs","start":[231,1]},"title":"fireBounds"},{"children":[],"comments":"Calcium fluorite (CaF₂) — lowest dispersion common optical material\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Physical","Optical","Dispersion"],"AbbeNumber"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[241,23],"name":"../../hydrogen/src/Hydrogen/Schema/Physical/Optical/Dispersion.purs","start":[241,1]},"title":"fluorite"},{"children":[],"comments":"Fused silica (SiO₂) — very low dispersion\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Physical","Optical","Dispersion"],"AbbeNumber"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[245,26],"name":"../../hydrogen/src/Hydrogen/Schema/Physical/Optical/Dispersion.purs","start":[245,1]},"title":"fusedSilica"},{"children":[],"comments":"BK7 — standard optical crown glass (Schott)\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Physical","Optical","Dispersion"],"AbbeNumber"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[249,18],"name":"../../hydrogen/src/Hydrogen/Schema/Physical/Optical/Dispersion.purs","start":[249,1]},"title":"bk7"},{"children":[],"comments":"N-BK7 — newer formulation of BK7\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Physical","Optical","Dispersion"],"AbbeNumber"],"tag":"TypeConstructor"}},"kind":null,"sourceSpan":{"end":[253,19],"name":"../../hydrogen/src/Hydrogen/Schema/Physical/Optical/Dispersion.purs","start":[253,1]},"title":"nbk7"},{"children":[],"comments":"PK52A — extra-low dispersion phosphate crown\n","info":{"declType":"value","type":{"annotation":[],"contents":[["Hydrogen","Schema","Physical","Optical","Dispersion"],"AbbeNumber"],"tag":"TypeConstructor"}},"