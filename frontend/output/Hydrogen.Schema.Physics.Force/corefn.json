{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                                     // hydrogen // schema // physics // force"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Force — Physical force primitives for physics-based UI and animation."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | Forces are the drivers of motion. In UI physics, forces create natural-feeling"},{"LineComment":" | animations: springs pull elements to targets, drag slows motion, gravity"},{"LineComment":" | creates weight. This module provides bounded, composable force primitives."},{"LineComment":" |"},{"LineComment":" | ## Force Categories"},{"LineComment":" |"},{"LineComment":" | **Conservative Forces**: Path-independent, have potential energy"},{"LineComment":" | - Gravitational: Constant downward pull"},{"LineComment":" | - Spring/Elastic: Proportional to displacement (Hooke's law)"},{"LineComment":" | - Electrostatic: Attraction/repulsion (UI element interactions)"},{"LineComment":" |"},{"LineComment":" | **Non-Conservative Forces**: Path-dependent, dissipate energy"},{"LineComment":" | - Drag: Proportional to velocity (air resistance)"},{"LineComment":" | - Friction: Opposes motion at contact"},{"LineComment":" | - Damping: Viscous resistance (spring damping)"},{"LineComment":" |"},{"LineComment":" | ## Bounded Design"},{"LineComment":" |"},{"LineComment":" | Force magnitudes are bounded to prevent:"},{"LineComment":" | - Infinite forces (division by zero in inverse-square laws)"},{"LineComment":" | - Numerical instability in simulations"},{"LineComment":" | - Unrealistic behavior at billion-agent scale"},{"LineComment":" |"},{"LineComment":" | ## Units"},{"LineComment":" |"},{"LineComment":" | Forces are dimensionless in UI space. The \"mass\" of a UI element is"},{"LineComment":" | typically 1.0, so force equals acceleration. Physical units (Newtons)"},{"LineComment":" | are not used; instead, forces are calibrated to produce pleasing motion."},{"LineComment":" |"},{"LineComment":" | ## Module Structure"},{"LineComment":" |"},{"LineComment":" | This is a leader module that re-exports from:"},{"LineComment":" | - `Force.Types` — Core Force2D type and vector operations"},{"LineComment":" | - `Force.Conservative` — Gravity, spring, and point forces"},{"LineComment":" | - `Force.Dissipative` — Drag, friction, and damping forces"},{"LineComment":" | - `Force.Fields` — Force fields and application utilities"},{"LineComment":" |"},{"LineComment":" | ## Dependencies"},{"LineComment":" |"},{"LineComment":" | - Prelude (Eq, Ord, Show)"},{"LineComment":" | - Data.Number (sqrt, abs)"},{"LineComment":" |"},{"LineComment":" | ## Dependents"},{"LineComment":" |"},{"LineComment":" | - Motion.Spring (spring physics)"},{"LineComment":" | - Component.Draggable (drag physics)"},{"LineComment":" | - Animation.Physics (physics-based animation)"}],"decls":[],"exports":[],"foreign":[],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[69,66],"start":[69,1]}},"moduleName":["Hydrogen","Schema","Physics","Force","Conservative"]},{"annotation":{"meta":null,"sourceSpan":{"end":[70,64],"start":[70,1]}},"moduleName":["Hydrogen","Schema","Physics","Force","Dissipative"]},{"annotation":{"meta":null,"sourceSpan":{"end":[71,54],"start":[71,1]}},"moduleName":["Hydrogen","Schema","Physics","Force","Fields"]},{"annotation":{"meta":null,"sourceSpan":{"end":[68,52],"start":[68,1]}},"moduleName":["Hydrogen","Schema","Physics","Force","Types"]},{"annotation":{"meta":null,"sourceSpan":{"end":[71,54],"start":[57,1]}},"moduleName":["Prim"]}],"moduleName":["Hydrogen","Schema","Physics","Force"],"modulePath":"../../hydrogen/src/Hydrogen/Schema/Physics/Force.purs","reExports":{"Hydrogen.Schema.Physics.Force.Conservative":["Gravity","PointForce","SpringForce","attractiveForce","gravity","gravityDirection","gravityEarth","gravityForce","gravityHeavy","gravityLight","gravityMagnitude","gravityMoon","gravityZero","pointForce","pointForceFalloff","pointForceStrength","pointForceValue","repulsiveForce","springForce","springForceDefault","springForceSoft","springForceStiff","springForceValue","springPotentialEnergy","springRestLength","springStiffness"],"Hydrogen.Schema.Physics.Force.Dissipative":["DampingForce","DragForce","FrictionForce","dampingCoefficient","dampingCritical","dampingForce","dampingForceValue","dampingHeavy","dampingLight","dragCoefficient","dragForce","dragForceHeavy","dragForceLight","dragForceMedium","dragForceValue","frictionForce","frictionForceValue","frictionIce","frictionKinetic","frictionRubber","frictionStatic","kineticCoefficient","staticCoefficient"],"Hydrogen.Schema.Physics.Force.Fields":["CompositeField","EmptyField","UniformField","accelerationFromForce","addForceToField","applyForce","emptyField","fieldContains","fieldForceAt","netForce","uniformField"],"Hydrogen.Schema.Physics.Force.Types":["Force2D","Conservative","NonConservative","force2D","forceAdd","forceClamp","forceDirection","forceDot","forceDown","forceLeft","forceMagnitude","forceNegate","forceNormalize","forceRight","forceScale","forceSubtract","forceUp","forceX","forceY","forceZero","isConservative","isNonConservative"]},"sourceSpan":{"end":[71,54],"start":[57,1]}}