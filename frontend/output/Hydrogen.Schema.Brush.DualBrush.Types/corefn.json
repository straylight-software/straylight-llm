{"builtWith":"0.15.15","comments":[{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":"                     // hydrogen // schema // brush // dualbrush // types"},{"LineComment":" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"},{"LineComment":" | Dual Brush Types — ADTs for combining two brush tips."},{"LineComment":" |"},{"LineComment":" | ## Design Philosophy"},{"LineComment":" |"},{"LineComment":" | Dual brush combines two brush tips to create complex textures and effects."},{"LineComment":" | Unlike texture (which applies a continuous pattern), dual brush uses a"},{"LineComment":" | secondary brush tip that stamps within or masks the primary brush stroke."},{"LineComment":" |"},{"LineComment":" | The secondary tip has its own scatter, size, and spacing, creating effects"},{"LineComment":" | like textured brushes, vegetation, splatter, and complex marks that would"},{"LineComment":" | be difficult to achieve with a single tip."},{"LineComment":" |"},{"LineComment":" | ## Dual Brush Mode"},{"LineComment":" |"},{"LineComment":" | How the two brush tips combine:"},{"LineComment":" |"},{"LineComment":" | - **Multiply**: Darkest wins (intersection of both tips)"},{"LineComment":" | - **ColorBurn**: Intense intersection, high contrast"},{"LineComment":" | - **Subtract**: Secondary cuts into primary"},{"LineComment":" | - **Intersect**: Only where both tips exist"},{"LineComment":" | - **Overlay**: Complex blending for varied effects"},{"LineComment":" |"},{"LineComment":" | ## Use Cases"},{"LineComment":" |"},{"LineComment":" | | Primary    | Secondary | Mode      | Effect             |"},{"LineComment":" | |------------|-----------|-----------|-------------------|"},{"LineComment":" | | Soft Round | Speckle   | Multiply  | Textured brush    |"},{"LineComment":" | | Hard Round | Grass     | Intersect | Detailed vegetation|"},{"LineComment":" | | Flat       | Noise     | Subtract  | Rough edges       |"},{"LineComment":" | | Airbrush   | Splatter  | Multiply  | Spray texture     |"},{"LineComment":" |"},{"LineComment":" | ## Dependencies"},{"LineComment":" |"},{"LineComment":" | - Prelude"}],"decls":[{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"bindType":"NonRec","expression":{"abstraction":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[150,51],"start":[150,49]}},"type":"Var","value":{"identifier":"eq","moduleName":["Data","Eq"]}},"annotation":{"meta":{"metaType":"IsSyntheticApp"},"sourceSpan":{"end":[150,71],"start":[150,29]}},"argument":{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"type":"Var","value":{"identifier":"eqString","moduleName":["Data","Eq"]}},"type":"App"},"identifier":"eq"},{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"bindType":"NonRec","expression":{"abstraction":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[138,23],"start":[138,21]}},"type":"Var","value":{"identifier":"append","moduleName":["Data","Semigroup"]}},"annotation":{"meta":{"metaType":"IsSyntheticApp"},"sourceSpan":{"end":[138,88],"start":[138,3]}},"argument":{"annotation":{"meta":null,"sourceSpan":{"end":[0,0],"start":[0,0]}},"type":"Var","value":{"identifier":"semigroupString","moduleName":["Data","Semigroup"]}},"type":"App"},"identifier":"append"},{"annotation":{"meta":null,"sourceSpan":{"end":[85,16],"start":[80,1]}},"bindType":"NonRec","expression":{"annotation":{"meta":null,"sourceSpan":{"end":[85,16],"start":[80,1]}},"constructorName":"DualMultiply","fieldNames":[],"type":"Constructor","typeName":"DualBrushMode"},"identifier":"DualMultiply"},{"annotation":{"meta":null,"sourceSpan":{"end":[85,16],"start":[80,1]}},"bindType":"NonRec","expression":{"annotation":{"meta":null,"sourceSpan":{"end":[85,16],"start":[80,1]}},"constructorName":"DualColorBurn","fieldNames":[],"type":"Constructor","typeName":"DualBrushMode"},"identifier":"DualColorBurn"}